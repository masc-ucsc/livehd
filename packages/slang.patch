-FetchContent_Declare(
-  fmt
-  GIT_REPOSITORY https://github.com/fmtlib/fmt.git
-  GIT_TAG 12.1.0
-  GIT_SHALLOW ON
-  ${find_pkg_args})
-
-# Force fmtlib to always be a static lib if we pull it via FetchContent (i.e.
-# not intercepted by find_package), since it's a private dependency that's
-# mostly header-only already.
+# LiveHD: the Bazel sandbox has no network, so this fmt FetchContent cannot run.
+# Add the @fmt archive (passed in via FMT_CMAKE_PATH) as a subdirectory instead.
+# fmt_FOUND stays unset, so the install section below still exports fmt into
+# slangTargets and the rest of external/CMakeLists.txt is used unchanged (vendored
+# boost fallback, expected.hpp / boost / BS_thread_pool installs). fmt_SOURCE_DIR
+# (normally set by FetchContent) is set so the fmt header install still resolves.
+get_filename_component(FMT_ROOT_DIR "${FMT_CMAKE_PATH}" DIRECTORY)
+set(fmt_SOURCE_DIR "${FMT_ROOT_DIR}")
 set(saved_build_shared_libs ${BUILD_SHARED_LIBS})
 set(BUILD_SHARED_LIBS OFF)
-FetchContent_MakeAvailable(fmt)
+add_subdirectory("${FMT_ROOT_DIR}" fmt EXCLUDE_FROM_ALL)
 set(BUILD_SHARED_LIBS ${saved_build_shared_libs})

 if(NOT TARGET fmt::fmt)

