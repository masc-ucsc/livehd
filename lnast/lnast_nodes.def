#if !defined(LNAST_NODE)
#error Must define LNAST_NODE macro.
#endif

#ifndef LNAST_NODE
#define LNAST_NODE( NAME, VERBAL )
#endif

#ifndef LNAST_LOOP_NODE
#define LNAST_LOOP_NODE( NAME, VERBAL ) LNAST_NODE( NAME, VERBAL )
#endif

// Invalid
LNAST_NODE( invalid, invalid )

// Tree Structure
LNAST_NODE( top, top )
LNAST_NODE( stmts, stmts )
LNAST_NODE( if, if )
// `unique if` / `match`: same child shape as `if` (cond, stmts, [cond,
// stmts]*, [else-stmts]) but the conditions are declared mutually exclusive
// (an implicit assume). tolg lowers it to a Hotmux instead of a Mux chain.
// Use Lnast_ntype::is_if_like() when if/unique_if are handled alike.
LNAST_NODE( unique_if, uif )
LNAST_NODE( for, for )
LNAST_NODE( while, while )
LNAST_NODE( func_call, fcall )
LNAST_NODE( func_def, fdef )
LNAST_NODE( io, io )

// Pseudo-functions emitted by prp2lnast for keywords that share the
// `func_call` shape but want a distinct dispatch tag instead of a
// `const(name)` first child. has/in/does are folded by constprop;
// case/break/continue/return are emitted verbatim.
LNAST_NODE( func_does, does )
LNAST_NODE( func_equals, equals )
LNAST_NODE( func_in, in )
LNAST_NODE( func_has, has )
LNAST_NODE( func_case, case )
LNAST_NODE( func_break, break )
LNAST_NODE( func_continue, continue )
LNAST_NODE( func_return, return )

// Assignment
// Task 1t — `assign` was DELETED. The single `store` node below is now the one
// write/bind node: statement scalar writes, field-path writes (old tuple_set),
// tuple-literal field payloads `(x=v)`, func_def/io signature params, and typed
// binds `name=value:type` are ALL `store`, disambiguated by parent context
// (only `store` STATEMENTS — direct stmts children — are arity-dispatched).
LNAST_NODE( dp_assign, dp_assign )  // FIXME: remove FUTURE

// Task 1t — declaration + bare-write nodes (replace the statement-level
// assign/tuple_set writes and the attr_set(type)+attr_set(comptime)+type_spec
// declaration triple). `dp_assign` is now the low anchor of is_primitive_op.
//   declare( ref(var), type_decl, const(qualifier), [value] )
//     - type_decl : a type node (prim_type_*/comp_type_*) or a `ref` to a
//                   named type, or prim_type_none when no `:type`.
//     - qualifier : single const, space-joined tokens (storage first), e.g.
//                   "mut", "const", "mut comptime", "mut wrap", "const".
//     - value     : optional init (absent for bare `var x:u8`).
//   store( ref(var), level0..levelN, value )
//     - 0 levels  == old assign; N levels == old tuple_set path.
LNAST_NODE( declare, declare )
LNAST_NODE( store, store )

// Deferred / past-cycle read:
//   delay_assign dst src offset
// - dst    : fresh tmp ref
// - src    : declared variable ref (pre-SSA name)
// - offset : comptime const (int).  Positive = future/next-cycle (reg D, wire settled);
//                                   negative = past cycle; 0 = reg Q pin (reg only)
LNAST_NODE( delay_assign, delay_assign )

// Operators
// - Bitwidth
LNAST_NODE( bit_and, bit_and )
LNAST_NODE( bit_or , bit_or )
LNAST_NODE( bit_not, bit_not )
LNAST_NODE( bit_xor, bit_xor )
// - Bitwidth Insensitive Reduce
LNAST_NODE( red_or , red_or )
LNAST_NODE( red_and, red_and )
LNAST_NODE( red_xor, red_xor )
LNAST_NODE( popcount, popcount )
// - Logical
LNAST_NODE( log_and, log_and )
LNAST_NODE( log_or , log_or )
LNAST_NODE( log_not, log_not )
// - Arithmetic
LNAST_NODE( plus, plus )
LNAST_NODE( minus, minus )
LNAST_NODE( mult, mult )
LNAST_NODE( div, div )
LNAST_NODE( mod, mod )
// - Shift
LNAST_NODE( shl, shl )
LNAST_NODE( sra, sra )
// - Bit Manipulation
LNAST_NODE( sext, sext )
LNAST_NODE( set_mask, set_mask )
LNAST_NODE( get_mask, get_mask )
// - Comparison
LNAST_NODE( ne, ne )
LNAST_NODE( eq, eq )
LNAST_NODE( lt, lt )
LNAST_NODE( le, le )
LNAST_NODE( gt, gt )
LNAST_NODE( ge, ge )

// Variables
LNAST_NODE( ref, ref )
LNAST_NODE( const, const )
LNAST_NODE( range, range )

// Task 1q — pipeline stage annotation: stages( const(min), const(max) ).
// Attached as the TRAILING child (identify by ntype, not position — the type
// child is optional) of each OUTPUT io `store` entry of a `pipe` func_def,
// and of the output reg `declare` the LN pipe upass inserts. Encoding:
//   pipe[N]     -> (N, N)        pipe[A..=B] -> (A, B)
//   pipe[A..<B] -> (A, B-1)      bare pipe   -> (1, 0)  max 0 = unconstrained
// comb/mod outputs carry no stages node (absent == (0,0)). Values are the
// SCC/sigma stage depth contract of 06c-pipelining.md; see
// the LiveHD docs.
LNAST_NODE( stages, stages )

// Task 1r — `x@[N]` cycle-check record: timecheck( ref(name), const(min),
// const(max) ). A STATEMENT (child of stmts), flop-free and inert: it asserts
// that `name` lands at the given absolute cycle (counted from the enclosing
// lambda's inputs) and is consumed by the future pipe/mod typecheck pass.
// `@[N]` -> (N, N). The `@[]` opt-out emits no timecheck at all. NEVER lower
// `@[N]` to delay_assign — that node moves values in time (past/.[defer]);
// timecheck only checks. SSA renames the ref child like any other read.
LNAST_NODE( timecheck, timecheck )

// Tuple Statements
// Task 1t — `tuple_set` deleted: statement-level field writes are now `store`
// (the same node that subsumed the statement-level scalar `assign`). A `store`
// with ≥3 children walks the old tuple_set path; with ≤2 it is a scalar write.
LNAST_NODE( tuple_concat, tuple_concat )
LNAST_NODE( tuple_add, tuple_add )
LNAST_NODE( tuple_get, tuple_get )

// Attribute Statements
LNAST_NODE( attr_set, attr_set )
LNAST_NODE( attr_get, attr_get )

// Compiler Internals
LNAST_NODE( cassert, cassert )

// Type Statements
// Task 1t — `type_def` deleted: `type Foo = …` lowers to `declare(mode=="type")`.
LNAST_NODE( type_spec, type_spec )  // FIXME: change to type_check

// Types
// Task 1t — the single "no/inferred/unresolved type" sentinel (unifies the
// former none_type + unknown_type).
LNAST_NODE( prim_type_none, prim_type_none )
// Task 1t/typesystem: the canonical integer type — `prim_type_int( [max], [min] )`
// with two OPTIONAL const children (absent ⇒ unbounded). Sign and bits are
// DERIVED from the range, never stored. The legacy width-based
// `prim_type_uint`/`prim_type_sint` were deleted in T5 (everything — uN/sN
// sugar, the inliner, ssa — now emits prim_type_int). See
// the LiveHD docs.
LNAST_NODE( prim_type_int, prim_type_int )
LNAST_NODE( prim_type_range, prim_type_range )
LNAST_NODE( prim_type_string, prim_type_string )
LNAST_NODE( prim_type_bool, prim_type_bool )
LNAST_NODE( comp_type_tuple, comp_type_tuple )
LNAST_NODE( comp_type_array, comp_type_array )
LNAST_NODE( comp_type_lambda, comp_type_lambda )
// Task 1t — DELETED: `prim_type_type`/`prim_type_ref` (moved into the declare
// `mode` enum), `comp_type_mixin` (FIXME stub), `unknown_type` (folded into the
// `prim_type_none` sentinel above), `type_def` (→ declare mode==type), and
// `expr_type` (a named type is now a `ref` in the type slot). `comp_type_lambda`
// is now the last type node (is_type upper bound).
// FIXME: add union

#undef LNAST_NODE
#undef LNAST_LOOP_NODE
