#!/usr/bin/env bash

set -euo pipefail

usage() {
  echo "usage: $0 <instance-netlist-colors> <orig-source-colors> [instance-name]" >&2
  echo "example: $0 pp.netlist.colors pp.source.colors _35031_" >&2
  exit 1
}

if [[ $# -lt 2 || $# -gt 3 ]]; then
  usage
fi

instance_trace=$1
path_trace=$2
instance_name=${3-}

if [[ ! -f ${instance_trace} ]]; then
  echo "missing file: ${instance_trace}" >&2
  exit 1
fi

if [[ ! -f ${path_trace} ]]; then
  echo "missing file: ${path_trace}" >&2
  exit 1
fi

awk -F',' -v instance_name="${instance_name}" '
  function trim(text) {
    gsub(/^[[:space:]]+|[[:space:]]+$/, "", text)
    return text
  }

  function emit_name(name,  bit, base) {
    name = trim(name)
    if (name == "") {
      return
    }

    if (match(name, /\[[0-9]+\]$/)) {
      bit  = substr(name, RSTART + 1, RLENGTH - 2)
      base = substr(name, 1, RSTART - 1)
      print name
      print base "." bit
      print base
      return
    }

    if (match(name, /\[[0-9]+:[0-9]+\]$/)) {
      base = substr(name, 1, RSTART - 1)
      print base
      return
    }

    print name
  }

  BEGIN {
    OFS = "\n"
  }

  NF >= 4 {
    if (instance_name != "" && trim($2) != instance_name) {
      next
    }

    names = $4
    n = split(names, arr, /[[:space:]]+/)
    for (i = 1; i <= n; ++i) {
      emit_name(arr[i])
    }
  }
' "${instance_trace}" | sort -u | awk -F',' '
  function trim(text) {
    gsub(/^[[:space:]]+|[[:space:]]+$/, "", text)
    return text
  }

  function strip_bus(name,  base) {
    if (match(name, /\[[0-9]+\]$/)) {
      base = substr(name, 1, RSTART - 1)
      return base
    }
    return ""
  }

  # First file (stdin): load signals into a hash set
  NR == FNR {
    s = trim($0)
    if (s != "") sigs[s] = 1
    next
  }

  # Second file (path_trace): match tokens against signals
  NF >= 4 {
    # Check instance name (field 2)
    t = trim($2)
    if (t in sigs) { print trim($3); next }

    # Check wire names (field 4) - space-separated tokens
    n = split($4, arr, /[[:space:]]+/)
    for (i = 1; i <= n; i++) {
      t = trim(arr[i])
      if (t in sigs) { print trim($3); next }
      b = strip_bus(t)
      if (b != "" && b in sigs) { print trim($3); next }
    }

    # Check node/instance names (field 5) - space-separated tokens
    if (NF >= 5) {
      n = split($5, arr, /[[:space:]]+/)
      for (i = 1; i <= n; i++) {
        t = trim(arr[i])
        if (t in sigs) { print trim($3); next }
        b = strip_bus(t)
        if (b != "" && b in sigs) { print trim($3); next }
      }
    }
  }
' - "${path_trace}" | sed -e 's/ /\n/g' | awk 'NF && $0 != "-"' | sort -u
