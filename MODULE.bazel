# tree-sitter-pyrope (top of tree: "remove is from grammar", daf3508)
# To bump the pin, recompute integrity via:
#   curl -sL https://github.com/masc-ucsc/tree-sitter-pyrope/archive/<commit>.zip | openssl dgst -sha256 -binary | base64
# LOCAL OVERRIDE (task 1f-is_typename): pointing at ../tree-sitter-pyrope
# (daf3508 "remove is from grammar") so `a is b` is a syntax error. daf3508 is now
# published on origin/main; the http_archive pin below mirrors it (top of tree) and
# can be swapped in for the local override when a published checkout is preferred.
# http_archive(
#     name = "tree-sitter-pyrope",
#     build_file = "//packages:tree-sitter-pyrope.BUILD",
#     integrity = "sha256-DHZ/ChtWmV07FBhgEaDSG8lBVcQU39u8cA0GIXK+XW0=",
#     strip_prefix = "tree-sitter-pyrope-daf3508b6612eb6ae11d119354155c4e05baa297",
#     urls = ["https://github.com/masc-ucsc/tree-sitter-pyrope/archive/daf3508b6612eb6ae11d119354155c4e05baa297.zip",
#     ],
# )
new_local_repository(
    name = "tree-sitter-pyrope",
    build_file = "//packages:tree-sitter-pyrope.BUILD",
    path = "../tree-sitter-pyrope",
)

