# GMP -- cvc5's bignum backend. cvc5's non-GPL prebuilt static libs leave the
# GMP symbols undefined (they are not bundled, to avoid the LGPL libgmp.a); they
# are satisfied at the final `lhd` link by this hermetic BCR build of GMP (no
# dependency on a system/homebrew libgmp). See packages/cvc5.BUILD.
bazel_dep(name = "gmp", version = "6.3.0.bcr.1")

