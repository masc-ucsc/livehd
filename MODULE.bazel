# prpparse — hand-written recursive-descent Pyrope parser; the inou/prp front-end
# (it replaced the tree-sitter-pyrope grammar, so neither @tree-sitter nor
# @tree-sitter-pyrope is a dependency anymore). Rooted at the prpparse/ subdir of
# the tree-sitter-pyrope repo so consumers include `prpparse/<hdr>` (no clash with
# LiveHD's core diag.hpp / parser.hpp); see //packages:prpparse.BUILD.
# To bump the pin, recompute integrity via:
#   curl -sL https://github.com/masc-ucsc/tree-sitter-pyrope/archive/<commit>.zip | openssl dgst -sha256 -binary | base64
http_archive(
    name = "prpparse",
    build_file = "//packages:prpparse.BUILD",
    integrity = "sha256-jWNdIxpybeecNDg+aJYxi0VXJz/IURCLlFTuhwNxDVg=",
    strip_prefix = "tree-sitter-pyrope-0f4e69f28e8abb9075c5e3ce1e5b3864df85bfb1/prpparse",
    urls = ["https://github.com/masc-ucsc/tree-sitter-pyrope/archive/0f4e69f28e8abb9075c5e3ce1e5b3864df85bfb1.zip"],
)
# For local prpparse co-development, swap the http_archive above for:
# new_local_repository(
#     name = "prpparse",
#     build_file = "//packages:prpparse.BUILD",
#     path = "../tree-sitter-pyrope/prpparse",
# )

