# lhd — the stateless, hermetic LiveHD CLI kernel (task 1y-bazel).
# Contract: the LiveHD docs. lhd links the pass/inou registry
# and drives it via argv; the legacy lgshell REPL was removed 2026-06-04.

load("@rules_cc//cc:defs.bzl", "cc_binary", "cc_library")
load("//tools:copt_default.bzl", "COPTS")

# Formal-source content salt (2f-fcore ruling 2026-07-10): hash every prover
# source (pass/lec + pass/semdiff + the cvc5 pin) into a constant baked into the
# binary. The verdict cache keys on it, so a prover change auto-invalidates all
# cached verdicts while unrelated lhd rebuilds keep the cache warm. shasum is
# macOS-native; sha256sum is the coreutils fallback (a failed exec consumes no
# stdin, so the pipe re-reads cleanly).
genrule(
    name = "formal_salt",
    srcs = [
        "//pass/lec:formal_srcs",
        "//pass/semdiff:formal_srcs",
        "//packages:cvc5_repo.bzl",
    ],
    outs = ["formal_salt.hpp"],
    cmd = "h=$$(cat $(SRCS) | (shasum -a 256 2>/dev/null || sha256sum) | cut -c1-16); " +
          "printf '// Generated by //lhd:formal_salt -- DO NOT EDIT.\\n" +
          "// Content hash of pass/lec + pass/semdiff + the cvc5 pin: the formal\\n" +
          "// verdict-cache engine-identity salt (todo/livehd/2f-fcore.html sec 3).\\n" +
          "#pragma once\\n#include <cstdint>\\n" +
          "namespace livehd { inline constexpr uint64_t kFormalSrcSalt = 0x%sULL; }\\n' \"$$h\" > $@",
)

cc_library(
    name = "lhd_lib",
    srcs = [
        "formal_cache.cpp",
        "formal_cache.hpp",
        "formal_salt.hpp",
        "lhd_kernel.cpp",
        "lhd_kernel_common.cpp",
        "lhd_kernel_compile.cpp",
        "lhd_kernel_formal.cpp",
        "lhd_kernel_internal.hpp",
        "lhd_kernel_passes.cpp",
        "lhd_kernel_sim.cpp",
        "lhd_kernel_tool.cpp",
        "lhd_meta.cpp",
        "lhd_options.cpp",
        "lhd_result.cpp",
    ],
    hdrs = ["lhd.hpp"],
    copts = COPTS,
    includes = ["."],
    visibility = ["//visibility:public"],
    deps = [
        "//core",
        "//graph",
        "//inou/cgen:inou_cgen",
        "//inou/prp:inou_prp",
        "//inou/slang:inou_slang",
        "//inou/yosys:lgyosys",
        "//lnast",
        "//pass/abc:pass_abc",
        "//pass/bitwidth:pass_bitwidth",
        "//pass/color:pass_color",
        "//pass/common:pass",
        "//pass/liberty:pass_liberty",
        "//pass/opentimer:pass_opentimer",
        "//pass/cprop:pass_cprop",
        "//pass/isabelle:pass_isabelle",
        "//pass/lean:pass_lean",
        "//pass/lec:lec_query",
        "//pass/lec:pass_lec",
        "//pass/formal:pass_formal",
        "//pass/partition:pass_partition",
        "//pass/semdiff:pass_semdiff",
        "//pass/semdiff:semdiff",
        "//pass/lnastfmt:pass_lnastfmt",
        "//pass/prp_writer:pass_prp_writer",
        "//pass/upass:pass_upass",
        "//upass/tolg:upass_tolg",
        "@hhds//hhds:tree_edit_distance",
        "@opentimer//:taskflow",  # the OT-bundled copy — see packages/opentimer.BUILD for the ODR rule
        "@rapidjson",
    ],
)

cc_binary(
    name = "lhd",
    srcs = [
        "lhd_main.cpp",
        "lhd_pyrope.cpp",
        "lhd_pyrope.hpp",
    ],
    additional_linker_inputs = ["lhd_export.lds"],
    copts = COPTS,
    data = [
        "//inou/yosys:scripts",
    ],
    # `--export-dynamic` lets the dlopen'd yosys-slang plugin bind to the Yosys
    # symbols in this binary; the version script then force-localizes lhd's own
    # slang/fmt/boost so they do not interpose the plugin's incompatible
    # embedded copies (see lhd_export.lds). macOS has no version-script flag and
    # does not run the yosys-slang plugin path, so it is Linux-only.
    linkopts = select({
        "@platforms//os:macos": ["-lz"],
        "//conditions:default": [
            "-Wl,--export-dynamic",
            "-lz",
            "-Wl,--version-script=$(location lhd_export.lds)",
        ],
    }),
    visibility = ["//visibility:public"],
    deps = [
        ":lhd_lib",
        "//lsp",
        "@tree_sitter_pyrope//:prpfmt",
    ],
)
