#!/bin/bash

if [ ${NO_CHECK}"x" == "1x" ]; then
  # disable check for performance monitoring
  exit 0
fi

if [ -x "bazel-bin/inou/yosys/yosys2" ]; then
  YOSYS="./bazel-bin/inou/yosys/yosys2"
elif [ -x "inou/yosys/yosys2" ]; then
  YOSYS="inou/yosys/yosys2"
elif [ -x "lgshell.runfiles/livehd/inou/yosys/yosys2" ]; then
  YOSYS="lgshell.runfiles/livehd/inou/yosys/"
else
  YOSYS=$(which yosys)
fi

CELLLIB=""
OPT_TOP=""
GOLD_TOP=""
GATE_TOP=""
GOLD=""
GATE=""
while true; do
  case "$1" in
  -r | --reference)
    case "$2" in
    "") shift 2 ;;
    *)
      GOLD=$2
      shift 2
      ;;
    esac
    ;;
  -i | --implementation)
    case "$2" in
    "") shift 2 ;;
    *)
      GATE=$2
      shift 2
      ;;
    esac
    ;;
  -l | --cell_library)
    case "$2" in
    "") shift 2 ;;
    *)
      CELLLIB=$2
      shift 2
      ;;
    esac
    ;;
  --yosys)
    case "$2" in
    "") shift 2 ;;
    *)
      YOSYS=$2
      shift 2
      ;;
    esac
    ;;
  --top)
    case "$2" in
    "") shift 2 ;;
    *)
      OPT_TOP=$2
      shift 2
      ;;
    esac
    ;;
  --reference_top | --gold_top)
    # top module name to select on the reference/gold side (overrides --top)
    case "$2" in
    "") shift 2 ;;
    *)
      GOLD_TOP=$2
      shift 2
      ;;
    esac
    ;;
  --implementation_top | --gate_top)
    # top module name to select on the implementation/gate side (overrides --top)
    case "$2" in
    "") shift 2 ;;
    *)
      GATE_TOP=$2
      shift 2
      ;;
    esac
    ;;
  "") break ;;
  *)
    argument=$1
    if [ ${argument:0:1} == "-" ]; then
      echo "Option $1 not recognized!"
      exit 1
    else
      if [ "${GOLD}" == "" ]; then
        GOLD=$1
        shift 1
      else
        GATE=$1
        shift 1
      fi
    fi
    ;;
  esac
done

if [ ! -f "${GATE}" ]; then
  echo "gate circuit ${GATE} not a valid file"
  exit 1
fi

if [ ! -f ${GOLD} ]; then
  echo "gold circuit ${GOLD} not a valid file"
  exit 1
fi

if [ ! -f "${YOSYS}" ]; then
  if [ -x "/usr/bin/yosys" ]; then
    YOSYS=/usr/bin/yosys
  elif [ -x "/usr/local/bin/yosys" ]; then
    YOSYS=/usr/local/bin/yosys
  else
    echo "lgcheck: unable to fix YOSYS path"
    exit 5
  fi
fi

# Per-side top defaults: an unset --reference_top/--implementation_top falls
# back to the shared --top, so plain `--top X` keeps working unchanged.
if [ "${GOLD_TOP}" == "" ]; then GOLD_TOP=$OPT_TOP; fi
if [ "${GATE_TOP}" == "" ]; then GATE_TOP=$OPT_TOP; fi

fm_top=$OPT_TOP
if [ "${fm_top}" == "" ]; then
  fm_top=$GATE_TOP
fi
if [ "${fm_top}" == "" ]; then
  filename=$(basename -- "$GATE")
  fm_top="${filename%.*}"
  if [[ $fm_top =~ "long_" ]]; then
    fm_top=${fm_top:5}
  elif [[ $fm_top =~ "fixme_" ]]; then
    fm_top=${fm_top:6}
  fi
fi

if [ -z $FM_SHELL ]; then
  FM_SHELL=$(which fm_shell)
fi

if [ -x "${FM_SHELL}" ]; then
  echo "using formality"

  echo "
  set_app_var synopsys_auto_setup true
  set_app_var hdlin_ignore_parallel_case false
  set_app_var hdlin_ignore_full_case false
  read_sverilog -r  \"${GOLD}\"
  set_top ${GOLD_TOP:-$fm_top}
  read_sverilog -i  \"${GATE}\"
  set_top ${GATE_TOP:-$fm_top}
  match
  report_unmatched_points >> \"fm_${fm_top}_error.log\"
  if { ![verify] }  {
    report_failing_points >> \"fm_${fm_top}_error.log\"
    report_aborted >> \"fm_${fm_top}_error.log\"
    analyze_points -all >> \"fm_${fm_top}_error.log\"
  }
  exit
  " >fm_script_${fm_top}.tcl

  ${FM_SHELL} -64bit -f fm_script_${fm_top}.tcl | grep "Verification SUCCEEDED"
  if [ $? -eq 0 ]; then
    echo "5.Successfully matched ${GATE} with ${GOLD} top:${fm_top}"
    exit 0
  fi

  echo "WARN: formality failed to prove equivalency."
fi

echo "using yosys:"${YOSYS}

if [ ! -f ${YOSYS} ]; then
  echo "Yosys binary not found"
  exit 1
fi

# Select each side's top independently so the reference and implementation may
# use DIFFERENT module names (both are renamed to gold/gate before comparison).
GOLD_TOP_STR="-auto-top"
if [ "${GOLD_TOP}" != "" ]; then
  GOLD_TOP_STR="-top $GOLD_TOP"
fi
GATE_TOP_STR="-auto-top"
if [ "${GATE_TOP}" != "" ]; then
  GATE_TOP_STR="-top $GATE_TOP"
fi

echo "checking GATE:$GATE (top:${GATE_TOP}) vs GOLD:$GOLD (top:${GOLD_TOP}) directory:$PWD"

# cgen output `include`s memory models (cgen_memory_*.v) that live in
# ware/rtl. Resolve the directory relative to this script (works both in a
# repo checkout and inside bazel runfiles) with a cwd-relative fallback.
SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
VLG_INC=""
for d in "${SELF_DIR}/../../ware/rtl" "ware/rtl"; do
  if [ -d "$d" ]; then
    VLG_INC="-I$d"
    break
  fi
done

if [ "${CELLLIB}" != "" ]; then
  if [ ! -f ${CELLLIB} ]; then
    echo "cell library ${CELLLIB} not found"
    exit 1
  fi
  # lib="read_verilog -sv ${CELLLIB}"
  lib="read_liberty ${CELLLIB}"
fi

#exit 2

yosys_read="read_verilog -sv ${GOLD}; hierarchy ${GOLD_TOP_STR}; proc; flatten; rename -top gold; design -stash gold;
            read_verilog -sv ${VLG_INC} ${GATE}; hierarchy ${GATE_TOP_STR}; proc; flatten; rename -top gate; design -stash gate;
            design -copy-from gold -as gold gold; design -copy-from gate -as gate gate; ${lib};"

yosys_prep="proc; memory -nomap; write_verilog trace0.v ; equiv_make gold gate equiv; write_verilog trace0b.v ; prep -flatten -top equiv; hierarchy -top equiv; hierarchy -check; flatten; proc; opt_clean;"

yosys_equiv="equiv_simple;"
#yosys_equiv_extra="${yosys_simple}; equiv_simple -seq 4; equiv_induct -seq 4;"
yosys_equiv_extra="${yosys_simple}; equiv_induct -seq 4;"

${YOSYS} -p "${yosys_read}; ${yosys_prep}; ${yosys_equiv}; write_verilog trace1.v ; equiv_status -assert" \
  2>/dev/null | tee lgcheck1.log | grep "Equivalence successfully proven!"

if [ $? -eq 0 ]; then
  echo "1.Successfully matched ${GATE} with ${GOLD} top:${OPT_TOP}"
  exit 0
fi

#${YOSYS} -p " read_verilog -sv ${GOLD}; hierarchy ${TOP_STR}; opt ; prep; memory; rename -top gold; design -stash gold;
#read_verilog -sv ${VLG_INC} ${GATE}; hierarchy ${TOP_STR}; opt ; prep; memory; rename -top gate; design -stash gate;
#design -copy-from gold -as gold gold
#design -copy-from gate -as gate gate
#
#miter -equiv -make_assert -make_outcmp -flatten gold gate equiv
#hierarchy -top equiv
#sat -prove-asserts -tempinduct -timeout 30 -ignore_unknown_cells -verify -set-init-undef equiv" \
#    2> /dev/null | grep "Equivalence successfully proven!"
#if [ $? -eq 0 ]; then
#  echo "Successfully matched ${GATE} with ${GOLD} top:${OPT_TOP}"
#  exit 0
#fi

if grep -q reset ${GOLD}; then
  # Assert the miter's reset (the `in_`-prefixed gold/gate shared input) for
  # the first two cycles, then release it from cycle 2 — a deterministic LEC
  # start that brings both sides through their reset path to a known state.
  #
  # 2d-reg fix: the prior `-set in_reset 1` applied the constraint to EVERY
  # temporal-induction timestep (not just cycle 0/1), pinning reset high
  # forever — so every reset-bearing register stayed at its reset value and
  # ANY two such circuits proved trivially equivalent (a vacuous pass:
  # add-vs-sub "matched"). Use per-cycle `-set-at` so reset is high only at
  # cycles 0 and 1 and the induction step runs with reset free (normal
  # operation), where a real difference is actually observable.
  RESET_STMT="-set-at 0 in_reset 1 -set-at 1 in_reset 1 -set-at 2 in_reset 0"
else
  RESET_STMT=""
fi

${YOSYS} -p " read_verilog -sv ${GOLD}; hierarchy ${GOLD_TOP_STR}; proc; opt; flatten ; rename -top gold; prep -top gold ; design -stash gold;
              read_verilog -sv ${VLG_INC} ${GATE}; hierarchy ${GATE_TOP_STR}; proc; opt; flatten ; rename -top gate; prep -top gate ; design -stash gate;
              design -copy-from gold -as gold gold
              design -copy-from gate -as gate gate

              miter -equiv -flatten -make_outputs -ignore_gold_x gold gate miter
              hierarchy -top miter
              write_verilog trace2.v
              sat -tempinduct-def -timeout 90 -prove trigger 0 ${RESET_STMT} -set-init-zero -ignore_unknown_cells -show-ports miter
              " \
  2>lgcheck2.err | tee lgcheck2.log | grep "proven: SUCC"
if [ $? -eq 0 ]; then
  echo "2.Successfully matched ${GATE} with ${GOLD} top:${OPT_TOP}"
  exit 0
fi

#${YOSYS} -p "${yosys_read};
#    proc; memory -nomap; opt_expr -full; opt -purge; opt -purge;
#    opt_reduce -full; opt_expr -mux_undef; opt_reduce; opt_merge; opt_clean -purge;
#    ${yosys_prep}; opt -purge; proc; opt -purge; ${yosys_equiv}; equiv_status -assert"
#
#if [ $? -eq 0 ]; then
#  echo "3.Successfully matched ${GATE} with ${GOLD} top:${OPT_TOP}"
#  exit 0
#fi

${YOSYS} -p "${yosys_read};
    memory -nomap; opt_expr -full; opt -purge; proc; opt -purge;
    opt_reduce -full; opt_expr -mux_undef; opt_reduce; opt_merge; opt_clean -purge; techmap -map +/adff2dff.v;
    ${yosys_prep}; opt -purge; proc; opt -purge; ${yosys_equiv_extra}; equiv_status -assert" \
  2>/dev/null | tee lgcheck4.log | grep "Equivalence successfully proven!"

if [ $? -eq 0 ]; then
  echo "4.Successfully matched ${GATE} with ${GOLD} top:${OPT_TOP}"
  exit 0
fi

LGCHECK_BMC_STEPS="${LGCHECK_BMC_STEPS:-5}"
if [[ "${LGCHECK_BMC_STEPS}" =~ ^[0-9]+$ ]] && [ "${LGCHECK_BMC_STEPS}" -gt 0 ]; then
  echo "INFO: running bounded miter check (LGCHECK_BMC_STEPS=${LGCHECK_BMC_STEPS})"

  # `sat -prove trigger 0` (formulation borrowed from hagent/tool/
  # equiv_check.py) emits an explicit marker in BOTH directions:
  #   not equivalent -> "SAT proof finished - model found: FAIL!"
  #   equivalent     -> "SAT proof finished - no model found: SUCCESS!"
  # One query per depth 1..N so transient (init-dependent) mismatches at
  # shallow depths are not masked by the deepest step.
  bmc_sat_cmds=""
  for ((t = 1; t <= LGCHECK_BMC_STEPS; t++)); do
    bmc_sat_cmds+="sat -ignore_unknown_cells -seq ${t} -set-at ${t} trigger 1 -prove trigger 0 -set-init-zero -set-def-inputs -show-ports miter; "
  done

  # No -q: yosys -q suppresses the SAT report itself, so the log would always
  # be empty and the greps below would vacuously "pass" any pair of designs.
  ${YOSYS} -p "read_verilog -sv ${GOLD}; hierarchy ${GOLD_TOP_STR}; proc; memory; opt; flatten ; rename -top gold; prep -top gold ; design -stash gold;
               read_verilog -sv ${VLG_INC} ${GATE}; hierarchy ${GATE_TOP_STR}; proc; memory; opt; flatten ; rename -top gate; prep -top gate ; design -stash gate;
               design -copy-from gold -as gold gold
               design -copy-from gate -as gate gate
               miter -equiv -flatten -make_outputs -ignore_gold_x gold gate miter
               async2sync
               hierarchy -top miter
               ${bmc_sat_cmds}
               " \
    2>lgcheck_bmc.err >lgcheck_bmc.log

  if grep -q "model found: FAIL" lgcheck_bmc.log; then
    echo "WARN: bounded check found a mismatch within ${LGCHECK_BMC_STEPS} steps (see lgcheck_bmc.log)."
    echo "FAIL: circuits are not equivalent ${GATE} vs ${GOLD} with top:${fm_top}"
    exit 1
  fi

  # A hard yosys error here (port-list mismatch in `miter`, parse error, bad
  # top) means the designs cannot even be compared: report non-equivalent,
  # never a silent pass (same policy as hagent/tool/equiv_check.py).
  if grep -q "^ERROR" lgcheck_bmc.err; then
    echo "WARN: bounded miter check failed: $(grep -m1 '^ERROR' lgcheck_bmc.err)"
    echo "FAIL: circuits are not equivalent ${GATE} vs ${GOLD} with top:${fm_top}"
    exit 1
  fi

  # Sound pass requires the explicit SUCCESS marker from every bounded depth.
  if [ "$(grep -c 'no model found: SUCCESS' lgcheck_bmc.log)" -eq "${LGCHECK_BMC_STEPS}" ]; then
    echo "BMC.Successfully matched ${GATE} with ${GOLD} within ${LGCHECK_BMC_STEPS} steps top:${fm_top}"
    exit 0
  fi

  echo "WARN: bounded miter check did not run to completion (see lgcheck_bmc.err); inconclusive."
fi

echo "WARN: Yosys failed to prove equivalency."

echo "FAIL: circuits are not equivalent ${GATE} vs ${GOLD} with top:${fm_top}"
exit 1
