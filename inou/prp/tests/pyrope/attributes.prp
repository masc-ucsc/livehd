/*
:name: attributes
:type: parsing lnast comptime
:verifier_pass: 2
:verifier_fail: 0
*/

comb top(a::[comptime], b::[comptime], c) -> (r) {
  mut x = 0
  r = (a.[comptime], b.[comptime], c.[comptime])
  cassert (true, true, false) == r
}

reg x:u32

const z = top(10, 30, x)
cassert z == (true, true, false)
