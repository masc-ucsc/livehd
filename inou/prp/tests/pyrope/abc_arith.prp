/*
:name: abc_arith
:type: lgraph compile
*/

// Flat combinational arithmetic fixture for pass.abc (task 2i-abc_arith):
// adders (2- and 3-operand Sum) plus the comparators LT/GT/EQ, with no
// hierarchy and no narrowing (every output is wide enough to hold its value),
// so the design stays a clean combinational cone that ABC can bit-blast with
// the selected adder architecture, optimize and technology-map. The
// comparators exercise the subtractor path of the same adder framework. The
// shifts (`shc` constant amount, `shv` runtime amount) exercise the
// combinational SHL bit-blast (constant re-wiring + runtime barrel shifter).
mod abc_arith(a:u4, b:u4, c:u4, d:u2) -> (sum:u5@[0], sum3:u6@[0], lt:u1@[0], gt:u1@[0], eq:u1@[0], shc:u7@[0], shv:u7@[0]) {
  sum  = a + b
  sum3 = a + b + c
  lt   = a < b
  gt   = a > b
  eq   = a == b
  shc  = a << 3
  shv  = a << d
}
