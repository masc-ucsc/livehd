/*
:name: bit_select
:type: parsing lnast comptime
:verifier_pass: 5
:verifier_fail: 1
*/

const x = 0x12345678
const y1 = x#[0]
const y2 = x#[0..=7]
const y3 = x#^[1..=4]
const y4 = x#|[0..=4]
const y5 = x#^[0..=3]

cassert y1 == 0
cassert y2 == 0x78
cassert y3 == (1 ^ 1 ^ 0 ^ 0)
cassert y4 == (1 | 0 | 0 | 0)
cassert y5 == (1 ^ 0 ^ 0 ^ 0)
cassert false
