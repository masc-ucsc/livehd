/*
:name: scope2
:type: comptime
:verifier_pass: 10
:verifier_fail: 0
*/

// Count note (1i): `mytest` carries 2 internal casserts and is inlined at 2
// call sites, so the runner-spliced IR contains 4 instances (was deduped to 2
// by the old constprop evaluator). Per-instantiation counting is intentional —
// each inlined copy is a distinct compile-time check.

comb mytest(a,b)->(r) {
  cassert(a == 11)
  cassert(b == 12)

  b += 100

  r = a+b

  a += 100
}

mut a = 1
cassert(a != nil)

{
  mut b = 2
  cassert(a == 1 and b == 2)

  mut z = mytest(a=10+a,b=10+b)

  cassert(z == 123)
  cassert(a == 1 and b == 2)
}

mut z = mytest(a=10+a,b=12)
cassert(z == 123)
cassert(a == 1)
