// 2f-lnimport — LNAST-level import of a Pyrope unit. `import("lib_add")` binds
// the whole pub namespace; `import("lib_add.my_add")` binds one pub entry.
const lib = import("lib_add")
cassert(lib.my_add(a=1, b=2) == 3)

const f = import("lib_add.my_add")
cassert(f(a=3, b=4) == 7)
