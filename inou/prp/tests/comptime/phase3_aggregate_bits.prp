/*
:name: phase3_aggregate_bits
:type: parsing lnast comptime
:verifier_pass: 4
:verifier_fail: 0
*/

// Phase 3 — under the typesystem redesign aggregates have no `.[bits]`
// (only scalars do). Per-field `.[bits]` reads require an annotated
// field; untyped fields read as nil.

const t = (a:u3=5, b:u2=2, c:u7=100)
cassert(t.a.[bits] == 3)
cassert(t.b.[bits] == 2)
cassert(t.c.[bits] == 7)
cassert(t.[bits] == nil)
