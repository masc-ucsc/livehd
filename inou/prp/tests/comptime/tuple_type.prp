/*
:name: tuple_type
:type: parsing lnast comptime
:verifier_pass: 10
:verifier_fail: 0
*/

cassert ((a=1,b=2) has "a")

cassert (b=100,a=333,e=40,5) does (a=1,b=3)
cassert (a=100,300,b=333,e=40,5) does (a=1,3)
cassert (a=1,3) !does (b=100,300,a=333,e=40,5)

// `equals` after bundle_sorted: same set of named names + same count of
// unnamed entries. Specific names matter (this is the named-tuple half).
cassert (x=1,d=4) equals (d=7,x=100)
cassert (x=1,d=4) !equals (a=2,b=4)

// Decision 5: canonical storage means source order doesn't matter for
// named entries. `(x=1,4)` and `(4,x=1)` both store as
// {named:{x:1}, unnamed:[4]} and compare equal.
cassert (x=1,d=4) == (d=4,x=1)
cassert (x=1,4)   == (x=1,4)
cassert (x=1,4)   == (4,x=1)

// Different named entries → unequal.
cassert (x=1,4) != (y=1,4)
