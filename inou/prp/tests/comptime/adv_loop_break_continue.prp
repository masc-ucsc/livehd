/*
:name: adv_loop_break_continue
:type: comptime
:verifier_pass: 2
:verifier_fail: 0
*/
// Two loop-unroll defects (same upass-runner mechanism):
// 1. `continue` inside a comptime-unrolled `for` is a no-op (skipped iteration still runs).
mut s = 0
for i in 0..<5 {
  if i == 2 { continue }
  s = s + i
}
cassert(s == 8)              // 0+1+3+4 (i==2 skipped)

// 2. a break-only-exit loop (`while true`/`loop`) must iterate until the break,
//    not run the body once.
mut a = 0
while true {
  a += 1
  if a >= 5 { break }
}
cassert(a == 5)
