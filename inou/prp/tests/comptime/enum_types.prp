/*
:name: enum_types
:type: parsing
*/

comb robot_charge() -> (s:string) { s = "robot charge" }
comb person_consume() -> (s:string) { s = "person consume" }
comb cyborg_consume() -> (s:string) { s = "cyborg consume" }
comb cyborg_charge() -> (s:string) { s = "cyborg charge" }
comb potato_consume() -> (s:string) { s = "potato consume" }

const Robot = (charge = robot_charge)
const Person = (consume = person_consume)
const Cyborg = (consume = cyborg_consume, charge = cyborg_charge)
const Potato = (consume = potato_consume)

comb nourish(x) -> (r:string) {
  cassert (x does Person) or (x does Robot)
  r = match x {
    does Person { x.consume() }
    does Robot  { x.charge()  }
  }
}
