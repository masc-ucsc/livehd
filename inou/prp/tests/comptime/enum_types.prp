/*
:name: enum_types
:type: parsing lnast comptime
:verifier_pass: 4
:verifier_fail: 0
*/

comb robot_charge(self) -> (s:string) { s = "robot charge" }
comb person_consume(self) -> (s:string) { s = "person consume" }
comb cyborg_consume(self) -> (s:string) { s = "cyborg consume" }
comb cyborg_charge(self) -> (s:string) { s = "cyborg charge" }
comb potato_consume(self) -> (s:string) { s = "potato consume" }

comptime const Robot = (charge = robot_charge)
comptime const Person = (consume = person_consume)
comptime const Cyborg = (consume = cyborg_consume, charge = cyborg_charge)
comptime const Potato = (consume = potato_consume)

comb nourish(x) -> (r:string) {
  cassert((x does Person) or (x does Robot))
  r = match x {
    does Person { x.consume() }
    does Robot  { x.charge()  }
    else        { cassert(false); "" }
  }
}

const r = nourish(Robot)
cputs("r:{r}")
cassert(r == "robot charge")

const p = nourish(Person)
cassert(p == "person consume")
