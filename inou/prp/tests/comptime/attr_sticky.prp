/*
:name: attr_sticky
:type: parsing lnast comptime
:verifier_pass: 17
:verifier_fail: 0
*/

mut b = 100
const c = 2

const a::[debug,foo] = 3

b = a + c

cassert b::[debug] and !b::[foo]
cassert b == 5

const x:a = 100

cassert not x::[debug]
cassert x == 100

const y = a
cassert y::[debug] and y::[foo]
cassert y == 3

mut z = a
cassert z::[debug] and z::[foo]
cassert z == 3

z = 300
cassert z::[debug] and z::[foo]
cassert z == 300

z::[potato] = 55
cassert !z::[potato]
cassert z::[debug] and z::[foo]

z:u4:[saturate] = 3000
cassert !z::[saturate] and z == 15
cassert z::[debug] and z::[foo]

const l = 1 + z::[foo]
cassert l::[debug] and !l::[foo] and l == 3001

const m = z::[fop]
cassert m::[debug] and m::[foo] and m == 3000

const n = z::[foo] + 0
cassert n::[debug] and !n::[foo] and n == 3000
