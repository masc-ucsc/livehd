/*
:name: attr_sticky
:type: parsing lnast comptime
:verifier_pass: 20
:verifier_fail: 0
*/

mut b = 100
const c = 2

const a::[debug,_foo,foo] = 3

b = a + c

cassert(b.[debug] and b.[_foo] and b.[foo] == nil)
cassert(b == 5)

const x:a = 100

cassert(x.[debug] != nil)
cassert(x == 100 and a == 3)

const y = a
cassert(y.[debug] and y.[_foo] and y.[foo])
cassert(y == 3)

mut z = a
cassert(z.[debug] and z.[_foo] and z.[foo])
cassert(z == 3)

z = 300
cassert(z.[debug] and z.[_foo] and z.[foo])
cassert(z == 300)

cassert(z.[potato] == nil)
cassert(z.[debug] and z.[_foo] and z.[foo])

sat z:u4 = 3000
cassert(z.[saturate] == nil and z == 15)
cassert(z.[debug] and z.[_foo] and z.[foo])

const l = 1 + if z.[_foo] { 200 } else {300}
cassert(l.[debug] and l.[_foo] and l.[foo] == nil)

if z.[_foo] { cassert(true) } else { cassert(false) }
cassert(l == 201)

const m = z
cassert(z == 15)
cassert(m == 15)
cassert(m.[debug] and m.[_foo] and m.[foo])
