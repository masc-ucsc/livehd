/*
:name: tuple_simple6
:type: parsing lnast comptime
:verifier_pass: 6
:verifier_fail: 0
*/

mut x = (a:u32 = 3, b = 4, mut 5)

cassert(x == (a=3,b=4,5))
cassert(x == (b=4,5,a=3))
cassert(x == (5) ++ (a=3,b=4))
cassert(x != (a=3,foo=4,5))
cassert(x == (5,a=3,b=4))
x[0] += 5
cassert(x == (a=3,b=4,10))
