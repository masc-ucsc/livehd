/*
:name: phase2_attr_max_min
:type: parsing lnast comptime
:verifier_pass: 9
:verifier_fail: 0
*/

// Phase 2 — basic attribute reads of the bitwidth bounds. uN/sN width types
// are syntax sugar for max/min, so reads should return consistent answers
// regardless of how the bounds were declared. (`:[range=…]` sugar was
// removed — bounds are declared only via `int(max=,min=)` or `uN`/`sN`.)

mut a:u8 = nil
cassert(a.[max] == 255)
cassert(a.[min] == 0)

mut b:s8 = nil
cassert(b.[max] == 127)
cassert(b.[min] == -128)

mut c:int(max=300, min=0) = nil
cassert(c.[max] == 300)
cassert(c.[min] == 0)

mut d:int(min=0, max=300) = nil
cassert(d.[max] == 300)
cassert(d.[min] == 0)

mut e:int(min=-10, max=10) = nil
cassert(e.[max] == 10)
