/*
:name: mix_tup
:type: comptime
:verifier_pass: 2
:verifier_fail: 0
*/

type Mix_tup = (
  mut flag:bool = false,
  mut state:u2
)

mod mix_tup_init(ref self:Mix_tup) {
  self.flag  = true
  self.state = 2                     // every cycle code
}

mut x:Mix_tup = nil
mut y:Mix_tup = mix_tup_init

cassert(!x.flag and x.state != 2)
cassert( y.flag and y.state == 2)
