/*
:name: bitreverse
:type: comptime
:verifier_pass: 10
:verifier_fail: 0
*/

// Phase 8 typesystem: `.[bits]` is declared-type-driven, so the
// reverse helpers take concrete widths. Untyped operands have nil
// bits and can't drive the loop bound; reads on `:uN`/`:sN`-typed
// values give the declared width.

comb sreverse(x:s6) -> (total:s6) {
  mut t:s6 = nil
  for i in 0..<x.[bits] {
    t#[i] = x#[x.[bits]-1-i]
  }
  total = t
}
comb reverse(x:u6) -> (total:u6) {
  mut t:u6 = nil
  cputs("x has {x}")
  for i in 0..<x.[bits] {
    t#[i] = x#[x.[bits]-1-i]
    cputs("t#{i} = x#{x.[bits]-1-i} // {t#[i]} = {x#[x.[bits]-1-i]}")
  }
  total = t
}

mut x0:u6 = 0ub00010110
cassert(x0.[bits] == 6)
cputs("reverse(x=x0):{reverse(x0)}")
//cassert(reverse(x0) == 0ub011010, "reverse(0ub00010110) should bit-reverse to 0ub011010") // leading zeros do not affect bits
//cassert(sreverse(x0) == 0ub011010, "sreverse(x0) should equal unsigned 0ub011010")
//cassert(sreverse(x0) == 0sb011010)

