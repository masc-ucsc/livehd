/*
:name: bitreverse
:type: comptime
:verifier_pass: 10
:verifier_fail: 0
*/

// Phase 8 typesystem: `.[bits]` is declared-type-driven, so the
// reverse helpers take concrete widths. Untyped operands have nil
// bits and can't drive the loop bound; reads on `:uN`/`:sN`-typed
// values give the declared width.

comb sreverse(x:s6) -> (total:s6) {
  mut t:s6 = nil
  //cputs("serverse: x has {x:b} bits={x.[bits]}")
  for i in 0..<x.[bits] {
    t#[i] = x#[x.[bits]-1-i]
    //cputs("t#{i} = x#{x.[bits]-1-i} // {t#[i]} = {x#[x.[bits]-1-i]}")
  }
  total = t
}
comb reverse(x) -> (total:u6) {
  mut t:u6 = nil
  //cputs("reverse: x has {x:b}")
  for i in 0..<x.[bits] {
    t#[i] = x#[x.[bits]-1-i]
    //cputs("t#{i} = x#{x.[bits]-1-i} // {t#[i]} = {x#[x.[bits]-1-i]}")
  }
  total = t
}

mut x0:u6 = 0ub00010110
cassert(x0.[bits] == 6)
cputs("reverse(x={x0:b}):{reverse(x0):b}")
cassert(reverse(x0) == 0ub011010, "reverse(0ub00010110) should bit-reverse to 0ub011010") // leading zeros do not affect bits
cassert(sreverse(x0) == 0ub011010, "sreverse(x0) should equal unsigned 0ub011010")
cassert(sreverse(x0) == 0sb011010)

const x1:u6 = 0ub1011
cassert(x1.[bits] == 6)
cputs("reverse({x1}:b)={reverse(x1):b}")
cassert(reverse(x1) == 0ub0110100, "reverse(x1) where x1=0ub001011")
cassert(sreverse(x1) == 0sb110100)

mut x2:s4 = 0sb1011 // negative number
cassert(x2.[bits] == 4)
cputs("reverse({x2})={reverse(x2)}")
cassert(reverse(x2) == 0ub01101)
cputs("sreverse({x2})={sreverse(x2)}")
cassert(sreverse(x2) == -9)
