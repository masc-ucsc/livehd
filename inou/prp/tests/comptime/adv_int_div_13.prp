/*
:name: adv_int_div_13
:type: comptime
:verifier_pass: 4
:verifier_fail: 0
*/

// Division result fits into typed destinations (range-fit check).
// `(-9)/3 == -3` clearly fits s3 (range -4..3). The plain `d == -3`
// cassert proves the value is really -3.
const a:u8 = 200 / 2
const b:s4 = (-14) / 2
const c:u1 = 5 / 5
const d:s3 = (-9) / 3

cassert(a == 100)
cassert(b == -7)
cassert(c == 1)
cassert(d == -3)
