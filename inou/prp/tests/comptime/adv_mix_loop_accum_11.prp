/*
:name: adv_mix_loop_accum_11
:type: comptime
:verifier_pass: 3
:verifier_fail: 0
*/

// A pair binding `for (index, value) in t` enumerates (index first, value
// second) — 05b-statements.md. The body accumulates over each element.
const bund = (1,2,3,4)
mut sum_via_index = 0
for (index, v) in bund {
  sum_via_index = sum_via_index + bund[index]
}
cassert(sum_via_index == 10)

mut sum_via_val = 0
for (index, v) in bund {
  sum_via_val = sum_via_val + v
}
cassert(sum_via_val == 10)

mut idx_acc = 0
for (index, v) in bund {
  idx_acc = idx_acc + index
}
cassert(idx_acc == 6)
