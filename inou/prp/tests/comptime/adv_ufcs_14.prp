/*
:name: adv_ufcs_14
:type: comptime
:verifier_pass: 2
:verifier_fail: 0
*/

// Extension method added after a type declaration (doc 06-functions.md lines
// 754-765): `t1.double = t1_do_double` attaches a new method that UFCS can call.
// Doc asserts y.a == 6 after y.double().
const t1 = (mut a:u32 = 0)

comb t1_do_double(ref self) { self.a *= 2 }
t1.double = t1_do_double

mut y:t1 = (a=3)
y.double()
cassert(y.a == 6)

y.double()
cassert(y.a == 12)
