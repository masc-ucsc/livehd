/*
:name: adv_ufcs_14
:type: comptime
:verifier_pass: 2
:verifier_fail: 0
*/

// A free `comb f(ref self, …)` is callable as a UFCS method on any value of the
// matching shape: `y.t1_do_double()` lowers to `t1_do_double(ref y)`. (Attaching
// the function to a NON-EXISTENT field — `t1.double = t1_do_double` — is a
// compile error: a tuple has no `double` field and `t1` is const; UFCS on the
// free name is the supported form.)
const t1 = (mut a:u32 = 0)

comb t1_do_double(ref self) { self.a *= 2 }

mut y:t1 = (a=3)
y.t1_do_double()
cassert(y.a == 6)

y.t1_do_double()
cassert(y.a == 12)
