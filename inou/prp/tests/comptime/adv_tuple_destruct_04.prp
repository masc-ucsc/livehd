/*
:name: adv_tuple_destruct_04
:type: comptime
:verifier_pass: 4
:verifier_fail: 0
*/

// Per 03-bundle.md "Named-tuple destructuring": when the RHS is a named tuple
// (a lambda return OR ANY TUPLE LITERAL WITH NAMED FIELDS), destructuring on
// the LHS matches BY NAME. A named tuple literal bound to a const should
// destructure by field name, exactly like a lambda return.

const lit = (const foo = 8, const bar = 9)

const (foo, bar) = lit
cassert(foo == 8)
cassert(bar == 9)

// Three named fields, every field bound by name (boundary values).
const lit3 = (const x = -1, const y = 0, const z = 1)
const (x, y, z) = lit3
cassert(x == -1 and y == 0 and z == 1)
cassert(x + y + z == 0)
