/*
:name: wrap_complex
:type: parsing lnast comptime
:verifier_pass: 8
:verifier_fail: 0
*/

mut x::[sbits=8] = 0
mut z::[ubits=8] = 0

x::[wrap] = 0sb1001_0111_1111
cassert x == 0sb0111_1111
z::[wrap] = 0sb1001_0111_1111
cassert z == 0sb0111_1111

x::[wrap] = 0sb1001_1101_0011
cassert x == 0sb1101_0011
z::[wrap] = 0sb1001_1101_0011
cassert z == 0sb01101_0011

x::[saturate] = 0sb1001_1101_0011
cassert x == 0sb1000_0000
z::[saturate] = 0sb1001_1101_0011
cassert z == 0

x::[saturate] = 0sb0001_1101_0011
cassert x == 0sb0111_1111
z::[saturate] = 0sb0001_1101_0011
cassert z == 0sb0111_1111
