/*
:name: case_insensitive
:type: comptime
:verifier_pass: 6
:verifier_fail: 0
*/
// Names (modules/lambdas, variables, tuple fields) match case-insensitively
// while the original spelling is preserved. Instantiating `Adder`/`adder`
// resolves the `comb ADDER`; reading `MYVAR`/`MyVar` resolves `const myVar`;
// reading `rec.field`/`rec.FIELD` resolves the `Field` tuple field.

comb ADDER(a, b) -> (r) { r = a + b }
cassert(Adder(a=1, b=2) == 3)
cassert(adder(a=10, b=5) == 15)

const myVar = 7
cassert(MYVAR == 7)
cassert(myvar + MyVar == 14)

const rec = (const Field=3, const other=4)
cassert(rec.field == 3)
cassert(rec.FIELD + rec.Other == 7)
