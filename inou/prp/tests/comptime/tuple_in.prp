/*
:name: tuple_in
:type: parsing lnast comptime
:verifier_pass: 8
:verifier_fail: 0
*/

// `a in b` requires b to be an UNNAMED tuple/array whose elements share a's
// type (integer width/signedness may differ). It expands to
// `a == b[0] or a == b[1] or …`; constprop folds the constant comparisons.
cassert(2 in (1, 2, 3))
cassert(3 in (1, 2, 3))            // matches the last element
cassert(not (0 in (1, 2, 3)))
cassert(not (9 in (1, 2, 3)))

cassert(7 in (7,))                 // single-element array
cassert(not (7 in ()))             // empty array ⇒ always false

const a:u4 = 3
cassert(a in (1, 300, 3))          // mixed integer widths are allowed

cassert((1, 2) in ((3, 4), (1, 2)))  // tuples compare structurally
