:name: adv_bitsel_slice_12
:type: comptime
:verifier_pass: 3
:verifier_fail: 0
*/

// 04-variables.md range section: convert a range to a one-hot integer with #[..]
//   cassert((1..=3)#[..] == 0ub1110)
// (FINDING: (1..=3)#[..] folds to 1, not the one-hot 0ub1110)
const r = 1..=3

cassert(r#[..] == 0ub1110)
cassert((1..=3)#[..] == 0ub1110)
cassert((0..=2)#[..] == 0ub0111)
