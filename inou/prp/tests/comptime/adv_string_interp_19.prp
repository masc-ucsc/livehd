/*
:name: adv_string_interp_19
:type: comptime
:verifier_pass: 4
:verifier_fail: 0
*/

// std::format-style positional argument form: string(fmt, args...) with {}
// placeholders. Per 02-basics.md the placeholders are filled left-to-right by
// the trailing arguments, so this must equal the inline-interpolation result.
const num = 2
const color = "blue"
const extension = "s"

const txt1 = "I have {num:d} {color} potato{extension}"
const txt2 = string("I have {:d} {} potato{}", num, color, extension)

cassert(txt1 == "I have 2 blue potatos")
cassert(txt2 == "I have 2 blue potatos")
cassert(txt1 == txt2)
cassert(string("{:d}", 7) == "7")
