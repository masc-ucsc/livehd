/*
:name: bitrange_open
:type: comptime
:verifier_pass: 6
:verifier_fail: 0
*/

// Open-ended bit slice `a#[k..]` over a COMPTIME value: selects bits k..MSB,
// packed LSB-first as an UNSIGNED value (the `#[]` zero-extend / "force"
// select). 0xAB = 0b1010_1011 (8 bits).
const a = 0xAB

cassert(a#[0..] == 0xAB)   // whole value (== bare `#[..]`)
cassert(a#[1..] == 0x55)   // 0b1010101
cassert(a#[3..] == 0x15)   // 0b10101
cassert(a#[4..] == 0xA)    // 0b1010
cassert(a#[7..] == 0x1)    // top bit set
cassert(a#[8..] == 0x0)    // past the MSB -> no bits
