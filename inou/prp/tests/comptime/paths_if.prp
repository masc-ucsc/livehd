/*
:name: paths_if
:type: comptime
:verifier_pass: 9
:verifier_fail: 0
:verifier_include_funcs: true
*/


mut c = 1

if true {
}else{
    c = 2
}

if false {
    c += 3
}

cassert(c == 1)

if false {
}else{
    c = 2
}

if true {
    c += 3
}

cassert(c == 5)

if false { c = 100 }
cassert(c == 5)
if not true { c = 100 }
cassert(c == 5)

if true { c = 100 }
cassert(c == 100)
if not false { c = 200 }
cassert(c == 200)

comb no_know_input(a)->(r) {
  // Inner-scope folding under an uncertain cond: writes are visible while
  // the body is walked, so casserts inside the if can fold against the
  // in-progress value. On exit constprop invalidates anything assigned
  // inside, which is what the (future) `cassert !c.[comptime]` would prove.
  mut c = 1
  mut d = 2
  // FIXME: cassert c.[comptime]   (future, once attribute reads are supported)
  if a {
    cassert(c == 1)
    c = d + 1
    cassert(c == 3)
  }
  // FIXME: cassert !c.[comptime]  (future, once attribute reads are supported)

  r = 1

  if true {
    r = 2
  }else{
    r = 100
  }
  cassert(r == 2)

  if a { // NOT comptime - both branches converge, but invalidate-on-exit
         // gives up the convergent value. Convergent-branch path-merge is
         // a follow-up.
    r = 200
  }else{
    r = 200
  }
  // FIXME: cassert !r.[comptime]   (future, once attribute reads are supported)

  r = 1
  if a { // NOT comptime - COULD NOT BE OPTIMIZED
    r = 200
  }
  if a { // NOT comptime - COULD NOT BE OPTIMIZED
  }else{
    r = 100
  }
  // After the two runtime `if a`s, r is runtime-divergent (r ∈ {100, 200} —
  // never 1). It loses its dlop trivial status on uncertain-exit, so a cassert
  // over it cannot fold at compile time. NO cassert here: the old
  // `cassert(r == 1)` only "passed" via the unsound nil-on-uncertain-exit
  // discharge, which wrongly passed an always-false claim. Proving the real
  // bound (r ∈ {100,200}) needs convergent-branch / range path-merge — a
  // follow-up (see crand_test1).
}
