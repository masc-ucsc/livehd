/*
:name: tuple_simple_attr
:type: parsing lnast comptime
:verifier_pass: 4
:verifier_fail: 0
*/

mut foo::[potato=4] = (a=-1)

foo ++= (b = 1)

foo ++= (const c::[bits=5] = 2)

cassert(foo == (a=-1, b=1, c=2))
cassert(foo.c.[bits] == 5)   // declared-type-driven: bits=5 from c::[bits=5]
cassert(foo.[potato] == 4)
cassert(foo.b.[potato] == 4)
