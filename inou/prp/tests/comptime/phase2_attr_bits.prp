/*
:name: phase2_attr_bits
:type: parsing lnast comptime
:verifier_pass: 6
:verifier_fail: 0
*/

// Phase 2 — `.[bits]` reads under the typesystem redesign (entry 1v).
// Declaration-driven: typed `:uN`/`:sN` → fixed envelope; untyped → nil.
// `.[ubits]`/`.[sbits]` have been removed.

mut a:u8 = 0
cassert(a.[bits] == 8)
a = 200
cassert(a.[bits] == 8)        // bits is declared, not value-derived

const c:s4 = -1
cassert(c.[bits] == 4)
cassert(c.[min] == -8)
cassert(c.[max] == 7)

const e = 0                   // untyped → nil
cassert(e.[bits] == nil)
