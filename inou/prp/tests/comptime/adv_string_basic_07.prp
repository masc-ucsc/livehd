/*
:name: adv_string_basic_07
:type: comptime
:verifier_pass: 6
:verifier_fail: 0
*/

// The positional string(format, args...) form (02-basics.md):
//   const txt2 = string("I have {:d} {} potato{}", num, color, extension)
//   cassert(txt1 == txt2 == "I have 2 blue potatos")
// {} substitutes the next positional argument; {:d} forces signed decimal.
const num = 2
const color = "blue"
const ext = "s"

cassert(string("{}", num) == "2")
cassert(string("{:d}", num) == "2")
cassert(string("a={}b", num) == "a=2b")
cassert(string("{} {}", num, color) == "2 blue")
cassert(string("I have {:d} {} potato{}", num, color, ext) == "I have 2 blue potatos")

// And it must agree with the equivalent double-quote interpolation.
const txt1 = "I have {num:d} {color} potato{ext}"
cassert(txt1 == string("I have {:d} {} potato{}", num, color, ext))
