/*
:name: adv_bitsel_slice_11
:type: comptime
:verifier_pass: 3
:verifier_fail: 0
*/

// 04-variables.md string section: a string typecasts to an integer via #[..]
//   const a = 'cad' ; const b = 0x64_61_63
//   cassert(a == string(b)) ; cassert(int(a) == b) ; cassert(a#[..] == b)
// (FINDING: int('cad') folds to nil and 'cad'#[..] is not comptime-known)
const a = 'cad'          // c=0x63, a=0x61, d=0x64
const b = 0x64_61_63

cassert(int(a) == b)
cassert(a#[..] == b)
cassert(a == string(b))
