/*
:name: bitset
:type: comptime
:verifier_pass: 4
:verifier_fail: 0
*/

const a = 0ub1010   // 4 bits (5bits signed)
const b = 0ub01     // 2 bits (3bits signed)
const c = 0ub1      // 1 bit  (2bits signed)

mut r:u7 = nil
r#[0]    = c#[0]
r#[1..=2] = b#[0..<2]
r#[3..=6] = a#[0..=3]
cputs("r:{r}")
cassert(r == 0ub1010_01_1)

mut x:u7 = nil
x#[0..+1] = c
x#[2..+3] = b
x#[5..+5] = a
cassert(x == 0ub01010_001_01)

const as = 0sb1010   // 4 bits
const bs = 0sb01     // 2 bits
const cs = 0sb1      // 1 bit

cassert(cs == -1)
r = nil
r#[0]    = cs
r#[1..=2] = bs
r#[3..=6] = as
cassert(r == 0ub1010_01_1)
