/*
:name: adv_enum_hier_10
:type: comptime
:verifier_pass: 3
:verifier_fail: 0
*/

// Integer-typed enum with no explicit values: sequential 0,1,2 (doc rule that
// :signed switches off one-hot numbering).
enum V6:signed = (a, b, c)

cassert(u8(V6.a) == 0)
cassert(u8(V6.b) == 1)
cassert(u8(V6.c) == 2)
