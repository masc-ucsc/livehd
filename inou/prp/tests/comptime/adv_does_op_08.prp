/*
:name: adv_does_op_08
:type: comptime
:verifier_pass: 6
:verifier_fail: 0
*/

// named-vs-positional matching. Fully named tuples: order independent.
const fn1 = (const a=1, const b=2)
const fn2 = (const b=2, const a=1)
cassert(fn1 does fn2)         // both fully named, order independent
cassert(fn2 does fn1)
// mixed: an unnamed field forces position+name to match (doc 07-typesystem
// "when either a or b have unnamed fields ... name but also position should
// match"). Here b=(b=2, 1) has an unnamed value 1 at position 1, but a's
// position-1 field is named `b` -> the unnamed value cannot positionally match.
cassert(not ((1, b=2) does (b=2, 1)))
cassert((1, b=2) does (1, b=2))      // exact position + name match
// extra named field, still superset
cassert((a=1, b=2, c=3) does (a=1, b=2))
cassert(not ((a=1, b=2) does (a=1, b=2, c=3)))
