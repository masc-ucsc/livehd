/*
:name: phase5_const_double_assign
:type: parsing lnast comptime
:verifier_pass: 1
:verifier_fail: 1
*/

// Phase 5 — negative test. Re-binding a `const` is a compile error. The
// attribute pass enforces this via `record_assign` raising upass::error on
// the second non-nil bind. The pyrope test harness treats a compile error
// as a non-zero pipeline exit, which doesn't compose with the verifier
// pass/fail tally — there is no `:expect_fail:` flag yet — so we keep a
// placeholder `cassert false` to register the negative path. Switch to an
// explicit `const a = 6` once the test harness can assert pipeline-exit
// failures.

const a = 5
cassert a == 5
cassert false
