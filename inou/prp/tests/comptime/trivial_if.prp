/*
:name: trivial_if
:type: comptime
:verifier_pass: 6
:verifier_fail: 0
*/


mut c = 1

if false {
    c = 2
}
cassert(c == 1)
if false { c = 100 }
cassert(c == 1)

mut c2 = nil
if false { c2 = 3 }
cassert(c2 == nil) // comptime-false arm leaves the nil init untouched

mut c3 = nil
if true { c3 = 4 }
cassert(c3 == 4)

if true {
  mut d = 4
  cassert(d == 4)
}
// NOTE: reading `d` here would be a compile error (if-arm locals are not
// visible outside the arm) — see tests/errors/if_arm_scope_read.prp.

mut d = 5 // a fresh top-level `d` is fine: the arm-local one is gone
cassert(d == 5)
