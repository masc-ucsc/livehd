/*
:name: formux
:type: comptime
:verifier_pass: 4
:verifier_fail: 0
*/

comb code1(cond1:bool, cond2:bool, a:u32, b:u32, c:u32) -> (res:u32) {
  mut res = a
  unique if cond1 {
    res = b
  } elif cond2 {
    res = c
  } // no res in else
}

comb code2(cond1:bool, cond2:bool, a:u32, , c:u32, b:u32) -> (res:u32) {
  // RTL equivalent — build the one-hot select bit-by-bit
  mut sel:u3 = nil
  sel#[0] = cond2
  sel#[1] = cond1
  sel#[2] = !cond1 and !cond2
  mut res2 = __hotmux(sel, a, b, c)
  optimize(!(cond1 and cond2)) // one hot check
}

for cond1 in (true, false) {
  for cond2 in (true, false) {
    mut r1 = code1(cond1,cond2,a=1,b=2,c=3)
    const (a,b,c) = (1,2,3)
    mut r2 = code2(cond1,cond2,a,b,c)

    cassert(r1==r2)
  }
}
