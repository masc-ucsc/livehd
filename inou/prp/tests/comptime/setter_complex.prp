/*
:name: setter_complex
:type: parsing lnast comptime
:verifier_pass: 5
:verifier_fail: 0
*/

const fint:int = 0
cassert(fint == 0)

mut fbool:bool = false
cassert(fbool == false)

comb init_empty(ref self) {
  cassert(self.v == "")
  self.v = "empty"
}

comb init_v(ref self, v) {
  self.v = v
}

comptime const Tup = (mut v = "", const init = [init_empty, init_v])

mut x:Tup = nil       // no-arg init overload runs at construction
cassert(x.v == "empty")

mut y:Tup = "Padua"   // init_v runs at construction
cassert(y.v == "Padua")
