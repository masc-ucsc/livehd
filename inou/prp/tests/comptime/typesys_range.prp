/*
:name: typesys_range
:type: comptime
:verifier_pass: 15
:verifier_fail: 0
*/

// Corner cases for entry 1v (LNAST basic typesystem + min/max upass).
// Declared-type-only policy: `.[bits]`/`.[max]`/`.[min]` derive from the
// declared type. Un-annotated values return nil for all three.

// Inferred from initializer: a fits 0..3 → 2 bits unsigned.
const a = 3
cassert(a.[max] == nil)
cassert(a.[min] == nil)
cassert(a.[bits] == nil)

// Inferred range from a small mut updated by constant adds.
mut b:u10 = 1
b = b + 1
b = b + 1
cassert(b == 3)
cassert(b.[max] >= 3)

// Bounded type: declared max/min envelope derives bits.
// (`:[range=…]`/`int(range=…)` are compile errors — see errors/readonly_attr_range.)
const c:int(max=15, min=0) = 5
cassert(c.[bits] == 4)
cassert(c.[max] == 15)
cassert(c.[min] == 0)

// Bool: bits=1, max=1, min=0.
const t:bool = true
cassert(t.[bits] == 1)
cassert(t.[max] == 0)
cassert(t.[min] == -1)

// String: size works.
const s = "abc"
cassert(s.[size] == 3)
cassert(s.[bits] == nil)

// Arithmetic narrows the *effective* range to the declared type's bound,
// not to the runtime expression's value.
mut d:int(max = 15) = 1
d = d + 14
cassert(d == 15)
cassert(d.[max] == 15)
