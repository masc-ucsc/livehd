/*
:name: tuple_decorator_complex
:type: parsing lnast upass
*/

mod set_xy(ref self, x:int, y:int) {
  self._x = x
  self._y = y
}

comb get_xy(self, idx:string) -> (r) {
  r = match idx {
    == 'x' { self._x }
    == 'y' { self._y }
  }
}

const Point = (_x = 0, _y = 0, setter = set_xy, getter = get_xy)

const p:Point = (1, 2)

cassert p['x'] == 1 and p['y'] == 2
cassert p.x == 1 and p.y == 2
