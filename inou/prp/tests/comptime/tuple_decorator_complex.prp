/*
:name: tuple_decorator_complex
:type: parsing lnast comptime
:verifier_pass: 2
:verifier_fail: 0
*/

comb init_xy(ref self, x:int, y:int) {
  self._x = x
  self._y = y
}

comb get_xy(self, idx:string) -> (r) {
  r = match idx {
    == 'x' { self._x }
    == 'y' { self._y }
    else   { cassert(false); 0 }
  }
}

comptime const Point = (_x = 0, _y = 0, init = init_xy, get = get_xy)

const p:Point = (1, 2)   // init runs at construction

cassert(p.get('x') == 1)
cassert(p.get('y') == 2)
