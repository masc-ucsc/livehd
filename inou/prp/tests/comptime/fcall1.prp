/*
:name: fcall1
:type: comptime
:verifier_pass: 4
:verifier_fail: 0
*/

comb fcall1(a:u3, b:u7, cond:bool) -> (res:s4) {
  if cond {
    res = a + 1
  }else{
    res = b#[0..<4]
  }
}

const x1 = fcall1(a=1,b=4,cond=true)
cassert(x1 == 2)
const x1b = fcall1(cond=true,a=1,b=4)
cassert(x1b == 2)

const x2 = fcall1(a=3,b=7,true)
cassert(x2 == 4)

const x3 = fcall1(a=1,b=0sb11011110,false)
cassert(x3 == 0sb1110 == -2)
