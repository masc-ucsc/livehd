/*
:name: case_test1
:type: parsing lnast upass
*/

const m1 = (a=1,b=50)
const m2 = (a=2,b=60)
mut m3 = (b=2,a=70)
const m4 = (c=2,b=80)
const m5 = (a=2,b=90,c=100)

mut hit=0

const b=300

match const t = m1; t {
 case (a=33,b=?)   { hit = 300 + t.a + t.b }
 case (a=2,b=?)    { hit = t.a + m1.b; cassert m1 == t }
 case (a=true,b=?) { hit = if t.a { b+100 } else { b-100 } }
}
cassert hit == 51

cassert (a=1,3)  case (a=?,3)
cassert (a=1,3)  case (a=1,?)
cassert (a=1,3)  case (a=1)
cassert (a=1)   !case (a=1,3)

cassert (a=1,b=2) case (a=1)
cassert (a=1,b=2) case (b=1)
cassert (a=1,b=2) !case (b=1)
cassert (b=2) !case (b=2,a=1)
cassert (b=2) !case (b=2,1)
cassert (b=2) !case (b=2,?)
cassert (b=2) !case (b=2,c=?)
