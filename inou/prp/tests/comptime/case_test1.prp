/*
:name: case_test1
:type: parsing lnast comptime
:verifier_pass: 12
:verifier_fail: 0
*/

const m1 = (a=1,b=50)
const m2 = (a=2,b=60)
mut m3 = (b=2,a=70)
const m4 = (c=2,b=80)
const m5 = (a=2,b=90,c=100)

mut hit=0

const b=300

match const t = m1; t {
 case (a=33,b=0sb?)   { hit = 300 + t.a + t.b }
 case (a=2,b=0sb?)    { hit = t.a + m1.b; cassert m1 == t }
 case (a=true,b=0sb?) { hit = if t.a { b+100 } else { b-100 } }
}
cassert hit == 51

cassert (a=1,3)  case (a=0sb?,3)
cassert (a=1,3)  case (a=1,0sb?)
cassert (a=1,3)  case (a=1)
cassert (a=1)   !case (a=1,3)

cassert (a=1,b=2) case (a=1)
cassert (a=1,b=2) case (b=1)
cassert (a=1,b=2) !case (b=1)
cassert (b=2) !case (b=2,a=1)
cassert (b=2) !case (b=2,1)
cassert (b=2) !case (b=2,0sb?)
cassert (b=2) !case (b=2,c=0sb?)
