/*
:name: case_test1
:type: parsing lnast comptime
:verifier_pass: 14
:verifier_fail: 0
*/

const m1 = (const a=1,const b=50)
const m2 = (const a=2,const b=60)
mut m3 = (const b=2,const a=70)
const m4 = (const c=2,const b=80)
const m5 = (const a=2,const b=90,const c=100)

mut hit=0

const b=300

match const t = m2; t {
 case (a=33,b=0sb?)   { hit = 300 + t.a + t.b }
 case (a=2,b=0sb?)    { hit = 1000+t.a + m1.b; cassert(m2 == t) }
 case (a=true,b=0sb?) { hit = if t.a { b+100 } else { b-100 } }
 else                 { cassert(false) }
}
cassert(t == nil)  // t was in local match scope
cassert(hit == 1052)

cassert((a=1,3,2)  case (3,a=0sb?,2))
cassert((a=1,3)  case (a=1,0sb?))
cassert((a=1,3)  case (a=1))
cassert(not ((a=1) case (a=1,3)))

cassert((a=1,b=2) case (a=1))
cassert((a=1,b=2) case (b=2))
cassert(not ((a=1,b=2) case (b=1)))
cassert(not ((b=2) case (b=2,a=1)))
cassert(not ((b=2) case (b=2,1)))
cassert(not ((b=2) case (b=2,0sb?)))
cassert(not ((b=2) case (b=2,c=0sb?)))
