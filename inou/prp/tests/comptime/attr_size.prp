/*
:name: attr_size
:type: parsing lnast comptime
:verifier_pass: 7
:verifier_fail: 0
*/

mut a = 3
cassert(a.[size] == 1)

mut b = (1,2,3)
cassert(b.[size] == 3)

mut c = 0
cassert(c.[size] == 1)

mut d = true
cassert(d.[size] == 1)

mut e = ("hello", "world")
cassert(e.[size] == 2)

mut g = 44 ++ 33
cassert(g.[size] == 2)

mut h = 1..=3
cassert(h.[size] == 3)
