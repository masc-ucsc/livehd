/*
:name: tuple_concat
:type: parsing lnast comptime
:verifier_pass: 5
:verifier_fail: 0
*/

cassert((...(a=1,c=3), ...(b=2,d=4)) == (a=1, c=3, b=2, d=4))
cassert((...(1,2), ...(a=2,nil,5)) == (1,2,a=2,nil,5))
cassert((...(x=1), ...(a=2,nil,5)) == (x=1,a=2,nil,5))

cassert((...(x=1,b=2), ...(y=0sb?,3)) == (x=1,b=2,y=0sb?,3))

cassert((1,b=2,...(3,c=3),6) == (1,b=2,3,c=3,6))
