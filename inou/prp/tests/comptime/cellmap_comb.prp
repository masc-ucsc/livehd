/*
:name: cellmap_comb
:type: comptime
:verifier_pass: 104
:verifier_fail: 0
*/

// Trivial coverage for the stateless combinational cells declared in
// graph/cell.hpp. Each cell is wrapped in a tiny `comb` lambda using
// the corresponding Pyrope operator, then exercised with 2-4 cases.
// Each case is also re-checked against the direct `__<cell>` call
// (the library-level cell invocation, same style as `__hotmux` in
// formux.prp). Direct cell call args use named pins from cell.cpp
// (positional calls are not allowed).
//
// Stateful cells (Memory, Flop, Latch, Fflop) and Sub/IO/AttrSet are
// out of scope. LUT has no direct Pyrope syntax (the compiler folds
// small match/Mux into LUTs when profitable), so it is covered via Mux.

// Ntype_op::Sum -- pins A (add) and B (subtract); only A used here.
comb cell_sum(a:u32, b:u32) -> (y) { y = a + b }

cassert(cell_sum(1, 2) == 3)
cassert(  __sum(a=(1, 2)) == 3)
cassert(cell_sum(100, 200) == 300)
cassert(  __sum(a=(100, 200)) == 300)
cassert(cell_sum(0, 0) == 0)
cassert(  __sum(a=(0, 0)) == 0)

// Ntype_op::Mult -- repeated A pin
comb cell_mult(a:u32, b:u32) -> (y) { y = a * b }

cassert(cell_mult(3, 4) == 12)
cassert(  __mult(a=(3, 4)) == 12)
cassert(cell_mult(0, 99) == 0)
cassert(  __mult(a=(0, 99)) == 0)
cassert(cell_mult(7, 7) == 49)
cassert(  __mult(a=(7, 7)) == 49)

// Ntype_op::Div -- pins a, b
comb cell_div(a:u32, b:u32) -> (y) { y = a / b }

cassert(cell_div(10, 2) == 5)
cassert(  __div(a=10, b=2) == 5)
cassert(cell_div(15, 4) == 3)
cassert(  __div(a=15, b=4) == 3)
cassert(cell_div(0, 5) == 0)
cassert(  __div(a=0, b=5) == 0)

// Ntype_op::And (bitwise) -- repeated A pin
comb cell_and(a:u8, b:u8) -> (y) { y = a & b }

cassert(cell_and(0ub1100, 0ub1010) == 0ub1000)
cassert(  __and(a=(0ub1100, 0ub1010)) == 0ub1000)
cassert(cell_and(0xff, 0x0f) == 0x0f)
cassert(  __and(a=(0xff, 0x0f)) == 0x0f)
cassert(cell_and(0, 0xff) == 0)
cassert(  __and(a=(0, 0xff)) == 0)

// Ntype_op::Or (bitwise) -- repeated A pin
comb cell_or(a:u8, b:u8) -> (y) { y = a | b }

cassert(cell_or(0ub1100, 0ub1010) == 0ub1110)
cassert(   __or(a=(0ub1100, 0ub1010)) == 0ub1110)
cassert(cell_or(0, 0xff) == 0xff)
cassert(   __or(a=(0, 0xff)) == 0xff)
cassert(cell_or(0x55, 0xaa) == 0xff)
cassert(   __or(a=(0x55, 0xaa)) == 0xff)

// Ntype_op::Xor -- repeated A pin
comb cell_xor(a:u8, b:u8) -> (y) { y = a ^ b }

cassert(cell_xor(0ub1100, 0ub1010) == 0ub0110)
cassert(  __xor(a=(0ub1100, 0ub1010)) == 0ub0110)
cassert(cell_xor(0xff, 0xff) == 0)
cassert(  __xor(a=(0xff, 0xff)) == 0)
cassert(cell_xor(0x55, 0xaa) == 0xff)
cassert(  __xor(a=(0x55, 0xaa)) == 0xff)

// Ntype_op::Ror (reduce OR) -- single input pin a
comb cell_ror(a:u8) -> (y) { y = a#|[..] }

cassert(cell_ror(0) == false)
cassert(  __ror(a=0) == false)
cassert(cell_ror(0ub0001) == true)
cassert(  __ror(a=0ub0001) == true)
cassert(cell_ror(0xff) == true)
cassert(  __ror(a=0xff) == true)

// Ntype_op::Not (bitwise) -- single input pin a. Every dlop/cell const is a
// signed integer (no unsigned const), so `~a == -a-1` with no implicit width
// mask: `~0 == -1` (all ones), not 0xff. To get a finite 0xff you negate a
// width-pinned negative, e.g. `~(0sb1_0000_0000) == 0xff` (= ~(-256)).
comb cell_not(a:sint) -> (y:sint) { y = ~a }

cassert(cell_not(0) == -1)
cassert(  __not(a=0) == -1)
cassert(cell_not(0xff) == -256)
cassert(  __not(a=0xff) == -256)
cassert(cell_not(0sb1_0000_0000) == 0xff)
cassert(  __not(a=0sb1_0000_0000) == 0xff)

// Ntype_op::Get_mask -- pins a, mask
comb cell_get_mask(a:u8) -> (y) { y = a#[0..=3] }

cassert(cell_get_mask(0xab) == 0xb)
cassert(  __get_mask(a=0xab, mask=0xf) == 0xb)
cassert(cell_get_mask(0x0f) == 0xf)
cassert(  __get_mask(a=0x0f, mask=0xf) == 0xf)
cassert(cell_get_mask(0xf0) == 0)
cassert(  __get_mask(a=0xf0, mask=0xf) == 0)

// Ntype_op::Set_mask -- pins a, mask, value
comb cell_set_mask(base:u8, lo:u4) -> (y:u8) {
  mut t = base
  t#[0..=3] = lo
  y = t
}

cassert(cell_set_mask(0xf0, 0xa) == 0xfa)
cassert(  __set_mask(a=0xf0, mask=0xf, value=0xa) == 0xfa)
cassert(cell_set_mask(0, 0x5) == 0x05)
cassert(  __set_mask(a=0, mask=0xf, value=0x5) == 0x05)
cassert(cell_set_mask(0xff, 0) == 0xf0)
cassert(  __set_mask(a=0xff, mask=0xf, value=0) == 0xf0)

// Ntype_op::Sext -- pins a, b (b is the sign-bit position)
comb cell_sext(a:u8) -> (y:sint) { y = a#sext[0..=3] }

cassert(cell_sext(0ub1010) == -6)
cassert(  __sext(a=0ub1010, b=3) == -6)
cassert(cell_sext(0ub0111) == 7)
cassert(  __sext(a=0ub0111, b=3) == 7)
cassert(cell_sext(0ub1111) == -1)
cassert(  __sext(a=0ub1111, b=3) == -1)

// Ntype_op::LT -- pins a (left) and b (right)
comb cell_lt(a:sint, b:sint) -> (y:bool) { y = a < b }

cassert(cell_lt(1, 2) == true)
cassert(   __lt(a=1, b=2) == true)
cassert(cell_lt(2, 1) == false)
cassert(   __lt(a=2, b=1) == false)
cassert(cell_lt(-3, 0) == true)
cassert(   __lt(a=-3, b=0) == true)

// Ntype_op::GT -- pins a (left) and b (right)
comb cell_gt(a:sint, b:sint) -> (y:bool) { y = a > b }

cassert(cell_gt(2, 1) == true)
cassert(   __gt(a=2, b=1) == true)
cassert(cell_gt(1, 2) == false)
cassert(   __gt(a=1, b=2) == false)
cassert(cell_gt(0, -3) == true)
cassert(   __gt(a=0, b=-3) == true)

// Ntype_op::EQ -- repeated A pin
comb cell_eq(a:u32, b:u32) -> (y:bool) { y = a == b }

cassert(cell_eq(3, 3) == true)
cassert(   __eq(a=(3, 3)) == true)
cassert(cell_eq(3, 4) == false)
cassert(   __eq(a=(3, 4)) == false)
cassert(cell_eq(0, 0) == true)
cassert(   __eq(a=(0, 0)) == true)

// Ntype_op::SHL -- pins a, b
comb cell_shl(a:u32, n:u8) -> (y) { y = a << n }

cassert(cell_shl(1, 0) == 1)
cassert(  __shl(a=1, b=0) == 1)
cassert(cell_shl(1, 4) == 16)
cassert(  __shl(a=1, b=4) == 16)
cassert(cell_shl(3, 2) == 12)
cassert(  __shl(a=3, b=2) == 12)

// Ntype_op::SRA -- pins a, b
comb cell_sra(a:sint, n:u8) -> (y:sint) { y = a >> n }

cassert(cell_sra(16, 2) == 4)
cassert(  __sra(a=16, b=2) == 4)
cassert(cell_sra(-8, 1) == -4)
cassert(  __sra(a=-8, b=1) == -4)
cassert(cell_sra(1, 0) == 1)
cassert(  __sra(a=1, b=0) == 1)

// Ntype_op::Mux -- pin s (selector), pins p1..pN values
comb cell_mux(sel:u2, a:u8, b:u8, c:u8, d:u8) -> (y:u8) {
  y = match sel {
    == 0 { a }
    == 1 { b }
    == 2 { c }
    else { d }
  }
}

cassert(cell_mux(0, 10, 20, 30, 40) == 10)
cassert(  __mux(s=0, p1=10, p2=20, p3=30, p4=40) == 10)
cassert(cell_mux(1, 10, 20, 30, 40) == 20)
cassert(  __mux(s=1, p1=10, p2=20, p3=30, p4=40) == 20)
cassert(cell_mux(2, 10, 20, 30, 40) == 30)
cassert(  __mux(s=2, p1=10, p2=20, p3=30, p4=40) == 30)
cassert(cell_mux(3, 10, 20, 30, 40) == 40)
cassert(  __mux(s=3, p1=10, p2=20, p3=30, p4=40) == 40)
