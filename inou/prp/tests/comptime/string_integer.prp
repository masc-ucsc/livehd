/*
:name: string_integer
:type: parsing lnast comptime
:verifier_pass: 8
:verifier_fail: 0
*/

// String->number parsing now rides on the sized casts (`uN`/`sN`); `int`/`uint`
// were removed (`signed`/`unsigned` are sign reinterprets and need bit-typed input).
cassert(3 == s8("3"))
cassert(s8("-4") == -4)

cassert(string(1+2) == "3")
const v = u32("33")
cassert(v == 33)

cassert(u8("0ub010101") == 0ub10101)

cassert(s8("-1") == -1)

cassert(string("hello ", "world ", 4) == string(string("hello"), string(" world "), string(4)) == "hello world 4")

cassert(u8("0xFF") == 255)
