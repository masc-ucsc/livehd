/*
:name: string_integer
:type: parsing
*/

cassert 3 == int("3")
cassert "-4".int() == -4

cassert string(1+2) == "3"
const v = u32("33")
cassert v == 33

cassert "0b010101".uint() == 0b10101

cassert "-1".uint() == nil

cassert string("hello", " world ", 4) == string("hello") ++ string(" world ") ++ string(4) == "hello world 4"

cassert uint("0xFF") == 255
