/*
:name: tuple_copy
:type: parsing lnast comptime
:verifier_pass: 4
:verifier_fail: 0
*/

mut foo = (a=40,b=50)
mut bar = (c=60)
mut xxx = (60)

foo.a = 2
foo.b = 3
bar.c = 6

cassert foo   == (a=2,b=3) == (2,3)
cassert bar.c ==  6
cassert xxx.0 == 60        == xxx

bar = foo

cassert foo == bar == (2,3)
