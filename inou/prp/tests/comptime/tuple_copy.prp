/*
:name: tuple_copy
:type: parsing lnast comptime
:verifier_pass: 4
:verifier_fail: 0
*/

mut foo = (mut a=40,mut b=50)
mut bar = (mut c=60)
mut xxx = (60)

foo.a = 2
foo.b = 3
bar.c = 6

cassert(foo   == (a=2,b=3))
cassert(bar.c ==  6)
cassert(xxx[0] == 60        == xxx)

bar = foo

cassert(foo == bar == (a=2,b=3))
