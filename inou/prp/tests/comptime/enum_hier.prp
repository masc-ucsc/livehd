/*
:name: enum_hier
:type: parsing lnast comptime
:verifier_pass: 6
:verifier_fail: 0
*/

enum Mammal = (rat, human)
enum Bird = (parroket, flinch)

const r = Mammal.rat
const h = Mammal.human

const p = Bird.parroket

cassert r != h
cassert r in Mammal
cassert h in Mammal

cassert p !in Mammal
cassert p in Bird
cassert p == Bird.parroket
