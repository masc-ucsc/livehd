/*
:name: enum_hier
:type: parsing lnast comptime
:verifier_pass: 6
:verifier_fail: 0
*/

enum Mammal = (rat, human)
enum Bird = (parroket, flinch)

const r = Mammal.rat
const h = Mammal.human

const p = Bird.parroket

cassert(r != h)
cassert(r in (Mammal.rat, Mammal.human))
cassert(h in (Mammal.rat, Mammal.human))
cassert(not (r in (Mammal.human,)))        // same-enum non-member
cassert(p in (Bird.parroket, Bird.flinch))
cassert(p == Bird.parroket)
