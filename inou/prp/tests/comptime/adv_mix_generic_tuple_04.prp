/*
:name: adv_mix_generic_tuple_04
:type: comptime
:verifier_pass: 5
:verifier_fail: 0
*/

// Generic over the element type of a 1-D array passed as a tuple field;
// fold a reduction at compile time, then destructure.
comb fold3<T>(xs:(T, T, T)) -> (sum:T, prod:T) {
  sum  = xs[0] + xs[1] + xs[2]
  prod = xs[0] * xs[1] * xs[2]
}

const r = fold3<u16>(xs = (2, 3, 5))
cassert(r.sum == 10)
cassert(r.prod == 30)

// Boundary: zeros and a one keep prod==0, sum tracks.
const r2 = fold3<int>(xs = (0, 7, 1))
cassert(r2.sum == 8)
cassert(r2.prod == 0)

// Negative element via signed generic
const r3 = fold3<i8>(xs = (-2, 3, 4))
cassert(r3.prod == -24)
