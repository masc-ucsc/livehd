/*
:name: adv_int_true_neg
:type: comptime
:verifier_pass: 3
:verifier_fail: 0
*/
// bool -> int: true is the all-ones (1-bit signed) value = -1; false = 0.
// Hence string(int(true)) is the decimal "-1".
cassert(signed(true)  == -1)
cassert(signed(false) == 0)
cassert(string(signed(true)) == "-1")
