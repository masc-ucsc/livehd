/*
:name: attr_set_path
:type: comptime
:verifier_pass: 9
:verifier_fail: 0
*/

// Attribute writes are only legal at a DECLARATION (`x::[attr = …]`), never as
// an attribute modification on an assignment to a tuple-path lvalue — i.e.
// `t.x::[tag = 42] = 11` is a compile error (annotate the field at the base's
// declaration instead). This test exercises the legal surface:
//   - single-level user attribute on a scalar declaration
//   - plain (no-attr) writes through a deep tuple path
//   - reading an attribute that was never set returns nil
//   - a user attribute sticking through a derived value (op propagation)

// Single-level user attribute on a scalar declaration.
const a::[note = 1] = 7
cassert(a.[note] == 1)
cassert(a == 7)

// Plain writes through tuple paths (no attribute modification on assignment).
mut t = (mut x = 0, mut y = (const lo = 0, mut hi = 0))
t.x = 11
cassert(t.x == 11)

// tuple_set with a deep path: t.y.hi gets written via path of len 2.
t.y.hi = 99
cassert(t.y.hi == 99)
cassert(t.y.lo == 0)

// Overwrite the deep tuple slot again (still a plain path write).
t.y.hi = 50
cassert(t.y.hi == 50)

// Sticky propagation through an expression op: the user attribute set at the
// declaration of `x` rides along into a derived value.
const x::[_special] = 4
const y = x + 1
cassert(y.[_special])

// Reading an attribute that was never set returns nil (no spurious entries).
cassert(t.y.lo.[bound] == nil)

// Plain writes to a scalar tuple field in sequence.
mut u = (mut v = 0)
u.v = 5
u.v = 6
cassert(u.v == 6)
