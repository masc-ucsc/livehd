/*
:name: adv_match_all_20
:type: comptime
:verifier_pass: 5
:verifier_fail: 0
*/

// statement-form match assigning two outputs; exactly-one-branch over all kinds.
// Two outputs MUST destructure by name; remap to distinct names per call site.
comb f(v) -> (lo, hi) {
  match v {
    == 0     { lo = 1 ; hi = 10 }
    in (1,2) { lo = 2 ; hi = 20 }
    < 5      { lo = 3 ; hi = 30 }
    > 99     { lo = 4 ; hi = 40 }
    else     { lo = 5 ; hi = 50 }
  }
}

const (a_lo = f.lo, a_hi = f.hi) = f(v=0)
const (b_lo = f.lo, b_hi = f.hi) = f(v=2)
const (c_lo = f.lo, c_hi = f.hi) = f(v=4)
const (d_lo = f.lo, d_hi = f.hi) = f(v=100)
const (e_lo = f.lo, e_hi = f.hi) = f(v=50)

cassert(a_lo == 1 and a_hi == 10)
cassert(b_lo == 2 and b_hi == 20)
cassert(c_lo == 3 and c_hi == 30)
cassert(d_lo == 4 and d_hi == 40)
cassert(e_lo == 5 and e_hi == 50)
