/*
:name: expr_match
:type: parsing lnast comptime
:verifier_pass: 3
:verifier_fail: 0
*/

const sel = 2

const result = match sel {
  == 0b00 { 0b0001 }
  == 0b01 { 0b0010 }
  == 0b10 { 0b0100 }
  == 0b11 { 0b1000 }
}
cassert result == 4

const table = (1,2,4,8)
cassert result == table[sel]

cassert result == 1 << sel
