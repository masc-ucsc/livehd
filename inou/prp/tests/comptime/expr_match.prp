/*
:name: expr_match
:type: parsing lnast comptime
:verifier_pass: 4
:verifier_fail: 0
*/

const sel = 2

const result = match sel {
  == 0ub00 { 0ub0001 }
  == 0ub01 { 0ub0010 }
  == 0ub10 { 0ub0100 }
  == 0ub11 { 0ub1000 }
  else    { cassert(false); 0 }
}
cassert(result == 4)
const result2 = match sel {
  case 0ub00 { 0ub0001 }
  case 0ub01 { 0ub0010 }
  case 0ub10 { 0ub0100 }
  case 0ub11 { 0ub1000 }
  else      { cassert(false); 0 }
}
cassert(result == result2)

const table = (1,2,4,8)
cassert(result == table[sel])

cassert(result == 1 << sel)
