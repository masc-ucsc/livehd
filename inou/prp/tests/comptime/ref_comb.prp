/*
:name: ref_comb
:type: comptime
:verifier_pass: 4
:verifier_fail: 0
*/

comb inline_noref(a)->(r) {
  a += 100
  r = a + 3
}

comb inline_ref(ref a)->(r) {
  a += 200
  r = a + 3
}

mut b = 1
cassert b == 1
const d1 = inline_noref(b)
cassert b == 1 and d1 == 104

mut c = 1
cassert c == 1
const d2 = inline_ref(c)
cassert c == 201 and d2 == 204
