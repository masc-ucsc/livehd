/*
:name: enum_simple
:type: parsing lnast comptime
:verifier_pass: 9
:verifier_fail: 0
*/

enum X = (l0, l1, l2)

const a = X.l0
const b = X.l1

cassert(a != b)
cassert(a == X.l0)
cassert(b == X.l1)

cassert(X.l0 == 0ub001)
cassert(X.l1 == 0ub010)
cassert(X.l2 == 0ub100)

enum V3 = (a, b=5, c)
cassert(V3.a == 0)
cassert(V3.b == 5)
cassert(V3.c == 6)
