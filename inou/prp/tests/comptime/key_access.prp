/*
:name: key_access
:type: parsing lnast comptime
:verifier_pass: 4
:verifier_fail: 0
*/

const foo = (xx=3, yy=4)

// named tuple: positional access (`foo[0]`) is not allowed — use the names.
cassert(foo.xx.[key] == "xx")
cassert(foo.yy.[key] == "yy")
cassert(foo.[key] == "foo")
cassert(foo.xx.[key] == "xx")
