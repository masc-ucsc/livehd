/*
:name: does_test1
:type: parsing lnast comptime
:verifier_pass: 35
:verifier_fail: 0
*/

// Task 1g — type-aware `does`. Constprop folds the structural half for
// tuple-vs-tuple AND the scalar/type half (kind + integer envelope) for
// scalars, type-name operands, literal-as-bundle, and per-field types.

const m1 = (a=1,b=0)
const m2 = (a=2,b=0)
mut m3 = (b=2,a=0)
const m4 = (c=2,b=0)
const m5 = (a=2,b=20,c=100)

cassert(m1 does m2)
cassert(m2 does m1)
cassert(m3 does m1)
cassert(m1 does m3)

cassert(not (m4 does m1))
cassert(not (m4 does m2))
cassert(not (m4 does m3))

cassert(m5 does m1)
cassert(m5 does m2)
cassert(m5 does m3)
cassert(m5 does m4)

cassert(not (m1 does m5))
cassert(not (m2 does m5))
cassert(not (m3 does m5))
cassert(not (m4 does m5))

const b1 = true
mut b2 = 100 < 30

cassert(b1 does true)        // bool var does bool literal — same kind
cassert(b2 does true)        // comparison result is boolean
cassert(b1 does b2)          // bool does bool
cassert(not (b1 does m1))    // bool does tuple → kind mismatch

mut i1 = 10
const i2 = 0
mut i3 = -1
cassert(i1 does i2)          // untyped ints are unbounded → superset of any int
cassert(i1 does i3)
cassert(i3 does 100)         // unbounded ⊇ literal [100,100]
cassert(not (i3 does b1))    // int does bool → kind mismatch
cassert(not (b1 does i2))    // bool does int → kind mismatch

cassert(not (100 does m1))   // literal scalar (coerced to {0:100}) ⊉ named tuple
cassert(not (m1 does 100))   // named tuple ⊉ unnamed-pos-0 literal

  cassert((100,30) does 30)        // 2-tuple ⊇ single-positional literal 30
  cassert(not ((a=3) does (30,a=200)))
  cassert(not ((a=3) does (a=30,200)))

cassert(not (30 does (30,200)))    // single-positional literal ⊉ 2-tuple
cassert(not ((3) does (30,a=200)))
cassert(not ((3) does (a=30,200)))

mut hit=0

// Match-arm `does` lowers to a proper func_does per arm (prp2lnast), so the
// structural + type-aware fold drives arm selection at comptime.
match m1 {
 does (a:u32=333,b=0) { hit = 1 }   // m1.a (untyped) ⊆ u32 envelope, shape ok
 else { hit = 0 }
}
cassert(hit==1)

match m1 {
 does m2 { hit = 30 }
 does m4 { hit = 10 }
 does 33 { hit = 20 }
 else { hit = 0 }
}
cassert(hit==30)

match m1 {
 does m4 { hit = 10 }
 does m3 { hit = 40 }
 does (c=1,b=0,e=3) { hit = 100 }
 else { hit = 0 }
}
cassert(hit==40)
