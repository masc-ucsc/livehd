/*
:name: does_test1
:type: parsing
*/

const m1 = (a=1,b=0)
const m2 = (a=2,b=0)
mut m3 = (b=2,a=0)
const m4 = (c=2,b=0)
const m5 = (a=2,b=20,c=100)

cassert m1 does m2
cassert m2 does m1
cassert m3 does m1
cassert m1 does m3

cassert m4 !does m1
cassert m4 !does m2
cassert m4 !does m3

cassert m5 does m1
cassert m5 does m2
cassert m5 does m3
cassert m5 does m4

cassert m1 !does m5
cassert m2 !does m5
cassert m3 !does m5
cassert m4 !does m5

const b1 = true
mut b2 = 100 < 30

cassert b1 does true
cassert b2 does true
cassert b1 does b2
cassert b1 !does m1

mut i1 = 10
const i2 = 0
mut i3 = -1
cassert i1 does i2
cassert i1 does i3
cassert i3 does 100
cassert i3 !does b1
cassert b1 !does i2

cassert 100 !does m1
cassert m1 !does 100

cassert (100,30) !does 30
cassert 30 !does (30,200)
cassert (a=3) does (30,a=200)
cassert (a=3) does (a=30,200)
cassert (3) !does (30,a=200)
cassert (3) !does (a=30,200)

mut hit=0

match m1 {
 does (a:u32=333,b=0) { hit = 1 }
 else { hit = 0 }
}
cassert hit==1

match m1 {
 does m2 { hit = 30 }
 does m4 { hit = 10 }
 does 33 { hit = 20 }
 else { hit = 0 }
}
cassert hit==30

match m1 {
 does m4 { hit = 10 }
 does m3 { hit = 40 }
 does (c=1,b=0,e=3) { hit = 100 }
 else { hit = 0 }
}
cassert hit==40
