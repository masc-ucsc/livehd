/*
:name: phase5_wrap_sticky
:type: parsing lnast comptime
:verifier_pass: 6
:verifier_fail: 0
*/

// Task 1t — `wrap` / `sat` are per-statement prefix modifiers: each one
// narrows a single assignment to the lhs's declared type. They lower to a
// `wrap|sat(v=…, type=<lhs>)` library call (no sticky `:[wrap]` attribute and
// no `.[wrap]` / `.[saturate]` read form).

mut w:u4 = 0
wrap w = 0xFF
cassert(w == 0xF)
wrap w = 0x10
cassert(w == 0)

mut x:u4 = 0
wrap x = 0xFF                // per-statement wrap
cassert(x == 0xF)

sat x = 0xFF                 // per-statement saturate
cassert(x == 0xF)            // 0xF is u4 max

mut y:s4 = 0
sat y = 100
cassert(y == 7)              // s4 max

sat y = -100
cassert(y == -8)             // s4 min
