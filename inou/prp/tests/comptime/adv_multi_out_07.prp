/*
:name: adv_multi_out_07
:type: comptime
:verifier_pass: 5
:verifier_fail: 0
*/

// Conditional early return via bare `return`; outputs keep prior assignment.
// Two outputs MUST destructure by name; remap to distinct names per call site.
comb safe_div(x, y) -> (q, ok) {
  q = 0
  ok = false
  if y == 0 { return }
  q = x / y
  ok = true
}

const (a_q = safe_div.q, a_ok = safe_div.ok) = safe_div(x=20, y=4)
cassert(a_q == 5)
cassert(a_ok == true)

const (b_q = safe_div.q, b_ok = safe_div.ok) = safe_div(x=20, y=0)
cassert(b_q == 0)
cassert(b_ok == false)

// Destructure the early-return case by the output names directly.
const (q, ok) = safe_div(x=99, y=0)
cassert(q == 0 and ok == false)
