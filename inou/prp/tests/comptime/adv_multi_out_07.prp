/*
:name: adv_multi_out_07
:type: comptime
:verifier_pass: 5
:verifier_fail: 0
*/

// Conditional early return via bare `return`; outputs keep prior assignment.
comb safe_div(x, y) -> (q, ok) {
  q = 0
  ok = false
  if y == 0 { return }
  q = x / y
  ok = true
}

const a = safe_div(x=20, y=4)
cassert(a.q == 5)
cassert(a.ok == true)

const b = safe_div(x=20, y=0)
cassert(b.q == 0)
cassert(b.ok == false)

// Destructure the early-return case.
const (q, ok) = safe_div(x=99, y=0)
cassert(q == 0 and ok == false)
