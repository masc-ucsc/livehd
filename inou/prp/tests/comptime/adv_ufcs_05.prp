/*
:name: adv_ufcs_05
:type: comptime
:verifier_pass: 2
:verifier_fail: 0
*/

// A free `comb set_x(ref self, x) -> (self)` called via UFCS. Because it has a
// `ref` parameter it MUTATES its receiver, so it may only be called as a
// statement (the receiver is the result). Binding its result in a right-hand-side
// expression (`mut a3 = a1.set_x(...)`) is a compile error — see
// errors/ref_method_in_rhs.
comb set_x(ref self, x) -> (self) { self.x = x }

mut a1 = (mut x:u10 = 0)
a1.set_x(x=10)        // in-place mutate: a1.x = 10
cassert(a1.x == 10)

a1.set_x(x=20)        // in-place again: a1.x = 20
cassert(a1.x == 20)
