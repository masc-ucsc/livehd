/*
:name: adv_init_ctor_11
:type: comptime
:verifier_pass: 4
:verifier_fail: 0
*/

// init that takes a single array-typed param and loops (comptime unrolled) to
// accumulate. A 2-element array works; a 4-element array does not.
// SUSPECTED BUG: the construction tuple passed to init's single [4]int param
// arrives with the wrong size/contents (a plain top-level loop over the same
// literal sums correctly).

type Accum = (
  mut total:int = nil,
  mut last:int = nil,
  comb init(ref self, data:[4]int) {
    mut acc = 0
    for e in data {
      acc = acc + e
    }
    self.total = acc
    self.last = data[3]
  }
)

mut a:Accum = (1, 2, 3, 4)   // total 10, last 4
mut b:Accum = (10, 20, 30, 5)

cassert(a.total == 10)
cassert(a.last == 4)
cassert(b.total == 65)
cassert(b.last == 5)
