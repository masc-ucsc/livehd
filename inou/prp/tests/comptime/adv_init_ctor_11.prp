/*
:name: adv_init_ctor_11
:type: comptime
:verifier_pass: 4
:verifier_fail: 0
*/

// init that takes a single array-typed param and loops (comptime unrolled) to
// accumulate. The construction tuple binds WHOLE to init's single `[4]int`
// param: try_init_construction tries the whole-tuple single-arg form before
// exploding the tuple into N positional args.

type Accum = (
  mut total:int = nil,
  mut last:int = nil,
  comb init(ref self, data:[4]int) {
    mut acc = 0
    for e in data {
      acc = acc + e
    }
    self.total = acc
    self.last = data[3]
  }
)

mut a:Accum = (1, 2, 3, 4)   // total 10, last 4
mut b:Accum = (10, 20, 30, 5)

cassert(a.total == 10)
cassert(a.last == 4)
cassert(b.total == 65)
cassert(b.last == 5)
