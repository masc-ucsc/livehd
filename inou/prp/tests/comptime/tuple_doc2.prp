/*
:name: tuple_doc2
:type: parsing lnast comptime
:verifier_pass: 12
:verifier_fail: 0
*/

{
        const x = (first=(second=3))
        // Single-entry named tuple collapses to its scalar via is_scalar()
        // + recursive get_trivial() in process_eq_ne_impl.
        cassert(x == 3 == x.first == x.first.second)
}

{
  mut c = (x=1, const b = 2, mut d = 3)
  c.x = 3
  c.d = 30
}

{
  mut b = 100
  mut a = (b:u8, b, b:u8 = 0, const c = 4)
  a.b = 200
  // Decision 1: keep named slots named in the RHS literal — `a` has
  // mixed shape (unnamed 0,1 + named b,c), so the literal must match.
  cassert(a == (100, 100, b=200, c=4))

  mut f = (b=3, const e = 5)
  f.b = 4
}

{
  mut a = (a=1,b=2)
  const b = (c=3)

  const ccat1 = (...a, ...b)
  cassert(ccat1 == (a=1,b=2,c=3))
  // `ccat1 == (1,2,3)` is false — a named tuple never compares equal to an
  // unnamed (positional) tuple via positional cross-match (see tuple_simple5).
}

{
  cassert((...(1,a=2,c=3), ...(b=20,33,d=30,4)) == (1,a=2,c=3,b=20,33,d=30,4))
}

{
  const x = (first=(second=3))

  cassert(x.first.second == 3)
  cassert(x.first        == 3)
  cassert(x              == 3)
  // Decision 1: dropped `x.0.second`, `x.first.0`, `x.0` — positional
  // access to an all-named tuple is no longer valid.
}

{
  mut bund1 = (0,1,2,3,4)

  mut bund2 = (bund1,bund1,((10,20),30))
  cassert(bund2[0][1] == 1)
  cassert(bund2[1][1] == 1)
  cassert(bund2[2][0] == (10,20))
  cassert(bund2[2][0][1] == 20)
  cassert(bund2[2][1] == 30)
}
