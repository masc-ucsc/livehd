/*
:name: tuple_doc2
:type: parsing lnast upass
*/

{
  mut c = (x=1, const b = 2, mut d = 3)
  c.x = 3
  c.d = 30
}

{
  mut b = 100
  mut a = (b:u8, b, b:u8 = 0, const c = 4)
  a.b = 200
  cassert a == (100, 100, 200, 4)

  mut f = (b=3, const e = 5)
  f.b = 4
}

{
  mut a = (a=1,b=2)
  const b = (c=3)

  const ccat1 = a ++ b
  cassert ccat1 == (a=1,b=2,c=3)
  cassert ccat1 == (1,2,3)
}

{
  cassert (((1,a=2,c=3) ++ (a=20,33,c=30,4)) == (1,a=(2,20),c=(3,30),33,4))
}

{
  const x = (first=(second=3))

  cassert x.first.second == 3
  cassert x.first        == 3
  cassert x              == 3
  cassert x.0.second     == 3
  cassert x.first.0      == 3
  cassert x.0            == 3
}

{
  mut bund1 = (0,1,2,3,4)

  mut bund2 = (bund1,bund1,((10,20),30))
  cassert bund2[0][1] == 1
  cassert bund2[1][1] == 1
  cassert bund2[2][0] == (10,20)
  cassert bund2[2][0][1] == 20
  cassert bund2[2][1] == 30
}
