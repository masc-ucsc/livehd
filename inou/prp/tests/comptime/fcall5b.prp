/*
:name: fcall5b
:type: comptime
:verifier_pass: 10
:verifier_fail: 0
*/
// dox returns a nested tuple (foo has sub-fields bar and baz) plus a scalar c
comb dox(a) -> (foo, c) {
  foo = (bar = a + 1, baz = a + 2)
  c   = a + 10
}

// whatever: same shape, different name — used to test rename of return fields
comb whatever(a) -> (foo, c) {
  foo = (bar = a + 100, baz = a + 200)
  c   = a + 1000
}

// OK — local names match the return-field names; foo keeps its nested shape
mut (foo, c) = dox(a=3)
cassert(foo.bar == 4 and foo.baz == 5)
cassert(c == 13)

// OK — rename across nested paths: dox.foo.bar -> x, dox.foo.baz -> y, dox.c -> z
mut (x = dox.foo.bar, y = dox.foo.baz, z = dox.c) = dox(a=10)
cassert(x == 11 and y == 12 and z == 20)

// OK — reassign with nested rename, order doesn't matter (bind by name)
(z = dox.c, y = dox.foo.baz, x = dox.foo.bar) = dox(a=20)
cassert(x == 21 and y == 22 and z == 30)

// OK — discard the return value entirely (no capture on the LHS)
dox(a=99)

// match against a nested tuple rebuilt from a destructured call result
const (tfoo = dox.foo, tc = dox.c) = dox(a=5)
const t = (const foo = tfoo, const c = tc)
mut hit = 0
match t {
  == (foo=(bar=0, baz=0), c=0)   { hit = 100 }
  == (foo=(bar=6, baz=7), c=15)  { hit = 200 }
  else                           { hit = 300 }
}
cassert(hit == 200)

// match using `case` pattern with wildcards (flat shape — match on the nested
// `foo` field directly). NOTE: matching `case` on a *nested* sub-bundle pattern
// (e.g. `match t { case (foo=(bar=0sb?, baz=7), ...) }`) does not comptime-fold
// yet — fold_case only walks first-level entries and defers on sub-bundles, so
// the arm stays runtime and hit2 would be unresolved. Recursive nested-`case`
// folding (mirroring nested `==`/compare_bundles_eq) is a follow-up.
mut hit2 = 0
match t.foo {
  case (bar=0sb?, baz=7) { hit2 = 1 }
  case (bar=0sb?, baz=0) { hit2 = 2 }
  else                   { hit2 = 3 }
}
cassert(hit2 == 1)

// rename the whole nested field + the scalar via remap, using a different func
mut (wfoo = whatever.foo, wc = whatever.c) = whatever(a=20)
cassert(wfoo.bar == 120 and wfoo.baz == 220)
cassert(wc == 1020)

// reassign (no mut) — order swapped, bind by name
(wc = whatever.c, wfoo = whatever.foo) = whatever(a=30)
cassert(wfoo == (bar=130, baz=230))
cassert(wc == 1030)
