/*
:name: tuple_doc1
:type: parsing
*/

{
  mut a = (r1 = (b=1,c=2), r2 = (3,4))
  cassert a.r1 == (1,2) and a.r2 == (3,4)
  cassert a.0  == (1,2) and a[1] == (3,4)

  cassert a.r1.c    == 2
  cassert a['r1'].c == 2
  cassert a.r1.1    == 2
  cassert a.r1[1]   == 2
  cassert a[0][1]   == 2
  cassert a[0]['c'] == 2
  cassert a.0.c     == 2
  cassert a.0.1     == 2
}

{
  mut a = (foo = 3)
  cassert a has 'foo'
  cassert !(a has 'bar')
  cassert a !has 'bar'
  cassert a has 0
  cassert a !has 1
}

{
  const xx = 3

  mut a = (xx, xx = 44, foo = 55)
  cassert a == (3, 44, 55) == (3, xx=44, foo=55)
  cassert xx == 3
}

{
  mut a = (1, 2)
  mut b = (1,)
  mut c = 1
  mut d = (1,)

  cassert a.0 == b.0 == c.0 == d.0
  cassert a != b
  cassert b == c == d
}
