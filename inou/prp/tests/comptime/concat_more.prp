/*
:name: concat_more
:type: parsing lnast comptime
:verifier_pass: 22
:verifier_fail: 0
*/

{
  const lhs = (a=1,b=2)
  const rhs = (c=3,d=4)
  const got = (...lhs, ...rhs)

  cassert(got == (a=1,b=2,c=3,d=4))
  cassert(got.a + got.d == 5)
  cassert(got.b + got.c == 5)
}

{
  const lhs = (cfg=(lo=1,hi=2), tag=7)
  const rhs = (cfg=(bar=3,extra=4), out=8)
  const got = (...lhs, ...rhs)

  cassert(got.cfg.lo == 1)
  cassert(got.cfg.hi == 2)
  cassert(got.cfg has 'bar' and got.cfg.bar == 3)
  cassert(got.cfg has 'extra' and got.cfg.extra == 4)
  cassert(got.tag + got.out == 15)
}

{
  const got = (...(lane=(zero=0)), ...(lane=(one=1)), ...(lane=(two=2)))

  cassert(got.lane == (zero=0,one=1,two=2))
  cassert(got.lane has 'one' and got.lane has 'two')
}

{
  const got = (...(10,a=1), ...(20,b=2,30), ...(c=3,40))

  cassert(got.a + got.b + got.c == 6)
  cassert(got[0] == 10)
  cassert(got[1] + got[2] + got[3] == 90)
}

{
  const base = (left=1, mid=(x=2))
  const tail = (right=3, last=4)
  const got = (head=0, ...base, marker=9, ...tail)

  cassert(got == (head=0,left=1,mid=(x=2),marker=9,right=3,last=4))
  cassert(got.mid.x == 2)
  cassert(got.head + got.left + got.right + got.last == 8)
}

{
  const got = (5, ...(a=6), 7)

  cassert(got == (5,a=6,7))
  cassert(got[0] + got.a + got[1] == 18)
}

{
  const got = (...(a=2, b=nil), ...(a=2, b=10, c=3))

  cassert(got.a == 2)
  cassert(got.b == 10)
  cassert(got.c == 3)
}

{
  // Overlapping concat by choice: nil-out the slots that the other side wins.
  mut a = (mut f1:u32=1, mut f2:u32=2)
  mut b = (mut f1:u32=3, mut f2:u32=4)
  a.f1 = nil
  b.f2 = nil
  const x = (...a, ...b)
  cassert(x.f1==3 and x.f2==2)
}
