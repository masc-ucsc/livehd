/*
:name: tuple_simple2
:type: parsing lnast comptime
:verifier_pass: 3
:verifier_fail: 0
*/

mut t = (1,2)

t = (...t, ...(b=3,44))

cassert(t[0] == 1 and t[1]==2 and t.b==3 and t[2]==44)

cassert(t == (1,2,b=3,44))

mut x = ()

x = (1,2,3,7)

x[3] = 44

// x!=t because t is named b=3
cassert(x != t and x[3] == 44)
