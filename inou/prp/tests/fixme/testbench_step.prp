/*
:name: testbench_step
:type: simulation
*/
// Remaining TBD: the string-path `peek("a/b")` / `poke("a/b", v)` accessors for
// arbitrary hierarchical signals (docs/pyrope/09-verification.md, 15-tbd.md).
// The instance/`step`/field-poke model below (mut dut = cnt; dut.en = true; step;
// dut.v) runs today -- only the string-path `peek`/`poke` are unimplemented, so
// this fails by design. Tagged `fixme` until the arbitrary-path probe lands.
mod cnt(en:bool) -> (v:u8@[0]) {
  reg c:u8 = 0
  v = c
  if en { wrap c += 1 }
}
test peek_poke_path {
  mut dut = cnt
  dut.en = true
  step
  assert(peek("cnt/c") == 1)     // string-path peek -- still TBD
  poke("cnt/c", 42)              // string-path poke -- still TBD
  step
  assert(peek("cnt/c") == 43)
}
