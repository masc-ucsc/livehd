/*
:name: testbench_step
:type: simulation
*/
// TBD feature: testbench extras peek/poke (docs/pyrope/09-verification.md,
// 15-tbd.md). `peek()` should read a hierarchical signal and `poke()` force one.
// `step` now parses as a statement (advance the simulation a cycle) but the
// `lhd sim` backend does not execute it yet; `peek`/`poke` remain undefined.
// Tagged `fixme`: fails by design until the interactive testbench runner exists.
mod cnt(en:bool) -> (v:u8@[0]) {
  reg c:u8 = 0
  v = c
  if en { wrap c += 1 }
}
test peek_poke_step {
  const o = cnt(en=true)
  step
  assert(peek("cnt/c") == 1)
  poke("cnt/c", 42)
  step
  assert(peek("cnt/c") == 43)
}
