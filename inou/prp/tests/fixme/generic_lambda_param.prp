/*
:name: generic_lambda_param
:type: compile
*/
// TBD feature (docs/pyrope/06-functions.md, 15-tbd.md; todo/livehd/3g.html
// subtask A): a LAMBDA-valued generic called in the body. The call-site
// `apply<inc>(…)` already parses and passes arity; the body call of `F`
// fails:
//   undefined-call: call to undefined function 'F'
// The concrete substitution (`r = inc(v=a)`) compiles green, so this file
// flips green exactly when lambda generics land.
comb inc(v:u8) -> (o:u9) {
  o = v + 1
}
comb apply<F>(a:u8) -> (r:u9) {
  r = F(v=a)
}
pub comb generic_lambda_param(x:u8) -> (r:u9) {
  r = apply<inc>(a=x)
}
