/*
:name: reduce_or_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `foo` with the same LCG stimulus as reduce_or_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const foo = import("reduce_or.foo")

test reduce_or.sig {
  mut acc = foo
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.b = s & 0xff
    step
    sig = sig * 1099511628211 + (acc.or_ur & 0x1)
    sig = sig * 1099511628211 + (acc.or_sr & 0x1)
    sig = sig * 1099511628211 + (acc.or_uf & 0x1)
    sig = sig * 1099511628211 + (acc.or_sf & 0x1)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 1535089949254367839, "signature mismatch vs iverilog golden reduce_or")
}
