// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `csel` with the same LCG stimulus as dyn_tuple_const_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const csel = import("dyn_tuple_const.csel")

test dyn_tuple_const.sig {
  mut acc = csel
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.sel = s & 0x3
    step
    sig = sig * 1099511628211 + (acc.z & 0xff)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 78162719416499944, "signature mismatch vs iverilog golden dyn_tuple_const")
}
