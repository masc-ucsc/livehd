/*
:name: mod_mux_aligned_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `pick` with the same LCG stimulus as mod_mux_aligned_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const pick = import("mod_mux_aligned.pick")

test mod_mux_aligned.sig {
  mut acc = pick
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.sel = s & 0x1
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.b = s & 0xff
    step
    if clock >= 32 {
      sig = sig * 1099511628211 + (acc.out & 0x1ff)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 3351615415236319844, "signature mismatch vs iverilog golden mod_mux_aligned")
}
