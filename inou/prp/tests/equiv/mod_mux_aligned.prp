/*
:name: mod_mux_aligned
:type: equiv
:verilog_top: mod_mux_aligned.pick
:pyrope_top: mod_mux_aligned.pick
*/

// 2d-reg — a mux whose data legs all land at the SAME cycle (the select
// never adds path depth): the arm union at the Mux cell is the single cycle
// 1, matching the declared landing. Arms at DIFFERENT cycles union into a
// range instead — see mod_twopaths.
mod pick(sel:bool, a:u8, b:u8) -> (out:u9@[1]) {
  stage[1] sd = sel
  stage[1] ad = a
  stage[1] bd = b
  mut r:u9 = 0
  if sd {
    r = ad + 1
  } else {
    r = bd + 2
  }
  out = r
}
