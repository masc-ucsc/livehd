/*
:name: reg_attr_override_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `blink` with the same LCG stimulus as reg_attr_override_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const blink = import("reg_attr_override.blink")

test reg_attr_override.sig {
  mut acc = blink
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.rst_n = s & 0x1
    s = s * 6364136223846793005 + 1442695040888963407
    acc.en = s & 0x1
    step
    if clock >= 32 {
      sig = sig * 1099511628211 + (acc.q & 0xff)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 2617919512181924688, "signature mismatch vs iverilog golden reg_attr_override")
}
