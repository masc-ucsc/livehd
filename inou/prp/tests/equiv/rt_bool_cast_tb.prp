// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `rt_bool_cast` with the same LCG stimulus as rt_bool_cast_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const rt_bool_cast = import("rt_bool_cast.rt_bool_cast")

test rt_bool_cast.sig {
  mut acc = rt_bool_cast
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.b = s & 0xff
    step
    sig = sig * 1099511628211 + (acc.zb & 0x1)
    sig = sig * 1099511628211 + (acc.zc & 0xf)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 3074296632502308104, "signature mismatch vs iverilog golden rt_bool_cast")
}
