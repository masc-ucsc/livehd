/*
:name: sim_loop_packed_bus_group
:type: equiv
:verilog_top: sim_loop_packed_bus_group
:pyrope_top: sim_loop_packed_bus_group
*/

// False word-level comb loop through a HIERARCHICALLY packed bus. bus =
// lo | (((ren<<10)|(addr<<8)|rdata) << 4): the read address is taken back OUT
// of the packed bus (bus#[12..=13], driven only by input `addr`) and selects
// rdata, which feeds back INTO the same bus at a DISJOINT field (bus[11:4]).
// The bit-level DAG is acyclic. split_packed_selfref_wires redirects the
// slice readers ONE level (onto the `<< 4` group shl), but that group still
// contains both the read field (addr) and the written field (rdata), so the
// word-level cycle survives and cgen.sim names the shl as the back-edge.
pub comb sim_loop_packed_bus_group::[timecheck=false](lo:u4, ren:u1, addr:u2, x:u32) -> (z:u8) {
  wire bus:u15
  wire rdata:u8
  rdata = (x >> (bus#[12..=13] * 8))#[0..=7]
  bus = lo | (((ren << 10) | (addr << 8) | rdata) << 4)
  z = bus#[4..=11]
}
