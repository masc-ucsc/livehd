// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `foo` with the same LCG stimulus as bitset_nil_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const foo = import("bitset_nil.foo")

test bitset_nil.sig {
  mut acc = foo
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.i = s & 0xffffffff
    step
    sig = sig * 1099511628211 + acc.io_sextImm
    sig = sig * 1099511628211 + (acc.io_direct & 0x1fff)
    sig = sig * 1099511628211 + acc.s_sext
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 1184756099601778804, "signature mismatch vs iverilog golden bitset_nil")
}
