// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `foo` with the same LCG stimulus as mod_comp_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const foo = import("mod_comp.foo")

test mod_comp.sig {
  mut acc = foo
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.b = s & 0xff
    step
    sig = sig * 1099511628211 + (acc.rp2 & 0xf)
    sig = sig * 1099511628211 + (acc.r3 & 0x3)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 1945942368084240209, "signature mismatch vs iverilog golden mod_comp")
}
