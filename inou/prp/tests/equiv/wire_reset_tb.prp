/*
:name: wire_reset_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `wreset` with the same LCG stimulus as wire_reset_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const wreset = import("wire_reset.wreset")

test wire_reset.sig {
  mut acc = wreset
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.rst = s & 0x1
    s = s * 6364136223846793005 + 1442695040888963407
    acc.do_flush = s & 0x1
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    step
    if clock >= 32 {
      sig = sig * 1099511628211 + (acc.o & 0xff)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 0, "signature mismatch vs iverilog golden wire_reset")
}
