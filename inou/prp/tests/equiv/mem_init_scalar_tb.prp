/*
:name: mem_init_scalar_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `regi` with the same LCG stimulus as mem_init_scalar_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const regi = import("mem_init_scalar.regi")

test mem_init_scalar.sig {
  mut acc = regi
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.i = s & 0x3
    s = s * 6364136223846793005 + 1442695040888963407
    acc.we = s & 0x1
    step
    if clock >= 32 {
      sig = sig * 1099511628211 + (acc.z & 0xff)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 4039755206806309604, "signature mismatch vs iverilog golden mem_init_scalar")
}
