// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `my_top` with the same LCG stimulus as lg_rename_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const my_top = import("lg_rename.my_top")

test lg_rename.sig {
  mut acc = my_top
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.b = s & 0xff
    step
    sig = sig * 1099511628211 + (acc.r & 0x1ff)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 263260108434056480, "signature mismatch vs iverilog golden lg_rename")
}
