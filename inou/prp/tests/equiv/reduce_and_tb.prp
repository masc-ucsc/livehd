/*
:name: reduce_and_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `foo` with the same LCG stimulus as reduce_and_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const foo = import("reduce_and.foo")

test reduce_and.sig {
  mut acc = foo
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.b = s & 0xff
    step
    sig = sig * 1099511628211 + (acc.an_ur & 0x1)
    sig = sig * 1099511628211 + (acc.an_sr & 0x1)
    sig = sig * 1099511628211 + (acc.an_uf & 0x1)
    sig = sig * 1099511628211 + (acc.an_sf & 0x1)
    sig = sig * 1099511628211 + (acc.an_1 & 0x1)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 4253040147984044597, "signature mismatch vs iverilog golden reduce_and")
}
