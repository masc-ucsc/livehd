/*
:name: shift_combo_i8_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `top` with the same LCG stimulus as shift_combo_i8_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const top = import("shift_combo_i8.top")

test shift_combo_i8.sig {
  mut acc = top
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.b = s & 0x3
    step
    sig = sig * 1099511628211 + (acc.r & 0xff)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 1721934318787632680, "signature mismatch vs iverilog golden shift_combo_i8")
}
