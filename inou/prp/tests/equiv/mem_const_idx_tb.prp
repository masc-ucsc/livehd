// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `cidx` with the same LCG stimulus as mem_const_idx_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const cidx = import("mem_const_idx.cidx")

test mem_const_idx.sig {
  mut acc = cidx
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.b = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.we = s & 0x1
    step
    if clock >= 32 {
      sig = sig * 1099511628211 + (acc.z & 0xff)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 2599186774691762088, "signature mismatch vs iverilog golden mem_const_idx")
}
