/*
:name: bitset_imm
:type: equiv
:verilog_top: bitset_imm.foo
:pyrope_top: bitset_imm.foo
*/

// Per-range LHS bit-assembly (`b#[lo..=hi] = src`) into a `mut` accumulator,
// the RISC-V-immediate idiom. The four writes are CONTIGUOUS (reach 4, 10, 11,
// 12) so the result grows one zero sign-bit at a time; the same assembled `b`
// is then read three ways to cover sign vs unsigned extraction:
//   io_sextImm = (b#sext[0..=12])#[0..=63]   sign-extend from bit 12, mask 64
//   io_zext    = (b#[0..=12])#[0..=63]        zero-extend the unsigned u13
//   io_direct  = b                            bare unsigned u13 read
// Equivalent (LEC-proven) to building the value with shifts + `|` (golden .v).
comb foo(i:u32) -> (io_sextImm:i64, io_zext:u64, io_direct:u13) {
  mut b:u13 = 0
  b#[1..=4]  = i#[8..=11]
  b#[5..=10] = i#[25..=30]
  b#[11]     = i#[7]
  b#[12]     = i#[31]
  io_sextImm = (b#sext[0..=12])#[0..=63]
  io_zext    = (b#[0..=12])#[0..=63]
  io_direct  = b
}
