/*
:name: mem_init_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `mem_init` with the same LCG stimulus as mem_init_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const mem_init = import("mem_init.mem_init")

test mem_init.sig {
  mut acc = mem_init
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.raddr = s & 0x3
    acc.reset = clock < 4
    step
    if clock >= 4 {
      sig = sig * 1099511628211 + (acc.q & 0xff)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 3934873786989097786, "signature mismatch vs iverilog golden mem_init")
}
