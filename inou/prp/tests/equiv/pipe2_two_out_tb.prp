/*
:name: pipe2_two_out_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `two` with the same LCG stimulus as pipe2_two_out_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const two = import("pipe2_two_out.two")

test pipe2_two_out.sig {
  mut acc = two
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xf
    s = s * 6364136223846793005 + 1442695040888963407
    acc.b = s & 0xf
    step
    if clock >= 32 {
      sig = sig * 1099511628211 + (acc.x & 0xff)
      sig = sig * 1099511628211 + (acc.y & 0xff)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 1325275294945046872, "signature mismatch vs iverilog golden pipe2_two_out")
}
