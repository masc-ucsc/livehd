/*
:name: bitsel_dyn_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `bsel` with the same LCG stimulus as bitsel_dyn_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const bsel = import("bitsel_dyn.bsel")

test bitsel_dyn.sig {
  mut acc = bsel
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.g = s & 0xffff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.idx = s & 0xf
    step
    sig = sig * 1099511628211 + (acc.z & 0x1)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 422267417980229489, "signature mismatch vs iverilog golden bitsel_dyn")
}
