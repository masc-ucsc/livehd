/*
:name: implies_ops_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `top` with the same LCG stimulus as implies_ops_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const top = import("implies_ops.top")

test implies_ops.sig {
  mut acc = top
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0x1
    s = s * 6364136223846793005 + 1442695040888963407
    acc.b = s & 0x1
    s = s * 6364136223846793005 + 1442695040888963407
    acc.c = s & 0x1
    s = s * 6364136223846793005 + 1442695040888963407
    acc.x = s & 0xf
    s = s * 6364136223846793005 + 1442695040888963407
    acc.y = s & 0xf
    step
    sig = sig * 1099511628211 + (acc.out1 & 0x1)
    sig = sig * 1099511628211 + (acc.out2 & 0x1)
    sig = sig * 1099511628211 + (acc.out3 & 0x1)
    sig = sig * 1099511628211 + (acc.out4 & 0x1)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 2663830029662940642, "signature mismatch vs iverilog golden implies_ops")
}
