/*
:name: sim_sub_stateful_feedback_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `top` with the same LCG stimulus as sim_sub_stateful_feedback_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const top = import("sim_sub_stateful_feedback.top")

test sim_sub_stateful_feedback.sig {
  mut acc = top
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.go = s & 0x1
    s = s * 6364136223846793005 + 1442695040888963407
    acc.flush = s & 0x1
    acc.reset = clock < 4
    step
    if clock >= 4 {
      sig = sig * 1099511628211 + (acc.ready_o & 0x1)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 2941984850869488968, "signature mismatch vs iverilog golden sim_sub_stateful_feedback")
}
