// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `mixedarm` with the same LCG stimulus as condout_mixed_arms_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const mixedarm = import("condout_mixed_arms.mixedarm")

test condout_mixed_arms.sig {
  mut acc = mixedarm
  mut s_   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s_ = s_ * 6364136223846793005 + 1442695040888963407
    acc.s = s_ & 0x1
    s_ = s_ * 6364136223846793005 + 1442695040888963407
    acc.a = s_ & 0x3
    step
    sig = sig * 1099511628211 + (acc.o & 0x3)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 3482249017062270872, "signature mismatch vs iverilog golden condout_mixed_arms")
}
