/*
:name: rt_typecast_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `rt_typecast` with the same LCG stimulus as rt_typecast_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const rt_typecast = import("rt_typecast.rt_typecast")

test rt_typecast.sig {
  mut acc = rt_typecast
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.b = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.c = s & 0xf
    step
    sig = sig * 1099511628211 + (acc.zi & 0xf)
    sig = sig * 1099511628211 + (acc.zu & 0xf)
    sig = sig * 1099511628211 + (acc.zs & 0xf)
    sig = sig * 1099511628211 + (acc.zc & 0xff)
    sig = sig * 1099511628211 + (acc.zd & 0xff)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 819646832305659613, "signature mismatch vs iverilog golden rt_typecast")
}
