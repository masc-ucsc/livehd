/*
:name: mod_mut_delay
:type: equiv
:verilog_top: mod_mut_delay.f
:pyrope_top: mod_mut_delay.f
*/

// Task 1r/1q — a `mut` integer is captured at the lambda declaration point and
// resolves the `@[runtime_delay]` landing-cycle slot. Here runtime_delay==2 at
// the point `f` is declared, so `@[runtime_delay]` is the depth-2 stage's
// landing cycle. `stage[2] x = a` delivers `a` two cycles later (a depth-2
// shift register).
mut runtime_delay = 2
mod f(a:u8) -> (x:u8@[runtime_delay]) {
  stage[2] x = a
}
