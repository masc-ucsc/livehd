/*
:name: io_bundle_nested
:type: equiv_slang
:verilog_top: io_bundle_nested.top
:pyrope_top: top
*/

// Pyrope reference for io_bundle_nested.v: `io_c = io_x ? io_a : 0` (the
// nested-struct bundle is purely a Verilog naming artifact -- see the .v
// header). FIXED (2026-06-30): the nested-struct `io` bundle now splits into
// per-field leaf nets, so prp-v2prp-io_bundle_nested PROVES equivalent (see the
// .v header for the slang_structure.cpp fix).
comb top(io_x:u1, io_a:u2) -> (io_c:u2) {
  if io_x != 0 {
    io_c = io_a
  } else {
    io_c = 0
  }
}
