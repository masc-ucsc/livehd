/*
:name: mem_pending_reset_restore
:type: equiv
:verilog_top: mem_pending_reset_restore.restore
:pyrope_top: mem_pending_reset_restore.restore
*/

// The async memory read lands @[0]: committed state, like a scalar reg read.
mod restore(reset:bool, a:u4, i:u1, we:bool) -> (z:u4@[0]) {
  reg t:[2]u4 = (4, 9)
  z = t[i]
  if we {
    t[i] = a
  }
}
