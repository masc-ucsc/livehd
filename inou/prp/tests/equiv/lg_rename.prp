/*
:name: lg_rename
:type: equiv
:verilog_top: chip_top
:pyrope_top: my_top
*/

// The `lg="…"` attribute is now INERT: it is still parsed (for backward
// compatibility) but no longer renames the artifact. The generated module keeps
// its own name `my_top` (Verilog flattens the hierarchical `lg_rename.my_top` to
// `my_top`), NOT `chip_top`. The equiv check proves that the (inert-lg) artifact
// is logically `a + b` regardless of the golden's independent module name.

pub comb my_top(a:u8, b:u8) -> (r:u9) { r = a + b }
