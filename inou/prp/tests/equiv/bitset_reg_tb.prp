/*
:name: bitset_reg_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `foo` with the same LCG stimulus as bitset_reg_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const foo = import("bitset_reg.foo")

test bitset_reg.sig {
  mut acc = foo
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.b = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.en = s & 0x1
    acc.reset = clock < 4
    step
    if clock >= 4 {
      sig = sig * 1099511628211 + (acc.o_cont & 0xfff)
      sig = sig * 1099511628211 + (acc.o_over & 0xfff)
      sig = sig * 1099511628211 + (acc.o_rev & 0xfff)
      sig = sig * 1099511628211 + (acc.o_hold & 0xfff)
      sig = sig * 1099511628211 + (acc.o_cond & 0xfff)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 321236754055697546, "signature mismatch vs iverilog golden bitset_reg")
}
