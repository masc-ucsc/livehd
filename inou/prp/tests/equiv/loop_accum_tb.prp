/*
:name: loop_accum_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `top` with the same LCG stimulus as loop_accum_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const top = import("loop_accum.top")

test loop_accum.sig {
  mut acc = top
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    step
    sig = sig * 1099511628211 + (acc.z & 0x3ff)
    sig = sig * 1099511628211 + (acc.w & 0x1ff)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 1371132354780885224, "signature mismatch vs iverilog golden loop_accum")
}
