/*
:name: mem_comptime_init_inferred
:type: equiv
:verilog_top: mem_comptime_init_inferred.mcii
:pyrope_top: mem_comptime_init_inferred.mcii
*/

// 2f-mem_comptime_init — the INFERRED form: a reg with no array type whose
// initializer is a comptime-computed array bundle. The runner synthesizes the
// reg's comp_type_array (dims + element envelope) from the initializer and
// materializes the literal, so it lowers to a memory exactly like the typed
// form.
mod mcii(reset:bool, i:u1, j:u1) -> (z:u4@[0]) {
  comptime mut iv:[2][2]u4 = nil
  for a in 0..<2 {
    for b in 0..<2 {
      iv[a][b] = a * 2 + b + 1   // ((1,2),(3,4))
    }
  }
  reg t = iv                     // no type — inferred [2][2]u4
  z = t[i][j]
}
