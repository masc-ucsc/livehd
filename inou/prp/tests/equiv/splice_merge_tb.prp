// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `spl` with the same LCG stimulus as splice_merge_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const spl = import("splice_merge.spl")

test splice_merge.sig {
  mut acc = spl
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.in1 = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.in2 = s & 0xff
    step
    sig = sig * 1099511628211 + (acc.out & 0xffff)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 2269644197427039392, "signature mismatch vs iverilog golden splice_merge")
}
