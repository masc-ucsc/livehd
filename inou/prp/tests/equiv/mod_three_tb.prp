// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `foo` with the same LCG stimulus as mod_three_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const foo = import("mod_three.foo")

test mod_three.sig {
  mut acc = foo
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xf
    s = s * 6364136223846793005 + 1442695040888963407
    acc.w = s & 0xffff
    step
    sig = sig * 1099511628211 + (acc.r4 & 0x3)
    sig = sig * 1099511628211 + (acc.r16 & 0x3)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 874090784195920058, "signature mismatch vs iverilog golden mod_three")
}
