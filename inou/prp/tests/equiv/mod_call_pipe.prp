/*
:name: mod_call_pipe
:type: equiv
:verilog_top: mod_call_pipe.top
:pyrope_top: mod_call_pipe.top
*/

// Task 1u-A — first hierarchical LEC: a mod instantiates a pipe[3] as an
// Ntype_op::Sub instance; stage[3] picks the declared latency exactly
// (deficit 0 — the stage binding realizes as a wire, no extra flops).
pipe[3] mul(a:u16, b:u16) -> (c:u32) { c = a * b }

mod top(in1:u16, in2:u16) -> (out:u32@[3]) {
  stage[3] tmp = mul(in1, in2)
  out = tmp
}
