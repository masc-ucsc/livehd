/*
:name: generic_mod_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `top` with the same LCG stimulus as generic_mod_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const top = import("generic_mod.top")

test generic_mod.sig {
  mut acc = top
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.x = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.y = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.w = s & 0xffff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.v = s & 0xffff
    step
    sig = sig * 1099511628211 + (acc.s8 & 0xff)
    sig = sig * 1099511628211 + (acc.s16 & 0xffff)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 3664878489717154400, "signature mismatch vs iverilog golden generic_mod")
}
