/*
:name: reduce_and
:type: equiv
:verilog_top: reduce_and.foo
:pyrope_top: foo
*/

// AND-reduction `foo#&[range]`: the get_mask slice is sign-extended from its
// top bit (so an all-ones slice reads as the signed -1) then compared `== -1`.
// Covers unsigned/signed operands, closed range and the open `#[..]` form,
// plus a single-bit range (k==1). Result is int 0/1.
pub comb foo(a:u8, b:s8) -> (an_ur:u1, an_sr:u1, an_uf:u1, an_sf:u1, an_1:u1) {
  an_ur = a#&[2..=4]   // unsigned, bits 2..4
  an_sr = b#&[2..=4]   // signed,   bits 2..4
  an_uf = a#&[..]      // unsigned, all 8 type bits
  an_sf = b#&[..]      // signed,   all 8 type bits
  an_1  = a#&[5]       // single selected bit (k==1)
}
