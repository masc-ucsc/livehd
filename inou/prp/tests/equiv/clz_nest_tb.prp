/*
:name: clz_nest_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `clz` with the same LCG stimulus as clz_nest_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const clz = import("clz_nest.clz")

test clz_nest.sig {
  mut acc = clz
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.io_in = s & 0x3ff
    step
    sig = sig * 1099511628211 + (acc.io_out & 0xf)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 3233550808660370795, "signature mismatch vs iverilog golden clz_nest")
}
