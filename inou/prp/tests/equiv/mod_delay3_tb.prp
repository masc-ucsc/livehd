/*
:name: mod_delay3_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `delay3` with the same LCG stimulus as mod_delay3_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const delay3 = import("mod_delay3.delay3")

test mod_delay3.sig {
  mut acc = delay3
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    step
    if clock >= 32 {
      sig = sig * 1099511628211 + (acc.x & 0xff)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 2538187469350063724, "signature mismatch vs iverilog golden mod_delay3")
}
