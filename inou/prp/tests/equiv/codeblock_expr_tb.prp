// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `blk` with the same LCG stimulus as codeblock_expr_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const blk = import("codeblock_expr.blk")

test codeblock_expr.sig {
  mut acc = blk
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.in1 = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.in2 = s & 0xff
    step
    sig = sig * 1099511628211 + (acc.out & 0xffff)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 3575016845520213696, "signature mismatch vs iverilog golden codeblock_expr")
}
