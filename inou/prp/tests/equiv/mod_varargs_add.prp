/*
:name: mod_varargs_add
:type: equiv
:verilog_top: mod_varargs_add.top
:pyrope_top: mod_varargs_add.top
*/

// Task 1p/2u follow-on — the `mod` analog of varargs_add: a var-arg `mod`
// whose body sums its leftovers with a `for a in args` loop. Variation vs the
// pipe test: a fixed leading operand `op` is added in too (acc starts at op).
// Combinational (`@[0]`), so the golden is a flat adder.
mod add_op(op:u8, ...args) -> (r:u11@[0]) {
  mut acc = op
  for a in args {
    acc = acc + a
  }
  r = acc
}

mod top(op:u8, a:u8, b:u8, c:u8) -> (z:u11@[0]) {
  z = add_op(op, a, b, c)
}
