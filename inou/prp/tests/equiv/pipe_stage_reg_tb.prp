// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `split` with the same LCG stimulus as pipe_stage_reg_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const split = import("pipe_stage_reg.split")

test pipe_stage_reg.sig {
  mut acc = split
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.b = s & 0xff
    acc.reset = clock < 4
    step
    if clock >= 4 {
      sig = sig * 1099511628211 + (acc.x & 0x1ff)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 3263893527130874256, "signature mismatch vs iverilog golden pipe_stage_reg")
}
