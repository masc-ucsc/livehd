/*
:name: array_selfref
:type: equiv_slang
:verilog_top: array_selfref.top
:pyrope_top: top
*/

// Pyrope reference for array_selfref.v: `z = a_0 ^ a_1` (substituting
// vec[0]=a_0 into vec[1]'s expression -- see the .v header for why the
// literal Verilog shape is NOT actually cyclic). FIXED (2026-06-30): the
// self-referencing packed array now splits into per-element wire leaf nets, so
// prp-v2prp-array_selfref PROVES equivalent (see the .v header for the fix).
pub comb top(a_0:u2, a_1:u2) -> (z:u2) {
  z = a_0 ^ a_1
}
