/*
:name: overload_dispatch_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `ovdispatch` with the same LCG stimulus as overload_dispatch_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const ovdispatch = import("overload_dispatch.ovdispatch")

test overload_dispatch.sig {
  mut acc = ovdispatch
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.x = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.y = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.z = s & 0xff
    step
    sig = sig * 1099511628211 + (acc.s2 & 0x1ff)
    sig = sig * 1099511628211 + (acc.s3 & 0x3ff)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 1799845389047405164, "signature mismatch vs iverilog golden overload_dispatch")
}
