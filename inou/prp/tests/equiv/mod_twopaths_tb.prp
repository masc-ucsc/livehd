/*
:name: mod_twopaths_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `twopaths` with the same LCG stimulus as mod_twopaths_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const twopaths = import("mod_twopaths.twopaths")

test mod_twopaths.sig {
  mut acc = twopaths
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xffffffff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.opt = s & 0x1
    step
    if clock >= 32 {
      sig = sig * 1099511628211 + (acc.o & 0xffffffff)
      sig = sig * 1099511628211 + (acc.o2 & 0xffffffff)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 606292484874397344, "signature mismatch vs iverilog golden mod_twopaths")
}
