/*
:name: mem_init_tuple
:type: equiv
:verilog_top: mem_init_tuple.regi2
:pyrope_top: mem_init_tuple.regi2
*/

// 1a-mem — a tuple-literal reg-array initializer packs per entry onto the
// Memory `init` pin (entry 0 in the low bits): power-on contents, same
// mechanism as a mut array's initializer; with no reset in the module it is
// power-on-only. The clocked-memory read lands @[1].
mod regi2(a:u8, i:u2, we:bool) -> (z:u8@[1]) {
  reg t:[4]u8 = (1,2,3,4)
  if we {
    t[i] = a
  }
  z = t[i]
}
