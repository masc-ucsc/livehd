/*
:name: mem_write_only_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `wro` with the same LCG stimulus as mem_write_only_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const wro = import("mem_write_only.wro")

test mem_write_only.sig {
  mut acc = wro
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.i = s & 0x3
    s = s * 6364136223846793005 + 1442695040888963407
    acc.p = s & 0xff
    step
    if clock >= 32 {
      sig = sig * 1099511628211 + (acc.z & 0xff)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 186306077265721428, "signature mismatch vs iverilog golden mem_write_only")
}
