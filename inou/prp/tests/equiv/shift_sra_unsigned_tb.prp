/*
:name: shift_sra_unsigned_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `top` with the same LCG stimulus as shift_sra_unsigned_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const top = import("shift_sra_unsigned.top")

test shift_sra_unsigned.sig {
  mut acc = top
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.b = s & 0x3
    step
    sig = sig * 1099511628211 + (acc.r & 0xff)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 2937647232856380712, "signature mismatch vs iverilog golden shift_sra_unsigned")
}
