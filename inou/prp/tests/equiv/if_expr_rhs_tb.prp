/*
:name: if_expr_rhs_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `ifsel` with the same LCG stimulus as if_expr_rhs_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const ifsel = import("if_expr_rhs.ifsel")

test if_expr_rhs.sig {
  mut acc = ifsel
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.c = s & 0x1
    s = s * 6364136223846793005 + 1442695040888963407
    acc.d = s & 0x1
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.b = s & 0xff
    step
    sig = sig * 1099511628211 + (acc.o & 0xff)
    sig = sig * 1099511628211 + (acc.p & 0xff)
    sig = sig * 1099511628211 + (acc.q & 0xff)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 966306568634752560, "signature mismatch vs iverilog golden if_expr_rhs")
}
