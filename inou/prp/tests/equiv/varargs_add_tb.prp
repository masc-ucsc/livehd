// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `top` with the same LCG stimulus as varargs_add_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const top = import("varargs_add.top")

test varargs_add.sig {
  mut acc = top
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.b = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.c = s & 0xff
    step
    sig = sig * 1099511628211 + (acc.z & 0x1ff)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 4551189516833295052, "signature mismatch vs iverilog golden varargs_add")
}
