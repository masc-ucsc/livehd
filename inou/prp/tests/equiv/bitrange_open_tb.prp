/*
:name: bitrange_open_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `osel` with the same LCG stimulus as bitrange_open_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const osel = import("bitrange_open.osel")

test bitrange_open.sig {
  mut acc = osel
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xffff
    step
    sig = sig * 1099511628211 + (acc.zfull & 0xffff)
    sig = sig * 1099511628211 + (acc.zoff & 0x7ff)
    sig = sig * 1099511628211 + (acc.zmsb & 0x1)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 1589454380756383321, "signature mismatch vs iverilog golden bitrange_open")
}
