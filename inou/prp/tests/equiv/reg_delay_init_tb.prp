/*
:name: reg_delay_init_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `delay` with the same LCG stimulus as reg_delay_init_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const delay = import("reg_delay_init.delay")

test reg_delay_init.sig {
  mut acc = delay
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    acc.reset = clock < 4
    step
    if clock >= 4 {
      sig = sig * 1099511628211 + (acc.o & 0x1ff)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 2099683587728952582, "signature mismatch vs iverilog golden reg_delay_init")
}
