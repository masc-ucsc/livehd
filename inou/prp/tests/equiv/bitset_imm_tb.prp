// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `foo` with the same LCG stimulus as bitset_imm_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const foo = import("bitset_imm.foo")

test bitset_imm.sig {
  mut acc = foo
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.i = s & 0xffffffff
    step
    sig = sig * 1099511628211 + acc.io_sextImm
    sig = sig * 1099511628211 + acc.io_zext
    sig = sig * 1099511628211 + (acc.io_direct & 0x1fff)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 3507276469204875038, "signature mismatch vs iverilog golden bitset_imm")
}
