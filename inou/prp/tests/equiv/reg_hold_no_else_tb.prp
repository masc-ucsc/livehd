/*
:name: reg_hold_no_else_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `regfile` with the same LCG stimulus as reg_hold_no_else_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const regfile = import("reg_hold_no_else.regfile")

test reg_hold_no_else.sig {
  mut acc = regfile
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.we_a = s & 0x1
    s = s * 6364136223846793005 + 1442695040888963407
    acc.we_b = s & 0x1
    s = s * 6364136223846793005 + 1442695040888963407
    acc.adata = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.bdata = s & 0xff
    acc.reset = clock < 4
    step
    if clock >= 4 {
      sig = sig * 1099511628211 + (acc.q & 0xff)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 2848668768103485984, "signature mismatch vs iverilog golden reg_hold_no_else")
}
