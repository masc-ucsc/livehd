/*
:name: reduce_xor
:type: equiv
:verilog_top: reduce_xor.foo
:pyrope_top: reduce_xor.foo
*/

// XOR-reduction (parity) `foo#^[range]` lowers to a balanced binary tree of
// 2-input Xor cells over the selected bits. Widths exercise both power-of-2
// (2, 4, 16) and non-power-of-2 (3, 5, 7) leaf counts so the odd-leaf
// carry-up branch is covered, plus unsigned/signed and the open `#[..]` form.
comb foo(a:u16, b:s16) -> (
  x2:u1, x4:u1, x3:u1, x5:u1, x7:u1, xf:u1, xs:u1, x1:u1
) {
  x2 = a#^[0..=1]    // 2 bits  (power of 2)
  x4 = a#^[0..=3]    // 4 bits  (power of 2)
  x3 = a#^[0..=2]    // 3 bits  (non-power of 2)
  x5 = a#^[0..=4]    // 5 bits  (non-power of 2)
  x7 = a#^[2..=8]    // 7 bits  (non-power of 2)
  xf = a#^[..]       // 16 bits (full type width)
  xs = b#^[3..=9]    // 7 bits, signed operand
  x1 = a#^[6]        // single bit (k==1)
}
