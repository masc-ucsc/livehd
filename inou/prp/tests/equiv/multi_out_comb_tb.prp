/*
:name: multi_out_comb_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `top` with the same LCG stimulus as multi_out_comb_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const top = import("multi_out_comb.top")

test multi_out_comb.sig {
  mut acc = top
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.x = s & 0xff
    step
    sig = sig * 1099511628211 + (acc.os & 0x1ff)
    sig = sig * 1099511628211 + (acc.od & 0x1ff)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 162598261478780216, "signature mismatch vs iverilog golden multi_out_comb")
}
