    s = s * 6364136223846793005 + 1442695040888963407
    acc.b = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.c = s & 0xff
    step
    sig = sig * 1099511628211 + (acc.z & 0x7ff)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 2163070258336151904, "signature mismatch vs iverilog golden mod_varargs_add")
}
