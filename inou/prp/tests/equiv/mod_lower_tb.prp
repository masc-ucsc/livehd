/*
:name: mod_lower_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `foo` with the same LCG stimulus as mod_lower_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const foo = import("mod_lower.foo")

test mod_lower.sig {
  mut acc = foo
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.c = s & 0x7
    step
    sig = sig * 1099511628211 + (acc.rp2 & 0x7)
    sig = sig * 1099511628211 + (acc.rp2b & 0x3f)
    sig = sig * 1099511628211 + (acc.rfit & 0x7)
    sig = sig * 1099511628211 + (acc.rfit_big & 0xff)
    sig = sig * 1099511628211 + (acc.rone & 0x1)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 1960143745570062768, "signature mismatch vs iverilog golden mod_lower")
}
