/*
:name: reg_hold_empty_elif_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `pcunit` with the same LCG stimulus as reg_hold_empty_elif_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const pcunit = import("reg_hold_empty_elif.pcunit")

test reg_hold_empty_elif.sig {
  mut acc = pcunit
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.taken = s & 0x1
    s = s * 6364136223846793005 + 1442695040888963407
    acc.stall = s & 0x1
    s = s * 6364136223846793005 + 1442695040888963407
    acc.tgt = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.nx = s & 0xff
    acc.reset = clock < 4
    step
    if clock >= 4 {
      sig = sig * 1099511628211 + (acc.pc & 0xff)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 0, "signature mismatch vs iverilog golden reg_hold_empty_elif")
}
