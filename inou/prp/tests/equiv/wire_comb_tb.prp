/*
:name: wire_comb_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `wcomb` with the same LCG stimulus as wire_comb_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const wcomb = import("wire_comb.wcomb")

test wire_comb.sig {
  mut acc = wcomb
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    step
    sig = sig * 1099511628211 + (acc.o & 0x1ff)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 1746347941797942764, "signature mismatch vs iverilog golden wire_comb")
}
