/*
:name: mod_acc_state_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `acc` with the same LCG stimulus as mod_acc_state_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const acc = import("mod_acc_state.acc")

test mod_acc_state.sig {
  mut acc_ = acc
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc_.a = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc_.go = s & 0x1
    acc_.reset = clock < 4
    step
    if clock >= 4 {
      sig = sig * 1099511628211 + (acc_.out & 0xff)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 970734311702964132, "signature mismatch vs iverilog golden mod_acc_state")
}
