/*
:name: cond_modified_read_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `condread` with the same LCG stimulus as cond_modified_read_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const condread = import("cond_modified_read.condread")

test cond_modified_read.sig {
  mut acc = condread
  mut s_   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s_ = s_ * 6364136223846793005 + 1442695040888963407
    acc.s = s_ & 0x1
    s_ = s_ * 6364136223846793005 + 1442695040888963407
    acc.b = s_ & 0x1
    step
    sig = sig * 1099511628211 + (acc.g & 0x1)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 0, "signature mismatch vs iverilog golden cond_modified_read")
}
