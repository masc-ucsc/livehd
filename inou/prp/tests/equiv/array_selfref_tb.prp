// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `top` with the same LCG stimulus as array_selfref_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const top = import("array_selfref.top")

test array_selfref.sig {
  mut acc = top
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a_0 = s & 0x3
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a_1 = s & 0x3
    step
    sig = sig * 1099511628211 + (acc.z & 0x3)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 2020557288129551344, "signature mismatch vs iverilog golden array_selfref")
}
