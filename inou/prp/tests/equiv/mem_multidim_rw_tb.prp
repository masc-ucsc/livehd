const md = import("mem_multidim_rw.md")

test mem_multidim_rw.sig {
  mut acc = md
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.wi = s & 0x1
    s = s * 6364136223846793005 + 1442695040888963407
    acc.wj = s & 0x3
    s = s * 6364136223846793005 + 1442695040888963407
    acc.ri = s & 0x1
    s = s * 6364136223846793005 + 1442695040888963407
    acc.rj = s & 0x3
    s = s * 6364136223846793005 + 1442695040888963407
    acc.we = s & 0x1
    step
    if clock >= 32 {
      sig = sig * 1099511628211 + (acc.z & 0xff)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 4108729743880471064, "signature mismatch vs iverilog golden mem_multidim_rw")
}
