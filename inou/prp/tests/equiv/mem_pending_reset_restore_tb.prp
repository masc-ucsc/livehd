// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `restore` with the same LCG stimulus as mem_pending_reset_restore_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const restore = import("mem_pending_reset_restore.restore")

test mem_pending_reset_restore.sig {
  mut acc = restore
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xf
    s = s * 6364136223846793005 + 1442695040888963407
    acc.i = s & 0x1
    s = s * 6364136223846793005 + 1442695040888963407
    acc.we = s & 0x1
    acc.reset = clock < 4
    step
    if clock >= 4 {
      sig = sig * 1099511628211 + (acc.z & 0xf)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 4496201036690673682, "signature mismatch vs iverilog golden mem_pending_reset_restore")
}
