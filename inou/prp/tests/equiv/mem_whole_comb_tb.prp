// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `combarr` with the same LCG stimulus as mem_whole_comb_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const combarr = import("mem_whole_comb.combarr")

test mem_whole_comb.sig {
  mut acc = combarr
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.inp = s
    s = s * 6364136223846793005 + 1442695040888963407
    acc.idx = s & 0x7
    step
    sig = sig * 1099511628211 + (acc.r & 0x3ff)
    sig = sig * 1099511628211 + acc.allout
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 2971933437981023685, "signature mismatch vs iverilog golden mem_whole_comb")
}
