/*
:name: reduce_xor_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `foo` with the same LCG stimulus as reduce_xor_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const foo = import("reduce_xor.foo")

test reduce_xor.sig {
  mut acc = foo
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xffff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.b = s & 0xffff
    step
    sig = sig * 1099511628211 + (acc.x2 & 0x1)
    sig = sig * 1099511628211 + (acc.x4 & 0x1)
    sig = sig * 1099511628211 + (acc.x3 & 0x1)
    sig = sig * 1099511628211 + (acc.x5 & 0x1)
    sig = sig * 1099511628211 + (acc.x7 & 0x1)
    sig = sig * 1099511628211 + (acc.xf & 0x1)
    sig = sig * 1099511628211 + (acc.xs & 0x1)
    sig = sig * 1099511628211 + (acc.x1 & 0x1)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 2969495134007276620, "signature mismatch vs iverilog golden reduce_xor")
}
