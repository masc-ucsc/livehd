/*
:name: mod_mixed_out_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `mix` with the same LCG stimulus as mod_mixed_out_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const mix = import("mod_mixed_out.mix")

test mod_mixed_out.sig {
  mut acc = mix
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    step
    if clock >= 32 {
      sig = sig * 1099511628211 + (acc.x & 0xff)
      sig = sig * 1099511628211 + (acc.y & 0xff)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 4036892741767205152, "signature mismatch vs iverilog golden mod_mixed_out")
}
