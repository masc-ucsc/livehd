/*
:name: mem_pending_sync_init_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `syncinit` with the same LCG stimulus as mem_pending_sync_init_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const syncinit = import("mem_pending_sync_init.syncinit")

test mem_pending_sync_init.sig {
  mut acc = syncinit
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.raddr = s & 0x3
    step
    if clock >= 32 {
      sig = sig * 1099511628211 + (acc.q & 0xf)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 3755842327876405268, "signature mismatch vs iverilog golden mem_pending_sync_init")
}
