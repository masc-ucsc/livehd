/*
:name: mod_call_pipe2
:type: equiv
:verilog_top: mod_call_pipe2.top
:pyrope_top: mod_call_pipe2.top
*/

pipe[1..=10] mul(a:u16, b:u16) -> (c:u32) { c = a * b }
// mod_call_pipe.prp has: comb mul(a:u16, b:u16) -> (c:u32) { c = a * b }

mod top(in1:u16, in2:u16) -> (out:u32@[3]) {
  stage[3] out = mul(a=in1, b=in2)
  //out = tmp
}
