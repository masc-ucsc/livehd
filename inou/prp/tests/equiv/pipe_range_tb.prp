// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `flex` with the same LCG stimulus as pipe_range_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const flex = import("pipe_range.flex")

test pipe_range.sig {
  mut acc = flex
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    step
    if clock >= 32 {
      sig = sig * 1099511628211 + (acc.d & 0x1ff)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 1176674272311324668, "signature mismatch vs iverilog golden pipe_range")
}
