/*
:name: mod_call_mod_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `top` with the same LCG stimulus as mod_call_mod_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const top = import("mod_call_mod.top")

test mod_call_mod.sig {
  mut acc = top
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    step
    if clock >= 32 {
      sig = sig * 1099511628211 + (acc.out & 0xff)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 2497764777245894892, "signature mismatch vs iverilog golden mod_call_mod")
}
