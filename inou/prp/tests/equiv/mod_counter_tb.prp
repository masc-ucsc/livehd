/*
:name: mod_counter_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `counter` with the same LCG stimulus as mod_counter_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const counter = import("mod_counter.counter")

test mod_counter.sig {
  mut acc = counter
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.enable = s & 0x1
    acc.reset = clock < 4
    step
    if clock >= 4 {
      sig = sig * 1099511628211 + (acc.count & 0xff)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 337060791082249240, "signature mismatch vs iverilog golden mod_counter")
}
