/*
:name: reg_out_feedforward_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `addreg` with the same LCG stimulus as reg_out_feedforward_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const addreg = import("reg_out_feedforward.addreg")

test reg_out_feedforward.sig {
  mut acc = addreg
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.b = s & 0xff
    step
    if clock >= 32 {
      sig = sig * 1099511628211 + (acc.q & 0x1ff)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 934314523336112544, "signature mismatch vs iverilog golden reg_out_feedforward")
}
