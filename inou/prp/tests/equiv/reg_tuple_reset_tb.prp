/*
:name: reg_tuple_reset_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `rtr` with the same LCG stimulus as reg_tuple_reset_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const rtr = import("reg_tuple_reset.rtr")

test reg_tuple_reset.sig {
  mut acc = rtr
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.en = s & 0x1
    s = s * 6364136223846793005 + 1442695040888963407
    acc.wx = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.wy = s & 0xf
    acc.reset = clock < 4
    step
    if clock >= 4 {
      sig = sig * 1099511628211 + (acc.ox & 0xff)
      sig = sig * 1099511628211 + (acc.oy & 0xf)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 64482425403196156, "signature mismatch vs iverilog golden reg_tuple_reset")
}
