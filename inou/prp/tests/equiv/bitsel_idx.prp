/*
:name: bitsel_idx
:type: equiv
:verilog_top: bitsel_idx.bsel
:pyrope_top: bsel
*/

// Runtime (non-comptime) single-bit select via the NATIVE `g#[idx]` syntax
// (todo "Runtime bit index a#[i]"). prp2lnast lowers the index to the one-hot
// mask `1<<idx`; tolg's lower_dynamic_bit_select turns the runtime get_mask
// into `|(g & (1<<idx))` — equal to the documented `(g>>idx)&1` workaround and
// LEC-equivalent to the Verilog element select `g[idx]` (the golden).
pub comb bsel(g:u16, idx:u4) -> (z:u1) {
  z = g#[idx]
}
