/*
:name: instance_collapse_order
:type: equiv
:verilog_top: instance_collapse_order.top
:pyrope_top: instance_collapse_order.top
*/

// Hierarchical-LEC STATELESS box-instance pairing guard (see the .v header
// for the full story). The four `icso_lane_parity` instances below are
// DELIBERATELY declared in the opposite order from the golden .v. This pair
// used to falsely REFUTE: hierarchical collapse corresponded box instances by
// traversal-order occurrence counters (`defname#N`), so the reversed order
// mispaired lane i with lane j and the box-input congruence compare (`bbin:`
// taps) refuted an EQUIVALENT design (the residual BypassNetwork LEC-lhd fail,
// 24 UIntExtractor_24 instances, after lec.gold_x=ignore removed its
// X false-refute). A stateless collapsed leaf is now PAIRING-FREE — each
// output is UF_def_port(inputs) with the UF shared per (def, port) across
// both designs and all instances, so congruence pairs the lanes dynamically
// and the collapsed parent proves directly regardless of declaration order
// (see Comb_box in pass/lec/encode.hpp). Repro by hand:
//   lhd lec --ref verilog:instance_collapse_order.v \
//           --impl pyrope:instance_collapse_order.prp \
//           --ref-top 'instance_collapse_order.top' \
//           --impl-top 'instance_collapse_order.top'
pub comb lane_parity::[lg="icso_lane_parity"](a:u8) -> (p:u1) {
  p = a#[0] ^ a#[1] ^ a#[2] ^ a#[3] ^ a#[4] ^ a#[5] ^ a#[6] ^ a#[7]
}

pub comb top::[lg="instance_collapse_order.top"](d:u32) -> (q:u4) {
  mut p3 = lane_parity::[name=u3](a = (d >> 24) & 0xff)
  mut p2 = lane_parity::[name=u2](a = (d >> 16) & 0xff)
  mut p1 = lane_parity::[name=u1](a = (d >> 8) & 0xff)
  mut p0 = lane_parity::[name=u0](a = d & 0xff)
  q = (p3 << 3) | (p2 << 2) | (p1 << 1) | p0
}
