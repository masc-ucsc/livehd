// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `top` with the same LCG stimulus as mod_call_pipe2_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const top = import("mod_call_pipe2.top")

test mod_call_pipe2.sig {
  mut acc = top
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.in1 = s & 0xffff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.in2 = s & 0xffff
    step
    if clock >= 32 {
      sig = sig * 1099511628211 + (acc.out & 0xffffffff)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 2432426238634762216, "signature mismatch vs iverilog golden mod_call_pipe2")
}
