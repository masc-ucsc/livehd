// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `coexist` with the same LCG stimulus as mem_whole_coexist_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const coexist = import("mem_whole_coexist.coexist")

test mem_whole_coexist.sig {
  mut acc = coexist
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.inp = s
    s = s * 6364136223846793005 + 1442695040888963407
    acc.waddr = s & 0x7
    s = s * 6364136223846793005 + 1442695040888963407
    acc.wdata = s & 0x3ff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.we = s & 0x1
    s = s * 6364136223846793005 + 1442695040888963407
    acc.idx = s & 0x7
    step
    if clock >= 32 {
      sig = sig * 1099511628211 + (acc.r & 0x3ff)
      sig = sig * 1099511628211 + acc.allout
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 3178469101321514565, "signature mismatch vs iverilog golden mem_whole_coexist")
}
