const sim_packed_selfref_1bit = import("sim_packed_selfref_1bit.sim_packed_selfref_1bit")

test sim_packed_selfref_1bit.sig {
  mut acc = sim_packed_selfref_1bit
  mut s   = 0x1234567890ABCDEF
