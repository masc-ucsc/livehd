/*
:name: wire_typed_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `wt` with the same LCG stimulus as wire_typed_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const wt = import("wire_typed.wt")

test wire_typed.sig {
  mut acc = wt
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    step
    sig = sig * 1099511628211 + (acc.o1 & 0xf)
    sig = sig * 1099511628211 + (acc.o2 & 0xf)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 2169835434032295120, "signature mismatch vs iverilog golden wire_typed")
}
