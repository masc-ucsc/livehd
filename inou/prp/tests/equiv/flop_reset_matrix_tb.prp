/*
:name: flop_reset_matrix_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `matrix` with the same LCG stimulus as flop_reset_matrix_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const matrix = import("flop_reset_matrix.matrix")

test flop_reset_matrix.sig {
  mut acc = matrix
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.reset_n = s & 0x1
    s = s * 6364136223846793005 + 1442695040888963407
    acc.en = s & 0x1
    acc.reset = clock < 4
    step
    if clock >= 4 {
      sig = sig * 1099511628211 + (acc.q_pp & 0xff)
      sig = sig * 1099511628211 + (acc.q_pn & 0xff)
      sig = sig * 1099511628211 + (acc.q_ps & 0xff)
      sig = sig * 1099511628211 + (acc.q_np & 0xff)
      sig = sig * 1099511628211 + (acc.q_nn & 0xff)
      sig = sig * 1099511628211 + (acc.q_ns & 0xff)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 867573074580689528, "signature mismatch vs iverilog golden flop_reset_matrix")
}
