/*
:name: reduce_popcount_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `foo` with the same LCG stimulus as reduce_popcount_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const foo = import("reduce_popcount.foo")

test reduce_popcount.sig {
  mut acc = foo
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xffff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.b = s & 0xffff
    step
    sig = sig * 1099511628211 + (acc.p2 & 0x3)
    sig = sig * 1099511628211 + (acc.p4 & 0x7)
    sig = sig * 1099511628211 + (acc.p3 & 0x3)
    sig = sig * 1099511628211 + (acc.p5 & 0x7)
    sig = sig * 1099511628211 + (acc.p7 & 0x7)
    sig = sig * 1099511628211 + (acc.pf & 0x1f)
    sig = sig * 1099511628211 + (acc.ps & 0xf)
    sig = sig * 1099511628211 + (acc.p1 & 0x1)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 509276030826819284, "signature mismatch vs iverilog golden reduce_popcount")
}
