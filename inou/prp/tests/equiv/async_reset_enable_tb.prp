// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `pipe` with the same LCG stimulus as async_reset_enable_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const pipe_ = import("async_reset_enable.pipe")

test async_reset_enable.sig {
  mut acc = pipe_
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.en = s & 0x1
    s = s * 6364136223846793005 + 1442695040888963407
    acc.arst = s & 0x1
    s = s * 6364136223846793005 + 1442695040888963407
    acc.d = s & 0xff
    acc.reset = clock < 4
    step
    if clock >= 4 {
      sig = sig * 1099511628211 + (acc.q & 0xff)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 2069492224545670168, "signature mismatch vs iverilog golden async_reset_enable")
}
