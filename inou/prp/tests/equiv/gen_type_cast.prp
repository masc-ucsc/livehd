/*
:name: gen_type_cast
:type: equiv
:verilog_top: gen_type_cast.top
:pyrope_top: top
*/

// FAILING tracker (generics body-binding gap, todo 3g subtask A): a generic
// type parameter used as a CONSTRUCTOR / cast inside the lambda body — `T(a)`
// — is not bound. Since the prpparse front-end swap this fails EARLY at name
// resolution (it used to reach tolg and abort on an `inl1_T` call):
//
//   undefined-call: call to undefined function 'T' (no such
//   `comb`/`mod`/`pipe`, variable, or built-in)
//
// Body references of a generic name are broken across the board — the type
// annotation form `mut tmp:T = a` fails too (unknown-type; tracked separately
// by //inou/prp:prp-tbd-generic_body_type). Once body binding substitutes the
// concrete entity, `widen<u8>(a)` is `u32(u8(a)) + 1` == `a + 1` (32-bit) —
// proven equivalent to the golden below (validated by LEC against the
// `mut tmp:u8 = a; r = u32(tmp) + 1` form).

comb widen<T>(a:T) -> (r:u32) {
  r = u32(T(a)) + 1
}

pub comb top(x:u8) -> (r:u32) {
  r = widen<u8>(a=x)
}
