// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `passthru` with the same LCG stimulus as pipe1_pass_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const passthru = import("pipe1_pass.passthru")

test pipe1_pass.sig {
  mut acc = passthru
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    step
    if clock >= 32 {
      sig = sig * 1099511628211 + (acc.o & 0xff)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 1763523098703638636, "signature mismatch vs iverilog golden pipe1_pass")
}
