const condconst = import("mem_whole_cond_const.condconst")

test mem_whole_cond_const.sig {
  mut acc = condconst
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.clr = s & 0x1
    s = s * 6364136223846793005 + 1442695040888963407
    acc.fill = s & 0x1
    s = s * 6364136223846793005 + 1442695040888963407
    acc.we = s & 0x1
    s = s * 6364136223846793005 + 1442695040888963407
    acc.waddr = s & 0x7
    s = s * 6364136223846793005 + 1442695040888963407
    acc.wdata = s & 0x3ff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.idx = s & 0x7
    step
    if clock >= 32 {
      sig = sig * 1099511628211 + (acc.r & 0x3ff)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 4360102869586704624, "signature mismatch vs iverilog golden mem_whole_cond_const")
}
