/*
:name: sim_lg_atomic_feedback_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `top` with the same LCG stimulus as sim_lg_atomic_feedback_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const top = import("sim_lg_atomic_feedback.top")

test sim_lg_atomic_feedback.sig {
  mut acc = top
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.b = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.d = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.topx = s & 0xff
    step
    sig = sig * 1099511628211 + (acc.x_out & 0x1ff)
    sig = sig * 1099511628211 + (acc.y_out & 0x1ff)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 4306229565427162360, "signature mismatch vs iverilog golden sim_lg_atomic_feedback")
}
