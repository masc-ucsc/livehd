// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `msel` with the same LCG stimulus as match_no_else_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const msel = import("match_no_else.msel")

test match_no_else.sig {
  mut acc = msel
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.x = s & 0x3
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.b = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.c = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.d = s & 0xff
    step
    sig = sig * 1099511628211 + (acc.res & 0xff)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 2427914668028547720, "signature mismatch vs iverilog golden match_no_else")
}
