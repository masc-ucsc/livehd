/*
:name: mod_mul_add_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `multiply_add` with the same LCG stimulus as mod_mul_add_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const multiply_add = import("mod_mul_add.multiply_add")

test mod_mul_add.sig {
  mut acc = multiply_add
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.in1 = s & 0xffff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.in2 = s & 0xffff
    step
    if clock >= 32 {
      sig = sig * 1099511628211 + (acc.out & 0x1ffffffff)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 4539991667148915504, "signature mismatch vs iverilog golden mod_mul_add")
}
