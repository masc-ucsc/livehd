/*
:name: bit_sel_sext_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `bsel` with the same LCG stimulus as bit_sel_sext_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const bsel = import("bit_sel_sext.bsel")

test bit_sel_sext.sig {
  mut acc = bsel
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    step
    sig = sig * 1099511628211 + (acc.zout & 0xffffffff)
    sig = sig * 1099511628211 + (acc.sout & 0xff)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 3569050868211327165, "signature mismatch vs iverilog golden bit_sel_sext")
}
