/*
:name: mem_rtl_rf
:type: equiv
:verilog_top: mem_rtl_rf.rtlmem
:pyrope_top: mem_rtl_rf.rtlmem
*/

// 1a-mem — __memory(cfg) RTL instantiation (08-memories.md), cfg vocabulary
// = the Memory cell pins VERBATIM (no `latency`; `type` picks 0 async /
// 1 sync / 2 array; rdport entries are 0/1). A 2rd+1wr RF, fwd off: reads
// are async (combinational on the current address) and see the committed
// state only. res[N] is the N-th read port's data.
mod rtlmem(raddr0:u4, raddr1:u4, wraddr:u4, din0:u4, we0:bool) -> (q0:u4@[0], q1:u4@[0]) {
  mut mem = (
    addr      = (raddr0, raddr1, wraddr),
    bits      = 4,
    size      = 16,
    din       = (0, 0, din0),
    enable    = (1, 1, we0),
    fwd       = false,
    type      = 0,
    wensize   = 1,
    rdport    = (1, 1, 0),
  )
  mut res = __memory(mem)
  q0 = res[0]
  q1 = res[1]
}
