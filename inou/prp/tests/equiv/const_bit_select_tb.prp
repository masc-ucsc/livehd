// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `top` with the same LCG stimulus as const_bit_select_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const top = import("const_bit_select.top")

test const_bit_select.sig {
  mut acc = top
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.sel = s & 0x1
    s = s * 6364136223846793005 + 1442695040888963407
    acc.b = s & 0x1ff
    step
    sig = sig * 1099511628211 + (acc.o & 0xf)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 2857134258806982753, "signature mismatch vs iverilog golden const_bit_select")
}
