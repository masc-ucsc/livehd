/*
:name: trivial_if_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `fun3` with the same LCG stimulus as trivial_if_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const fun3 = import("trivial_if.fun3")

test trivial_if.sig {
  mut acc = fun3
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0x7
    s = s * 6364136223846793005 + 1442695040888963407
    acc.b = s & 0x7f
    s = s * 6364136223846793005 + 1442695040888963407
    acc.cond = s & 0x1
    step
    sig = sig * 1099511628211 + (acc.res & 0xf)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 877803379796293660, "signature mismatch vs iverilog golden trivial_if")
}
