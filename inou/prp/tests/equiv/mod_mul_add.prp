/*
:name: mod_mul_add
:type: equiv
:verilog_top: mod_mul_add.multiply_add
:pyrope_top: mod_mul_add.multiply_add
*/

// The 06c-pipelining.md canonical: two pipes at different latencies,
// aligned with an explicit stage delay; every @[N] discharges at LNAST.
pipe mul(a:u16, b:u16) -> (c:u32) { c = a * b }
// (u33 exact-width add until runtime `wrap` LG lowering lands)
pipe add(a:u32, b:u32) -> (c:u33) { c = a + b }

mod multiply_add(in1:u16, in2:u16) -> (out:u33@[4]) {
  stage[3] tmp     = mul(in1, in2)
  stage[3] in1_d   = in1
  stage[1] out@[4] = add(tmp@[3], in1_d@[3])
}
