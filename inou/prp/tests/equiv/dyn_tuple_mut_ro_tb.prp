/*
:name: dyn_tuple_mut_ro_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `msel` with the same LCG stimulus as dyn_tuple_mut_ro_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const msel = import("dyn_tuple_mut_ro.msel")

test dyn_tuple_mut_ro.sig {
  mut acc = msel
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.sel = s & 0x3
    step
    sig = sig * 1099511628211 + (acc.z & 0xff)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 703495381462517028, "signature mismatch vs iverilog golden dyn_tuple_mut_ro")
}
