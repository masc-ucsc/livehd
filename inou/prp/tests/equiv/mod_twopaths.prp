/*
:name: mod_twopaths
:type: equiv
:verilog_top: mod_twopaths.twopaths
:pyrope_top: mod_twopaths.twopaths
*/

// 1a-mem follow-up — multi-path landing cycles. `o` reaches the interface
// through 1 flop (tmp1) or 2 flops (tmp2) depending on `opt`: the mux SELECT
// never adds path depth, the arm intervals UNION to (1,2). The declaration
// either covers the interval (`@[1..=2]` / `@[1..<3]`) or opts out (`@[]`);
// a single `@[N]` would be rejected. Inline `@[...]` asserts work the same.
mod twopaths(a:u32, opt:bool) -> (o:u32@[], o2:u32@[1..=2]) {
  reg tmp1:u32 = nil
  reg tmp2:u32 = nil

  if opt {
    o = tmp1@[1]
  } else {
    o = tmp2@[2]
  }

  o2 = o@[1..<3]   // opt decides whether 1 or 2 flops are crossed

  tmp2 = tmp1@[1]  // pipe stage 1 -> 2
  tmp1 = a@[0]     // pipe stage 0 -> 1
}
