// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `top` with the same LCG stimulus as gen_type_cast_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const top = import("gen_type_cast.top")

test gen_type_cast.sig {
  mut acc = top
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.x = s & 0xff
    step
    sig = sig * 1099511628211 + (acc.r & 0xffffffff)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 1746347941797942764, "signature mismatch vs iverilog golden gen_type_cast")
}
