/*
:name: mem_mut_array_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `mutarr` with the same LCG stimulus as mem_mut_array_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const mutarr = import("mem_mut_array.mutarr")

test mem_mut_array.sig {
  mut acc = mutarr
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.wsel = s & 0x3
    s = s * 6364136223846793005 + 1442695040888963407
    acc.rsel = s & 0x3
    step
    sig = sig * 1099511628211 + (acc.z & 0xff)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 3045452026397501572, "signature mismatch vs iverilog golden mem_mut_array")
}
