    s_ = s_ * 6364136223846793005 + 1442695040888963407
    acc.b = s_ & 0xff
    step
    sig = sig * 1099511628211 + (acc.o & 0xff)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 1794039820240181904, "signature mismatch vs iverilog golden match_const_else")
}
