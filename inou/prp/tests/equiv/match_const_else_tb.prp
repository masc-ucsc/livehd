const t = import("match_const_else.t")

test match_const_else.sig {
  mut acc = t
  mut s_   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s_ = s_ * 6364136223846793005 + 1442695040888963407
