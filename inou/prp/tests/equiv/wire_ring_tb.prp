/*
:name: wire_ring_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `ring` with the same LCG stimulus as wire_ring_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const ring = import("wire_ring.ring")

test wire_ring.sig {
  mut acc = ring
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    acc.reset = clock < 4
    step
    if clock >= 4 {
      sig = sig * 1099511628211 + (acc.out & 0xff)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 2809252318551601616, "signature mismatch vs iverilog golden wire_ring")
}
