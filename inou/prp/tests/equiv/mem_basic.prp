/*
:name: mem_basic
:type: equiv
:verilog_top: mem_basic.memdut
:pyrope_top: mem_basic.memdut
*/

// 1a-mem — a reg array is an async Memory cell (type 0, fwd on): a write
// commits at the cycle edge; a same-cycle read of the written address sees
// the new value through forwarding (part of the cell abstraction). Like a
// scalar reg read, an ASYNC memory read returns committed state with no
// added stage — it lands @[0]; only a SYNC read (type=1) charges +1.
mod memdut(a:u8, wsel:u2, rsel:u2, we:bool) -> (z:u8@[0]) {
  reg t:[4]u8 = nil
  if we {
    t[wsel] = a
  }
  z = t[rsel]
}
