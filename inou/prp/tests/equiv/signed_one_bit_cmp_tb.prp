/*
:name: signed_one_bit_cmp_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `p` with the same LCG stimulus as signed_one_bit_cmp_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const p = import("signed_one_bit_cmp.p")

test signed_one_bit_cmp.sig {
  mut acc = p
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.x = s & 0xff
    step
    sig = sig * 1099511628211 + (acc.b & 0x1)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 1104349266517089973, "signature mismatch vs iverilog golden signed_one_bit_cmp")
}
