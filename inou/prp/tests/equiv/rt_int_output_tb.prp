// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `rt_int_output` with the same LCG stimulus as rt_int_output_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const rt_int_output = import("rt_int_output.rt_int_output")

test rt_int_output.sig {
  mut acc = rt_int_output
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xf
    s = s * 6364136223846793005 + 1442695040888963407
    acc.c = s & 0xf
    step
    sig = sig * 1099511628211 + (acc.zi & 0x3f)
    sig = sig * 1099511628211 + (acc.zu & 0x3f)
    sig = sig * 1099511628211 + (acc.zc & 0x1f)
    sig = sig * 1099511628211 + (acc.zk & 0x3ff)
    sig = sig * 1099511628211 + (acc.zn & 0x1ff)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 1718736179613569040, "signature mismatch vs iverilog golden rt_int_output")
}
