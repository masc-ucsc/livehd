/*
:name: tup_in_port
:type: equiv
:verilog_top: tup_in_port.top
:pyrope_top: tup_in_port.top
*/

// 2i-issues C — a tuple/struct-typed INPUT port whose fields are read inside an
// if-EXPRESSION. The io interface flattens to dotted leaves `ar.x`,`ar.y`, but
// the body's `ar.x`/`ar.y` reads sit inside the if-arm `stmts`, copied by the
// branch lowering. SSA (upass_ssa copy_branch_port_aware) rewrites those nested
// `tuple_get(ar,'x')` reads to the flattened leaf, so the port read lowers
// exactly like the hand-flattened twin. (Pairs with tup_out_port.)
pub comb top(ar:(x:u3, y:s4), cond:bool) -> (res:s5) {
  res = if cond { ar.x + 1 } else { ar.y - 1 }
}
