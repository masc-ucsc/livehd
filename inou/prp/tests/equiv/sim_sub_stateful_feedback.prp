/*
:name: sim_sub_stateful_feedback
:type: equiv
:verilog_top: sim_sub_stateful_feedback_top
:pyrope_top: sim_sub_stateful_feedback_top
*/

// FALSE combinational loop through a STATEFUL sub-instance (XiangShan
// DivUnit/SRT16DividerDataModule idiom). The sub's `ready` output is a pure
// register read (`busy` flop), and the fed-back input `kill` only affects the
// flop's NEXT value — no bit-level cycle exists. But cgen.sim schedules a Sub
// atomically (all inputs -> all outputs via one child.cycle()), and
// flatten_false_loop_subs declines because callee_is_pure_comb() rejects any
// callee containing a Flop, so the survivor errs `comb-loop-through-instance`.
pub mod busy_cell::[lg="sssf_busy_cell", hdl](start:u1, kill:u1) -> (ready:u1@[]) {
  reg busy:u1 = 0
  ready = busy ^ 1
  if kill != 0 {
    busy = 0
  } elif start != 0 {
    busy = 1
  }
}

pub mod top::[lg="sim_sub_stateful_feedback_top", hdl](go:u1, flush:u1) -> (ready_o:u1@[0]) {
  wire u_ready:u1
  wire kill:u1
  kill = (u_ready ^ 1) & flush     // depends on the instance's own output
  mut ures = busy_cell::[name=u](start = go, kill = kill)
  u_ready = ures.ready
  ready_o = u_ready
}
