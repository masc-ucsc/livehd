/*
:name: comb_single_out_op_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `csout` with the same LCG stimulus as comb_single_out_op_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const csout = import("comb_single_out_op.csout")

test comb_single_out_op.sig {
  mut acc = csout
  mut s_   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s_ = s_ * 6364136223846793005 + 1442695040888963407
    acc.a = s_ & 0xff
    s_ = s_ * 6364136223846793005 + 1442695040888963407
    acc.b = s_ & 0xff
    step
    sig = sig * 1099511628211 + (acc.s & 0x3ff)
    sig = sig * 1099511628211 + (acc.c & 0x1ff)
    sig = sig * 1099511628211 + (acc.d & 0x3ff)
    sig = sig * 1099511628211 + (acc.e & 0x1ff)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 4084091540730462272, "signature mismatch vs iverilog golden comb_single_out_op")
}
