/*
:name: sim_prp_packed_selfref
:type: equiv
:verilog_top: sim_prp_packed_selfref
:pyrope_top: sim_prp_packed_selfref
*/

// Repro for the EnqPolicy/Dispatcher lhd-sim emission category. This is a
// false word-level cycle: `hi` reads only io[3:2], and those bits are driven
// only by input `a`, but cgen.sim schedules the packed `io` value as one object
// and reports a combinational loop when emitting the Pyrope sim.
pub comb sim_prp_packed_selfref::[timecheck=false](a:u2) -> (z:u2) {
  wire io:u4
  wire hi:u2
  wire low:u2

  hi = io#[2..=3]
  low = hi & 3
  io = low | (a << 2)
  z = io#[0..=1]
}
