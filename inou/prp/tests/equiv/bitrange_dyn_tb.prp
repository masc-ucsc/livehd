/*
:name: bitrange_dyn_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `rsel` with the same LCG stimulus as bitrange_dyn_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const rsel = import("bitrange_dyn.rsel")

test bitrange_dyn.sig {
  mut acc = rsel
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xffff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.base = s & 0xf
    s = s * 6364136223846793005 + 1442695040888963407
    acc.len = s & 0x7
    step
    sig = sig * 1099511628211 + (acc.z & 0xffff)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 3033662316553131463, "signature mismatch vs iverilog golden bitrange_dyn")
}
