// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `acc_mix` with the same LCG stimulus as pipe_state_acc_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const acc_mix = import("pipe_state_acc.acc_mix")

test pipe_state_acc.sig {
  mut acc = acc_mix
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xf
    s = s * 6364136223846793005 + 1442695040888963407
    acc.b = s & 0xf
    acc.reset = clock < 4
    step
    if clock >= 4 {
      sig = sig * 1099511628211 + (acc.x & 0x1ff)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 2992334268227567529, "signature mismatch vs iverilog golden pipe_state_acc")
}
