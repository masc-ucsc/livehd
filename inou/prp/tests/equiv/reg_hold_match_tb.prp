/*
:name: reg_hold_match_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `selreg` with the same LCG stimulus as reg_hold_match_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const selreg = import("reg_hold_match.selreg")

test reg_hold_match.sig {
  mut acc = selreg
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.sel = s & 0x3
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.b = s & 0xff
    acc.reset = clock < 4
    step
    if clock >= 4 {
      sig = sig * 1099511628211 + (acc.q & 0xff)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 4111853156688622368, "signature mismatch vs iverilog golden reg_hold_match")
}
