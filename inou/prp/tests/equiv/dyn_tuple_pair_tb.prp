// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `sel2` with the same LCG stimulus as dyn_tuple_pair_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const sel2 = import("dyn_tuple_pair.sel2")

test dyn_tuple_pair.sig {
  mut acc = sel2
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.sel = s & 0x1
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.b = s & 0xff
    step
    sig = sig * 1099511628211 + (acc.z & 0xff)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 8375737633542640, "signature mismatch vs iverilog golden dyn_tuple_pair")
}
