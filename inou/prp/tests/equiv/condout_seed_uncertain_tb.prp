const seedmod = import("condout_seed_uncertain.seedmod")

test condout_seed_uncertain.sig {
  mut acc = seedmod
  mut s_   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s_ = s_ * 6364136223846793005 + 1442695040888963407
    acc.s = s_ & 0x1
    s_ = s_ * 6364136223846793005 + 1442695040888963407
    acc.t = s_ & 0x7
    step
    sig = sig * 1099511628211 + (acc.b & 0x1f)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 0, "signature mismatch vs iverilog golden condout_seed_uncertain")
}
