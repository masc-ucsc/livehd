/*
:name: bitset_mut_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `foo` with the same LCG stimulus as bitset_mut_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const foo = import("bitset_mut.foo")

test bitset_mut.sig {
  mut acc = foo
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.b = s & 0xff
    step
    sig = sig * 1099511628211 + (acc.o_cont & 0xfff)
    sig = sig * 1099511628211 + (acc.o_over & 0xfff)
    sig = sig * 1099511628211 + (acc.o_rev & 0xfff)
    sig = sig * 1099511628211 + (acc.o_gap & 0xfff)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 3907103131466705696, "signature mismatch vs iverilog golden bitset_mut")
}
