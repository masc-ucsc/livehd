// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `pa` with the same LCG stimulus as packed_assign_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const pa = import("packed_assign.pa")

test packed_assign.sig {
  mut acc = pa
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.sel = s & 0x3
    step
    sig = sig * 1099511628211 + (acc.z & 0xf)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 403444927762190170, "signature mismatch vs iverilog golden packed_assign")
}
