/*
:name: lead_or_chain_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `top` with the same LCG stimulus as lead_or_chain_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const top = import("lead_or_chain.top")

test lead_or_chain.sig {
  mut acc = top
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.sel = s & 0xf
    s = s * 6364136223846793005 + 1442695040888963407
    acc.x = s & 0xff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.y = s & 0xff
    step
    sig = sig * 1099511628211 + (acc.out1 & 0x1)
    sig = sig * 1099511628211 + (acc.out2 & 0x1)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 3342865803117809338, "signature mismatch vs iverilog golden lead_or_chain")
}
