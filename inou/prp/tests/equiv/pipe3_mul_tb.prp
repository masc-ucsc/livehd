// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `mul` with the same LCG stimulus as pipe3_mul_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const mul = import("pipe3_mul.mul")

test pipe3_mul.sig {
  mut acc = mul
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xffff
    s = s * 6364136223846793005 + 1442695040888963407
    acc.b = s & 0xffff
    step
    if clock >= 32 {
      sig = sig * 1099511628211 + (acc.c & 0xffffffff)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 2432426238634762216, "signature mismatch vs iverilog golden pipe3_mul")
}
