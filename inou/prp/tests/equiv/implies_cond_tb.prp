/*
:name: implies_cond_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `top` with the same LCG stimulus as implies_cond_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const top = import("implies_cond.top")

test implies_cond.sig {
  mut acc = top
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.req = s & 0x1
    s = s * 6364136223846793005 + 1442695040888963407
    acc.ack = s & 0x1
    s = s * 6364136223846793005 + 1442695040888963407
    acc.x = s & 0xf
    s = s * 6364136223846793005 + 1442695040888963407
    acc.y = s & 0xf
    step
    sig = sig * 1099511628211 + (acc.grant & 0x1)
    sig = sig * 1099511628211 + (acc.sel & 0xf)
    sig = sig * 1099511628211 + (acc.same & 0x1)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 2121173152353606016, "signature mismatch vs iverilog golden implies_cond")
}
