/*
:name: mod_passthru_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `passthru` with the same LCG stimulus as mod_passthru_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const passthru = import("mod_passthru.passthru")

test mod_passthru.sig {
  mut acc = passthru
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.a = s & 0xff
    step
    sig = sig * 1099511628211 + (acc.x & 0xff)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 2610057518563888284, "signature mismatch vs iverilog golden mod_passthru")
}
