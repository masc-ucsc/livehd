/*
:name: bitset_gap_tb
:type: simulation
*/
// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `foo` with the same LCG stimulus as bitset_gap_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const foo = import("bitset_gap.foo")

test bitset_gap.sig {
  mut acc = foo
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.i = s & 0xffffffff
    step
    sig = sig * 1099511628211 + (acc.out_gap & 0xffff)
    sig = sig * 1099511628211 + (acc.out_over & 0xffff)
    sig = sig * 1099511628211 + (acc.out_rev & 0x1fff)
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 419350174283675130, "signature mismatch vs iverilog golden bitset_gap")
}
