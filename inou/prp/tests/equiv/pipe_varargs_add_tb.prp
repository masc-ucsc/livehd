    if clock >= 32 {
      sig = sig * 1099511628211 + (acc.z & 0x3ff)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 361714174950711260, "signature mismatch vs iverilog golden pipe_varargs_add")
}
