/*
:name: bitset_nil
:type: equiv
:verilog_top: bitset_nil.foo
:pyrope_top: bitset_nil.foo
*/

// A `nil`-initialised accumulator (`mut b:uN = nil`) has no reset/init store,
// so it never gets a driver — using it as a bit-assembly base used to be a hard
// "unresolved reference" tolg error. It is now legal: the partial writes drive
// the covered bits and the (here fully covered) base contributes nothing.
// `b` covers ALL 13 bits, so the result is concrete (LEC-clean).
//
// `s` additionally exercises a SIGNED source slice: `i#sext[28..=31]` is a
// 4-bit signed value dropped into an 8-bit slot (bits 5..12), so the sign bit
// fans out across bits 9..12 — then a `#sext` read sign-extends the whole 13.
comb foo(i:u32) -> (io_sextImm:i64, io_direct:u13, s_sext:i64) {
  mut b:u13 = nil
  b#[0]      = i#[0]
  b#[1..=4]  = i#[8..=11]
  b#[5..=10] = i#[25..=30]
  b#[11]     = i#[7]
  b#[12]     = i#[31]
  io_sextImm = (b#sext[0..=12])#[0..=63]
  io_direct  = b

  mut s:u13 = nil
  s#[0..=4]  = i#[0..=4]
  s#[5..=12] = i#sext[28..=31]
  s_sext = (s#sext[0..=12])#[0..=63]
}
