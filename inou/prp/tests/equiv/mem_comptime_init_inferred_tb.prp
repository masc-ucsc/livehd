// AUTO-GENERATED by gen_equiv_tb.py -- differential sim regression.
// Drives `mcii` with the same LCG stimulus as mem_comptime_init_inferred_tb.v for 1000 cycles and
// checks the output signature against the Icarus-Verilog golden.
const mcii = import("mem_comptime_init_inferred.mcii")

test mem_comptime_init_inferred.sig {
  mut acc = mcii
  mut s   = 0x1234567890ABCDEF
  mut sig = 0
  tick 1000 {
    s = s * 6364136223846793005 + 1442695040888963407
    acc.i = s & 0x1
    s = s * 6364136223846793005 + 1442695040888963407
    acc.j = s & 0x1
    acc.reset = clock < 4
    step
    if clock >= 4 {
      sig = sig * 1099511628211 + (acc.z & 0xf)
    }
  }
  assert((sig & 0x3FFFFFFFFFFFFFFF) == 1272283683311590032, "signature mismatch vs iverilog golden mem_comptime_init_inferred")
}
