/*
:name: int_type_call_range
:type: error
:error: not a valid integer type bound
:help: max=
*/

// `unsigned(range=…)` would be pure sugar for `unsigned(max=,min=)`, so it is not
// a type argument — one way to bound an integer type.

const c:unsigned(range = 0..=15) = 5 // locate_error_here
cassert(c == 5)
