/*
:name: readonly_attr_range
:type: error
:error: not an attribute|cannot write
*/

// `range` is not an attribute: bounds are declared through a TYPE
// (`:signed(max=,min=)`, `:uN`/`:sN`). `:[range=…]` was legacy sugar for
// max/min and is rejected the same way as `:[max=]`/`:[min=]`.

mut x:signed:[range = 0..=15] = 1 // locate_error_here
cassert(x == 1)
