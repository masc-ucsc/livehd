/*
:name: assert_ifelse
:type: parsing lnast upass
*/

comb pick_max(a:u32, b:u32) -> (x:u32) {
  assert(a != b)

  x = match (a<b, a>b) {
    == (true, false)  { a }
    == (false, true)  { b }
    else              { a }   // unreachable: assert(a != b) above
  }
}

test "works" {
  assert(pick_max(a=3, b=50) == 50)
  assert(pick_max(a=0, b=5) == 5)
}
