/*
:name: seq_detect
:type: simulation
*/
// Simulation example: a "11" sequence detector that counts every pair of
// consecutive 1 bits. A fixed pattern is streamed one bit per cycle: each `tick`
// iteration pokes this cycle's bit, advances one clock with `step`, and peeks
// the count. A test-local golden model mirrors the detector.

mod seq_detect(din:bool) -> (count:u8@[0]) {
  reg prev:bool = false
  reg cnt:u8    = 0

  count = cnt                       // combinational read of cnt.q -> @[0]

  if prev and din { wrap cnt += 1 } // saw two consecutive 1s
  prev = din
}

test detect.stream {
  const pattern = [true, true, true, false, true, true]  // 6-cycle stimulus

  mut acc     = seq_detect
  mut gprev   = false               // golden: previous bit
  mut gcnt    = 0                   // golden: detection count
  mut c_final = nil
  tick 6 {
    const s = pattern[clock]               // this cycle's bit
    acc.din = s
    if gprev and s { gcnt = gcnt + 1 }     // golden mirror of cnt
    gprev = s
    step
    c_final = acc.count
  }
  // pattern 1,1,1,0,1,1 has three "11" pairs
  assert(c_final == gcnt, "detector disagrees with golden model")
  assert(c_final == 3)
}
