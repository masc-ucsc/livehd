/*
:name: counter
:type: simulation
*/
// Simulation example: a free-running up-counter, driven in the instance/`step`
// style. The DUT is a persistent instance (`mut acc = counter`): each `tick`
// iteration pokes this cycle's inputs, advances one clock with `step`, then
// peeks the output. `clock` is the 0-based cycle index; reset is just an input
// (`acc.reset = clock < 2`). VCD (`--set sim.vcd=true`) shows the clock toggling
// and reset/inputs as ordinary traced signals.

mod counter(enable:bool) -> (value:u8@[0]) {
  reg count:u8 = 0

  value = count                 // combinational read of count.q -> @[0]

  if enable { wrap count += 1 }
}

// Test 1: enable held high, reset asserted for the first 2 cycles. The reset
// input zeroes `count`, so it stays 0 during the 2-cycle window and then counts
// for the remaining cycles -> cycles - 2.
test counter.held_high(cycles:u20=20) {
  mut acc     = counter
  mut v_final = nil
  tick cycles {
    acc.enable = true
    acc.reset  = clock < 2        // hold reset for cycles 0 and 1
    step
    v_final = acc.value
  }
  assert(v_final == cycles - 2, "count must be (cycles - reset_cycles) = cycles - 2")
}

// Test 2: enable toggled every cycle. A test-local golden value mirrors the
// register's next-state so the end-of-sim assert is self-checking.
test counter.gated {
  mut acc      = counter
  mut en       = false
  mut expected = 0
  mut v_final  = nil
  tick 20 {
    en = not en                       // this cycle's enable
    if en { expected = expected + 1 } // golden mirror of count
    acc.enable = en
    step
    v_final = acc.value
  }
  // enable was high on 10 of the 20 cycles
  assert(v_final == expected, "gated counter disagrees with golden model")
  assert(v_final == 10)
}
