/*
:name: accumulator
:type: simulation
*/
// Simulation example: a running-sum accumulator fed a changing input.
//
// Each `tick` iteration is one cycle: the accumulator is called with this
// cycle's `din`, the loop advances the clock, and the returned `sum` is
// captured. A test-local golden value mirrors the accumulated total so the
// end-of-sim `assert` is self-checking.

mod accumulator(din:u8) -> (sum:u32@[0]) {
  reg total:u32 = 0

  sum = total                   // combinational read of total.q -> @[0]

  wrap total = total + din      // registered next-state
}

test accum.sum {
  mut i:u8 = 0
  mut expected = 0
  mut s_final = nil
  tick 8 {
    expected = expected + i           // golden mirror: total += din
    const s = accumulator(din=i)      // this cycle's input is i
    s_final = s
    wrap i = i + 1
  }
  // total == 0 + 1 + 2 + ... + 7 == 28 after 8 cycles
  assert(s_final == expected, "accumulator disagrees with golden model")
  assert(s_final == 28)
}
