/*
:name: accumulator
:type: simulation
*/
// Simulation example: a running-sum accumulator fed a changing input, driven in
// the instance/`step` style. Each `tick` iteration pokes `din`, advances the
// clock with `step`, and peeks `sum`. A test-local golden value mirrors the
// accumulated total so the end-of-sim `assert` is self-checking.

mod accumulator(din:u8) -> (sum:u32@[0]) {
  reg total:u32 = 0

  sum = total                   // combinational read of total.q -> @[0]

  wrap total = total + din      // registered next-state
}

test accum.sum {
  mut acc      = accumulator
  mut expected = 0
  mut s_final  = nil
  tick 8 {
    acc.din  = clock            // this cycle's input is the cycle index
    expected = expected + clock // golden mirror: total += din
    step
    s_final = acc.sum
  }
  // total == 0 + 1 + 2 + ... + 7 == 28 after 8 cycles
  assert(s_final == expected, "accumulator disagrees with golden model")
  assert(s_final == 28)
}
