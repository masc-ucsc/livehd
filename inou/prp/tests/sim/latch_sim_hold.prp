/*
:name: latch_sim_hold
:type: simulation
*/

// todo/livehd/2f-latch — LIVE (promoted at M5). Simulation of a transparent-HIGH latch:
// open a window, close it with d stable, then wiggle d while closed and check
// the latch HOLDS. Flips green at M5 (latch commit classes in cgen_sim); M0
// only changes the failure mode (today `lhd sim` dies with a misleading
// `combinational-loop` error naming an internal node — M0 replaces that with a
// real "latch unsupported in sim" diagnostic, and this test keeps failing until
// M5 actually simulates the latch).
//
// ASSERT-VISIBILITY RULE (2f-latch): asserts observe q only in ticks where the
// latch is CLOSED (gate deasserted) and never straddle a closing edge with a
// changing d. In those ticks the real-transparency semantics (Icarus on the
// golden), the commit-at-closing-edge model, and a flop-with-enable encoding
// all agree, so this fixture does not pin an implementation choice. The
// schedule was validated against iverilog (always_latch golden, per-frame
// sampling): q = 5,5,5,5,42,42.
pub mod lhold8(en:bool, d:u8) -> (q:u8@[0]) {
  reg l:u8:[latch=true]
  q = l
  if en {
    l = d
  }
}

test lhold8.window_capture_and_hold {
  mut acc = lhold8
  tick 6 {
    // c0: open on d=5; c1: close with d STABLE; c2-c3: wiggle d while closed;
    // c4: reopen on d=42; c5: close with d stable
    acc.en = (clock == 0) or (clock == 4)
    mut dv:u8 = 42
    if clock <= 1 {
      dv = 5
    } elif clock == 2 {
      dv = 99
    } elif clock == 3 {
      dv = 77
    }
    acc.d = dv
    step
    if (clock >= 1) and (clock <= 3) {
      assert(acc.q == 5, "latch captured 5 at the closing edge and holds it")
    }
    if clock == 5 {
      assert(acc.q == 42, "second window captured 42")
    }
  }
}
